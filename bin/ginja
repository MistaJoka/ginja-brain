@cli.command()
@click.argument("query", nargs=-1, required=True)
@click.option("--top", "-n", default=10, help="Number of results")
def recall(query, top):
    """Search your memory semantically."""
    cfg = load_config()
    q = " ".join(query)
    try:
        results = search_memory(q, cfg, top_k=top)
        if not results:
            console.print("[yellow]No relevant memories found.[/yellow]")
            return
        table = Table(title=f'Memory: "{q}"', show_lines=True)
