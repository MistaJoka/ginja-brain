@click.group()
def cli():
    """ginja — Your AI extension."""
    pass


@cli.command()
@click.argument("query", nargs=-1, required=True)
@click.option("--model", "-m", default=None, help="Override model")
@click.option("--fast", "-f", is_flag=True, help="Force fast 3B model (100% GPU)")
@click.option("--quality", "-q", is_flag=True, help="Force quality 7B model")
@click.option("--no-memory", is_flag=True, help="Skip memory retrieval")
def ask(query, model, fast, quality, no_memory):
    """Ask anything — streams the answer and saves to memory."""
    cfg = load_config()
    q = " ".join(query)
    if model:
        chosen = model
    elif fast:
        chosen = cfg["fast_model"]
    elif quality:
        chosen = cfg.get("quality_model", "mistral:7b")
    else:
        chosen = pick_model(q, cfg)

    memories = []
    if not no_memory:
        try:
            memories = search_memory(q, cfg, top_k=cfg["top_k_memories"])
        except Exception:
            pass

    prompt = build_prompt(q, load_persona(), memories, shell_context())
    response = ask_with_fallback(prompt, cfg, chosen)

    if cfg.get("save_conversations") and response:
        try:
            store_memory(
                f"Q: {q[:200]}\nA: {response[:500]}",
                cfg, collection="conversations", source="ask",
            )
        except Exception:
            pass


