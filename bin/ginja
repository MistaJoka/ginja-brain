# ── Resource Manager ───────────────────────────────────────────────────────────
class ResourceManager:
    """Cross-process inference lock and VRAM budget tracker.

    Prevents concurrent Ollama calls from OOM-ing the GPU on low-resource hardware.
    Uses fcntl advisory locking — the OS auto-releases the lock if the process dies.
    Embedding calls (nomic-embed-text) are intentionally not locked: they use a
    small dedicated model and often occur in the same process as inference.
    """

    LOCK_TIMEOUT = 90  # seconds to wait before giving up and proceeding unlocked

    def __init__(self):
        self._lock_fh = None

    # ── VRAM helpers ──────────────────────────────────────────────────────────

    def vram_stats(self) -> tuple:
        """Returns (used_mb, total_mb, free_mb). Falls back to (0, 0, 4000) without nvidia-smi."""
        try:
            r = subprocess.run(
                ["nvidia-smi",
                 "--query-gpu=memory.used,memory.total,memory.free",
                 "--format=csv,noheader,nounits"],
                capture_output=True, text=True, timeout=2,
            )
            parts = [x.strip() for x in r.stdout.strip().split(",")]
            return int(parts[0]), int(parts[1]), int(parts[2])
        except Exception:
            return 0, 0, 4_000

    def model_vram_mb(self, model: str) -> int:
        """Estimated VRAM (MB) for a model. Exact match wins; then base-name prefix fallback."""
        if model in MODEL_VRAM_MB:
            return MODEL_VRAM_MB[model]
        base = model.split(":")[0].lower()
        for key, mb in MODEL_VRAM_MB.items():
            if key.split(":")[0].lower() == base:
                return mb
        return 4_500  # conservative default for unknown models

    def can_load(self, model: str) -> bool:
        """True if free VRAM exceeds model requirement + 300 MB safety margin."""
        _, _, free = self.vram_stats()
        return free >= self.model_vram_mb(model) + 300

    def can_load_mb(self, needed_mb: int) -> bool:
        """True if free VRAM exceeds needed_mb + 300 MB safety margin."""
        _, _, free = self.vram_stats()
        return free >= needed_mb + 300

    # ── Model lifecycle ───────────────────────────────────────────────────────

    def loaded_models(self, ollama_url: str = "http://localhost:11434") -> list:
        """Query Ollama /api/ps for currently loaded models.
        Returns list of {name, size_vram, expires_at} dicts."""
        try:
            import urllib.request
            with urllib.request.urlopen(f"{ollama_url}/api/ps", timeout=3) as r:
                return json.loads(r.read()).get("models", [])
        except Exception:
            return []

    def evict(self, model: str, ollama_url: str = "http://localhost:11434") -> bool:
        """Unload a model from Ollama VRAM by sending keep_alive=0."""
        try:
            import urllib.request
            payload = json.dumps({"model": model, "keep_alive": 0}).encode()
            req = urllib.request.Request(
                f"{ollama_url}/api/generate",
                data=payload,
                headers={"Content-Type": "application/json"},
            )
            with urllib.request.urlopen(req, timeout=10) as r:
                r.read()
            return True
        except Exception:
            return False

    def ensure_vram(self, needed_mb: int, ollama_url: str = "http://localhost:11434") -> bool:
        """Evict loaded models (smallest first) until needed_mb + 300 MB safety margin fits.
        Returns True if enough VRAM is available after eviction."""
        if self.can_load_mb(needed_mb):
            return True
        loaded = self.loaded_models(ollama_url)
        for m in sorted(loaded, key=lambda x: x.get("size_vram", 0)):
            self.evict(m["name"], ollama_url)
            time.sleep(1.0)
            if self.can_load_mb(needed_mb):
                return True
        _, _, free = self.vram_stats()
        return free >= needed_mb + 300

    # ── Lock ──────────────────────────────────────────────────────────────────

    def acquire(self, model: str, timeout: int = None, ollama_url: str = "http://localhost:11434") -> bool:
        """Acquire the exclusive inference slot, evicting stale models if VRAM is tight.
        Returns True when acquired, False on timeout."""
        wait = timeout if timeout is not None else self.LOCK_TIMEOUT
        deadline = time.time() + wait
        try:
            fh = INFERENCE_LOCK.open("w")
        except Exception:
            return True  # can't create lock file — proceed unlocked

        while time.time() < deadline:
            try:
                fcntl.flock(fh, fcntl.LOCK_EX | fcntl.LOCK_NB)
                # Got the exclusive slot — evict stale models if VRAM is tight
                needed_mb = self.model_vram_mb(model)
                if not self.can_load_mb(needed_mb):
                    self.ensure_vram(needed_mb, ollama_url)
                fh.write(json.dumps({
                    "model": model,
                    "pid": os.getpid(),
                    "since": datetime.now(timezone.utc).isoformat(),
                }))
                fh.flush()
                self._lock_fh = fh
                return True
            except (IOError, OSError):
                time.sleep(0.5)

        fh.close()
        return False

    def release(self):
        """Release the inference slot."""
        if self._lock_fh:
            try:
                self._lock_fh.truncate(0)
                fcntl.flock(self._lock_fh, fcntl.LOCK_UN)
                self._lock_fh.close()
            except Exception:
                pass
            self._lock_fh = None

    def lock_info(self) -> dict | None:
        """Read current lock state without acquiring. Returns None if slot is free."""
        if not INFERENCE_LOCK.exists():
            return None
        try:
            fh = INFERENCE_LOCK.open("r")
            try:
                fcntl.flock(fh, fcntl.LOCK_EX | fcntl.LOCK_NB)
                fcntl.flock(fh, fcntl.LOCK_UN)
                fh.close()
                return None  # slot is free
            except (IOError, OSError):
                content = fh.read().strip()
                fh.close()
                return json.loads(content) if content else {"model": "?", "pid": "?"}
        except Exception:
            return None

    # ── Status ─────────────────────────────────────────────────────────────────

    def status(self) -> dict:
        vram_used, vram_total, vram_free = self.vram_stats()
        load1 = 0.0
        try:
            load1 = os.getloadavg()[0]
        except Exception:
            pass
        ram_total_mb, ram_avail_mb = 0, 0
        try:
            for line in Path("/proc/meminfo").read_text().splitlines():
                if line.startswith("MemTotal:"):
                    ram_total_mb = int(line.split()[1]) // 1024
                elif line.startswith("MemAvailable:"):
                    ram_avail_mb = int(line.split()[1]) // 1024
        except Exception:
            pass
        return {
            "vram_used_mb": vram_used,
            "vram_total_mb": vram_total,
            "vram_free_mb": vram_free,
            "ram_total_mb": ram_total_mb,
            "ram_avail_mb": ram_avail_mb,
            "load1": load1,
            "lock_info": self.lock_info(),
        }


_rm = ResourceManager()


# ── Config ─────────────────────────────────────────────────────────────────────
def load_config() -> dict:
    if not CONFIG_FILE.exists():
        GINJA_DIR.mkdir(parents=True, exist_ok=True)
        CONFIG_FILE.write_text(json.dumps(DEFAULT_CONFIG, indent=2))
    with open(CONFIG_FILE) as f:
        cfg = json.load(f)
    for k, v in DEFAULT_CONFIG.items():
        cfg.setdefault(k, v)
    return cfg


def load_persona() -> str:
    return PERSONA_FILE.read_text().strip() if PERSONA_FILE.exists() else ""


def load_context() -> str:
    return CONTEXT_FILE.read_text().strip() if CONTEXT_FILE.exists() else ""


# ── Qdrant helpers ─────────────────────────────────────────────────────────────
def get_qdrant(cfg: dict):
    from qdrant_client import QdrantClient
    return QdrantClient(url=cfg["qdrant_url"], timeout=10)


def ensure_collections(client, vector_size: int = 768):
    from qdrant_client.models import Distance, VectorParams
    existing = {c.name for c in client.get_collections().collections}
    for name in ("memories", "documents", "conversations", "operator_feedback"):
        if name not in existing:
            client.create_collection(
                collection_name=name,
                vectors_config=VectorParams(size=vector_size, distance=Distance.COSINE),
            )


def embed(text: str, cfg: dict) -> list:
    import ollama
    resp = ollama.embeddings(model=cfg["embed_model"], prompt=text)
    return resp["embedding"]


def store_memory(text: str, cfg: dict, collection: str = "memories", source: str = "",
                 dedup_threshold: float = None):
    from qdrant_client.models import PointStruct
    client = get_qdrant(cfg)
    vec = embed(text, cfg)
    ensure_collections(client, len(vec))
    if dedup_threshold is not None:
        try:
            hits = client.query_points(collection_name=collection, query=vec, limit=1).points
            if hits and hits[0].score >= dedup_threshold:
                return None
        except Exception:
            pass
    client.upsert(
        collection_name=collection,
        points=[PointStruct(
            id=str(uuid.uuid4()),
            vector=vec,
            payload={
                "text": text,
                "source": source,
                "created": datetime.now(timezone.utc).isoformat(),
            },
        )],
    )


def search_memory(query: str, cfg: dict, top_k: int = 5,
                  recency_weight: float = 0.0,
                  collections: list = None,
                  source_filter: list = None) -> list:
    from qdrant_client.models import Filter, FieldCondition, MatchAny
    client = get_qdrant(cfg)
    vec = embed(query, cfg)
    search_cols = collections if collections is not None else ["memories", "documents", "conversations"]
    q_filter = None
    if source_filter:
        q_filter = Filter(must=[FieldCondition(key="source", match=MatchAny(any=source_filter))])
    now_ts = datetime.now(timezone.utc)
    results = []
    for collection in search_cols:
        try:
            hits = client.query_points(
                collection_name=collection,
                query=vec,
                query_filter=q_filter,
                limit=top_k,
            ).points
            for hit in hits:
                created = hit.payload.get("created", "")
                if recency_weight > 0.0 and created:
                    try:
                        created_dt = datetime.fromisoformat(created)
                        days_old = max(0, (now_ts - created_dt).days)
                        recency_score = math.exp(-days_old / 30.0)
                        adjusted = (1 - recency_weight) * hit.score + recency_weight * recency_score
                    except Exception:
                        adjusted = hit.score
                else:
                    adjusted = hit.score
                results.append({
                    "id": str(hit.id),
                    "score": adjusted,
                    "raw_score": hit.score,
                    "collection": collection,
                    "text": hit.payload.get("text", ""),
                    "source": hit.payload.get("source", ""),
                    "created": created,
                })
        except Exception:
            pass
    results.sort(key=lambda x: x["score"], reverse=True)
    return results[:top_k]


def _evolution_recall(query: str, cfg: dict, top_k: int = 8) -> list:
    """Signal-filtered, recency-weighted recall for evolution cycles."""
    SIGNAL_SOURCES = ["evolution", "learn_oracle", "wonder", "user", "remember", "evolve_research", "react_observation"]
    return search_memory(query, cfg, top_k=top_k,
                         collections=["memories"],
                         source_filter=SIGNAL_SOURCES,
                         recency_weight=0.3)


# ── File reading (with PDF support) ───────────────────────────────────────────
def read_file(file_path: Path) -> str:
    if file_path.suffix.lower() == ".pdf":
        try:
            import pypdf
            reader = pypdf.PdfReader(str(file_path))
            return "\n".join(page.extract_text() or "" for page in reader.pages)
        except Exception as e:
            console.print(f"[yellow]PDF read warning: {e}[/yellow]")
            return ""
    return file_path.read_text(encoding="utf-8", errors="ignore")


# ── Chunking ───────────────────────────────────────────────────────────────────
def chunk_text(text: str, char_size: int, char_overlap: int) -> list:
    chunks, start = [], 0
    while start < len(text):
        end = min(start + char_size, len(text))
        if end < len(text):
            nl = text.rfind("\n", start, end)
            if nl > start + char_size // 2:
                end = nl
        chunk = text[start:end].strip()
        if len(chunk) > 50:
            chunks.append(chunk)
        start = end - char_overlap
    return chunks


def ingest_file(file_path: Path, cfg: dict, char_size: int, char_overlap: int) -> int:
    try:
        text = read_file(file_path)
    except Exception:
        return 0
    if not text.strip():
        return 0
    chunks = chunk_text(text, char_size, char_overlap)
    for chunk in chunks:
        store_memory(chunk, cfg, collection="documents", source=str(file_path))
    return len(chunks)


# ── Model router ───────────────────────────────────────────────────────────────
def pick_model(query: str, cfg: dict) -> str:
    q = query.lower()
    if any(kw in q for kw in CODE_KEYWORDS):
        return cfg["code_model"]
    if len(query) < 80:
        return cfg["fast_model"]
    return cfg["primary_model"]


# ── Shell context ──────────────────────────────────────────────────────────────
def shell_context() -> str:
    cwd = os.getcwd()
    git_branch = ""
    try:
        r = subprocess.run(
            ["git", "rev-parse", "--abbrev-ref", "HEAD"],
            capture_output=True, text=True, cwd=cwd, timeout=2,
        )
        if r.returncode == 0:
            git_branch = r.stdout.strip()
    except Exception:
        pass
    ctx = f"Current directory: {cwd}"
    if git_branch:
        ctx += f"\nGit branch: {git_branch}"
    project_ctx = load_context()
    if project_ctx and project_ctx != cwd:
        ctx += f"\nProject context: {project_ctx}"
    return ctx


# ── Prompt builder ─────────────────────────────────────────────────────────────
def build_prompt(query: str, persona: str, memories: list, ctx: str) -> str:
    parts = []
    if persona:
        parts.append(f"## About me\n{persona}")
    if ctx:
        parts.append(f"## Current context\n{ctx}")
    if memories:
        mem_lines = "\n".join(f"- [{m['collection']}] {m['text']}" for m in memories)
        parts.append(f"## Relevant memories from my brain\n{mem_lines}")
    parts.append(f"## My question\n{query}")
    return "\n\n".join(parts)


# ── Ollama streaming ───────────────────────────────────────────────────────────
def ollama_stream(prompt: str, model: str, messages: list = None, num_ctx: int = 2048,
                  ollama_url: str = "http://localhost:11434") -> str:
    import ollama
    acquired = _rm.acquire(model, ollama_url=ollama_url)
    if not acquired:
        console.print(
            f"[yellow]⚠ inference slot busy after {_rm.LOCK_TIMEOUT}s — "
            f"proceeding (VRAM contention possible)[/yellow]"
        )
    full = ""
    if messages is None:
        messages = [{"role": "user", "content": prompt}]
    try:
        for chunk in ollama.chat(
            model=model,
            messages=messages,
            stream=True,
            options={"num_ctx": num_ctx},
        ):
            token = chunk["message"]["content"]
            print(token, end="", flush=True)
            full += token
        print()
        return full
    except Exception as e:
        console.print(f"\n[red]Ollama error ({model}): {e}[/red]")
        return ""
    finally:
        if acquired:
            _rm.release()


def ollama_complete(prompt: str, model: str, cfg: dict) -> str:
    import ollama
    ollama_url = cfg.get("ollama_url", "http://localhost:11434")
    acquired = _rm.acquire(model, ollama_url=ollama_url)
    if not acquired:
        console.print(f"[yellow]⚠ inference slot busy after {_rm.LOCK_TIMEOUT}s — proceeding[/yellow]")
    try:
        resp = ollama.chat(
            model=model,
            messages=[{"role": "user", "content": prompt}],
            options={"num_ctx": cfg.get("num_ctx", 2048)},
        )
        return resp["message"]["content"]
    except Exception as e:
        return f"[error: {e}]"
    finally:
        if acquired:
            _rm.release()


def ask_with_fallback(prompt: str, cfg: dict, model: str) -> str:
    num_ctx = cfg.get("num_ctx", 2048)
    fallback_chain = [model]
    if model != cfg["fast_model"]:
        fallback_chain.append(cfg["fast_model"])
    for m in fallback_chain:
        console.print(f"[dim]model: {m}[/dim]")
        result = ollama_stream(prompt, m, num_ctx=num_ctx)
        if result:
            return result
    if cfg.get("use_gemini_fallback") and cfg.get("gemini_api_key"):
        return ask_gemini(prompt, cfg)
    console.print("[red]All models failed. Is Ollama running?[/red]")
    return ""


def gemini_available(cfg: dict) -> bool:
    return bool(cfg.get("gemini_api_key", "").strip())


def gemini_complete(prompt: str, cfg: dict, pro: bool = False, stream: bool = False) -> str:
    """Call Gemini API using google-genai SDK."""
    global _gemini_unavailable
    try:
        from google import genai
        client = genai.Client(api_key=cfg["gemini_api_key"])
        model_name = cfg.get("gemini_pro_model", "gemini-2.0-flash") if pro \
                     else cfg.get("gemini_model", "gemini-2.0-flash")
        console.print(f"[dim]model: {model_name}[/dim]")
        if stream:
            full = ""
            for chunk in client.models.generate_content_stream(
                model=model_name, contents=prompt
            ):
                token = chunk.text or ""
                print(token, end="", flush=True)
                full += token
            print()
            return full
        else:
            resp = client.models.generate_content(model=model_name, contents=prompt)
            return resp.text or ""
    except Exception as e:
        err = str(e)
        if "429" in err or "RESOURCE_EXHAUSTED" in err or "spending cap" in err or "quota" in err.lower():
            _gemini_unavailable = True
            console.print("[yellow]⚠ Gemini quota exceeded — switching to local AI for this session[/yellow]")
        elif any(code in err for code in ("401", "403")) or "API_KEY" in err.upper() or "UNAUTHENTICATED" in err:
            _gemini_unavailable = True
            console.print("[yellow]⚠ Gemini auth error — switching to local AI for this session[/yellow]")
        else:
            console.print(f"[red]Gemini error: {e}[/red]")
        return ""


def ask_gemini(prompt: str, cfg: dict) -> str:
    """Legacy streaming ask — kept for backward compat with ask command fallback."""
    return gemini_complete(prompt, cfg, pro=False, stream=True)


def _resource_pressure() -> str:
    """Assess current system load. Returns 'normal', 'high', or 'critical'."""
    try:
        load1 = os.getloadavg()[0]
    except Exception:
        load1 = 0.0

    vram_pct = 0.0
    try:
        r = subprocess.run(
            ["nvidia-smi", "--query-gpu=memory.used,memory.total",
             "--format=csv,noheader,nounits"],
            capture_output=True, text=True, timeout=2,
        )
        parts = [x.strip() for x in r.stdout.strip().split(",")]
        used, total = int(parts[0]), int(parts[1])
        if total > 0:
            vram_pct = used / total
    except Exception:
        pass

    if load1 >= 8.0 or vram_pct >= 0.92:
        return "critical"
    if load1 >= 5.0 or vram_pct >= 0.80:
        return "high"
    return "normal"


def smart_complete(prompt: str, cfg: dict, use_case: str = "general",
                   pro: bool = False, fallback_model: str = None) -> str:
    """Route to Gemini or Ollama based on use_case, config, and current resource pressure.

    use_case values:
      'evolve'    — self-reflection / growth (prefers Gemini if gemini_for_evolve)
      'implement' — code generation (prefers Gemini if gemini_for_implement)
      'general'   — follows use_gemini_fallback setting

    Resource pressure degrades gracefully:
      'high'     — skip Pro-tier; use flash / primary model
      'critical' — skip Gemini entirely; use fast model
    """
    global _gemini_unavailable
    pressure = _resource_pressure()

    if pressure == "critical":
        model = cfg.get("fast_model", cfg["primary_model"])
        console.print(f"[dim]⚡ resource:critical — using fast model ({model})[/dim]")
        return ollama_complete(prompt, model, cfg)

    model = fallback_model or cfg.get("quality_model", cfg["primary_model"])
    if pressure == "high":
        model = cfg.get("primary_model")
        pro   = False

    if not _gemini_unavailable:
        if use_case == "evolve" and cfg.get("gemini_for_evolve") and gemini_available(cfg):
            result = gemini_complete(prompt, cfg, pro=pro)
            if result:
                return result
        elif use_case == "implement" and cfg.get("gemini_for_implement") and gemini_available(cfg):
            result = gemini_complete(prompt, cfg, pro=pro)
            if result:
                return result
        elif use_case == "general" and cfg.get("use_gemini_fallback") and gemini_available(cfg):
            result = gemini_complete(prompt, cfg, pro=pro, stream=True)
            if result:
                return result

    return ollama_complete(prompt, model, cfg)


# ── Web helpers ────────────────────────────────────────────────────────────────
def searxng_search(query: str, cfg: dict, num_results: int = 5) -> list:
    import requests
    url = cfg.get("searxng_url", "http://localhost:8080")
    try:
        resp = requests.get(
            f"{url}/search",
            params={"q": query, "format": "json"},
            timeout=10,
        )
        resp.raise_for_status()
        data = resp.json()
        return data.get("results", [])[:num_results]
    except Exception as e:
        console.print(f"[red]SearXNG error: {e}[/red]")
        console.print("[dim]Is SearXNG running? docker compose up -d searxng[/dim]")
        return []


def fetch_page_text(url: str, max_chars: int = 8000) -> str:
    try:
        import requests
        from bs4 import BeautifulSoup
        resp = requests.get(url, timeout=4, headers={"User-Agent": "ginja/1.0"})
        resp.raise_for_status()
        soup = BeautifulSoup(resp.text, "html.parser")
        for tag in soup(["script", "style", "nav", "footer", "header"]):
            tag.decompose()
        text = soup.get_text(separator="\n", strip=True)
        return text[:max_chars]
    except Exception:
        return ""


def scroll_recent(client, collection: str, days: int = 7) -> list:
    """Return recent entries from a Qdrant collection within N days."""
    cutoff = (datetime.now(timezone.utc) - timedelta(days=days)).isoformat()
    try:
        results, _ = client.scroll(collection_name=collection, limit=500, with_payload=True)
        return [
            r.payload for r in results
            if r.payload.get("created", "0") >= cutoff
        ]
    except Exception:
        return []


def research_topic(t: str, cfg: dict, depth: int = 3, pages: int = 5, fetch: bool = False) -> str:
    """Core research logic — returns summary string. Used by both research and evolve commands."""
    query_prompt = (
        f"Generate {depth} different search queries to thoroughly research: {t}\n"
        "Return ONLY the queries, one per line, no numbering."
    )
    queries_raw = ollama_complete(query_prompt, cfg["fast_model"], cfg)
    queries = [q.strip() for q in queries_raw.strip().splitlines() if q.strip()][:depth]
    if not queries:
        queries = [t]

    all_text = []
    total_ingested = 0
    for query in queries:
        console.print(f"  [dim]→ {query}[/dim]")
        hits = searxng_search(query, cfg, num_results=pages)
        for hit in hits:
            url = hit.get("url", "")
            snippet = hit.get("content", "") or hit.get("title", "")
            if not url:
                continue
            if fetch:
                page_text = fetch_page_text(url)
                text = page_text if page_text else f"Title: {hit.get('title','')}\n{snippet}"
            else:
                text = f"Title: {hit.get('title','')}\nURL: {url}\nSummary: {snippet}"
            if text:
                all_text.append(f"Source: {url}\n{text[:2000]}")
                total_ingested += 1

    if not all_text:
        return ""

    combined = "\n\n---\n\n".join(all_text[:8])
    summary_prompt = (
        f"I researched: {t}\n\nHere is what I found:\n\n{combined}\n\n"
        "Summarize the key findings. Be specific and technical. "
        "Highlight anything surprising or especially useful."
    )
    summary = ollama_complete(summary_prompt, cfg["primary_model"], cfg)
    console.print(f"  [green]✓[/green] {total_ingested} sources ingested")
    return summary


