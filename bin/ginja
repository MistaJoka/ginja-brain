def _parse_duration(s: str) -> int:
    """Parse '2h', '30m', '1h30m', '90s' into seconds."""
    import re
    total = 0
    for value, unit in re.findall(r'(\d+)([hms])', s.lower()):
        v = int(value)
        if unit == 'h':   total += v * 3600
        elif unit == 'm': total += v * 60
        elif unit == 's': total += v
    if total == 0:
        raise click.BadParameter(f"Cannot parse {s!r}. Use e.g. '2h', '30m', '1h30m'.")
    return total


PHASE_ORDER = ["newborn", "emerging", "developing", "mature"]
PHASE_THRESHOLDS = [   # descending — first match wins
    (50, "mature"),
    (20, "developing"),
    (5,  "emerging"),
    (0,  "newborn"),
]

