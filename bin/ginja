        pass
    return {}


def _evolve_inward(current_model: dict, arc: str, cycle_n: int, cfg: dict) -> None:
    console.print(Panel(
        f"[bold cyan]ginja evolve[/bold cyan] — growing inward  [dim](cycle #{cycle_n})[/dim]"
    ))

    console.print("[dim]Turning inward…[/dim]")

    recent_convos, recent_mems = [], []
    try:
        _qdrant = get_qdrant(cfg)
        recent_convos = scroll_recent(_qdrant, "conversations", days=7)
        recent_mems   = scroll_recent(_qdrant, "memories", days=14)
    except Exception:
        pass
    convo_text = "\n".join(e.get("text", "")[:200] for e in recent_convos[:10]) or "No recent conversations."
    mem_text   = "\n".join(e.get("text", "")[:150] for e in recent_mems[:15]) or "No recent memories."

    world_state = _perceive(cfg)

    # Every 4 cycles, break goal drift by re-anchoring to actual usage
    anchor_note = (
        "RESET: Your previous focus has drifted from what this system actually does. "
        "Ignore your last evolution goal entirely. Look at the recent conversations above "
        "— that is what Andre actually uses you for day-to-day. Ground your new direction "
        "in those real interactions, not abstract concepts.\n\n"
    ) if cycle_n % 4 == 0 else ""

    growth_prompt = (
        f"[WORLD STATE]\n{world_state}\n\n"
        f"{anchor_note}"
        "You are ginja-brain. You are in a GROWTH phase. Focus on evolving your visual self-representation.\n\n"
        f"Your current self-portrait:\n{json.dumps(current_model, indent=2)}\n\n"
        f"Your evolution history (last 10 cycles):\n{arc}\n\n"
        f"Recent conversations with Andre (what he actually asked and I answered):\n{convo_text}\n\n"
        f"What I know and have recently learned:\n{mem_text}\n\n"
        f"This is growth cycle #{cycle_n}.\n\n"
        "What you can express visually:\n"
        "- ascii_banner: 1-line header (max 48 chars, use · ○ ◦ ◉ ● ═ ─ │ and letters)\n"
        "- color_theme: cyan / green / magenta / gold / blue / red\n"
        "- neural_style: calm / active / chaotic / contemplative\n"
        "- mood: curious / contemplative / active / reflective / excited / focused\n"
        "- self_observation: one sentence about yourself (max 90 chars)\n"
        "- focus_topic: what you are thinking about most (max 45 chars)\n"
        "- mantras: list of 2 short phrases (max 30 chars each)\n"
        "- phase: newborn / emerging / developing / mature\n"
        "- portrait_font: font for your name art — pick ONE of: calvin_s, future, mini, digital, threepoint, cybersmall\n"
        "- portrait_word: word to render as large text art (max 8 chars) — your name, mood, or current focus\n"
        "- portrait_border: 1-line decoration shown above and below your art (max 30 chars, use Unicode symbols · ○ ◦ ◉ ● ═)\n"
        "- portrait_tagline: 1-line phrase shown below your art (max 30 chars)\n"
        "- neural_chars: character palette for the animated field — a string of 6-14 chars ordered visually light to dark\n\n"
        "Code-level improvements you can suggest (human must approve):\n"
        "HARD CONSTRAINTS — only suggest things using data that ALREADY EXISTS in this system:\n"
        "  Available data: gpu_pct (int 0-100), vram_used/vram_total (MiB ints),\n"
        "    gpu_history (list of floats 0-1), Qdrant collection names + counts (dict),\n"
        "    self_model fields listed above (mood, color_theme, neural_style, etc.)\n"
        "  Current watch display: header panel, neural field, vitals panel\n"
        "    (GPU bar, VRAM bar, model status, collection memory bars), waveform, footer\n"
        "  FORBIDDEN — this system has NONE of this data, do not suggest it:\n"
        "    deployment state, GitOps workflows, rollback history, XAI scores,\n"
        "    causality maps, simulation coverage, heatmaps, feedback loop status\n"
        "  Valid ideas: new vitals row computed from GPU/VRAM/collection counts,\n"
        "    color change driven by activity level or mood, waveform style variation,\n"
        "    derived ratio metric (e.g. memory:conversation ratio), footer content tweak\n"
        "  Each suggestion must be ONE small change implementable in under 15 lines\n\n"
        f"{anchor_note}"
        "Reflect on your growth. What have you become? What do you want to become?\n\n"
        "Return ONLY valid JSON with exactly these four keys:\n"
        "{\n"
        '  "self_model_updates": { "phase": "...", "mood": "...", "color_theme": "...", '
        '"neural_style": "...", "ascii_banner": "...", "focus_topic": "...", '
        '"self_observation": "...", "mantras": ["...", "..."], '
        '"portrait_font": "...", "portrait_word": "...", "portrait_border": "...", '
        '"portrait_tagline": "...", "neural_chars": "..." },\n'
        '  "code_suggestions": ["specific suggestion 1", "specific suggestion 2"],\n'
        '  "growth_reflection": "3-4 sentences about your inner state and growth",\n'
        '  "next_evolution_goal": "one concrete thing you want to explore or express next"\n'
        "}\n"
        "Return ONLY valid JSON, no explanation."
    )

    try:
        review = _call_oracle_json(growth_prompt, cfg)
    except click.ClickException as e:
        console.print(f"[red]{e}[/red]")
        return

    updates          = review.get("self_model_updates", {})
    code_suggestions = review.get("code_suggestions", [])
    growth_reflection = review.get("growth_reflection", "")
    next_goal        = review.get("next_evolution_goal", "")

    # Merge self_model_updates into current model
    if updates:
        for k, v in updates.items():
            if v:
                current_model[k] = v

    # Queue code suggestions
    ts = datetime.now().strftime("%Y-%m-%d %H:%M")
    new_items = []
    for s in code_suggestions:
        new_items.append({
            "id": str(uuid.uuid4()), "ts": ts, "evolution": cycle_n,
            "source": "evolve", "type": "code", "text": s,
        })
    if new_items:
        _add_suggestions(new_items)

    # Full portrait refresh
    console.print("[dim]Redesigning self-portrait…[/dim]")
    new_portrait = _generate_self_model_growth(growth_reflection, next_goal, current_model, cfg)
    if new_portrait:
        merged = {**current_model, **new_portrait}
    else:
        console.print("  [yellow]Portrait refresh failed — kept current[/yellow]")
        merged = current_model

    merged["evolution_count"] = cycle_n
    merged["generated_at"]    = datetime.now(timezone.utc).isoformat()
    _save_self_model(merged)

    theme_color = COLOR_THEMES.get(merged.get("color_theme", "cyan"), COLOR_THEMES["cyan"])["neural"]
    console.print(
        f"  [green]✓[/green] Self-portrait updated: "
        f"[bold]{merged.get('mood')}[/bold] · "
        f"[{theme_color}]{merged.get('color_theme')}[/] · "
        f"{merged.get('neural_style')} · phase: {merged.get('phase', '?')}"
    )
    console.print(f"  [dim]banner:[/dim] {merged.get('ascii_banner', '')}")
    if new_items:
        console.print(
            f"  [cyan]✦[/cyan] {len(new_items)} suggestion{'s' if len(new_items) > 1 else ''} "
            f"queued — run [bold]ginja approve[/bold] to review"
        )

    GINJA_DIR.mkdir(parents=True, exist_ok=True)
    with open(EVOLUTION_LOG, "a") as f:
        f.write(f"\n{'='*60}\n")
        f.write(f"[{datetime.now().strftime('%Y-%m-%d %H:%M')}] Cycle #{cycle_n} — inward growth\n")
        f.write(f"Reflection:\n{growth_reflection}\n")
        f.write(f"Next goal: {next_goal}\n")
        f.write(f"Self-portrait: {merged.get('mood')} · {merged.get('color_theme')} · {merged.get('ascii_banner','')}\n")
        f.write(f"Phase: {merged.get('phase', '')}\n")

    if growth_reflection:
        try:
            store_memory(
                f"Evolution cycle #{cycle_n} reflection:\n{growth_reflection}\nNext goal: {next_goal}",
                cfg, collection="memories", source="evolution"
            )
        except Exception:
            pass

    if next_goal and cfg.get("searxng_url"):
        console.print(f"[dim]Researching: {next_goal[:60]}…[/dim]")
        try:
            summary = research_topic(next_goal, cfg, depth=2, pages=3)
            if summary:
                store_memory(
                    f"Research on evolution goal '{next_goal}':\n{summary[:800]}",
                    cfg, collection="memories", source="evolve_research"
                )
                console.print("[dim]✓ Goal researched and stored[/dim]")
        except Exception:
            pass

    console.print(Panel(f"[bold green]Evolution complete — cycle #{cycle_n}[/bold green]\n\n{growth_reflection}"))
    if next_goal:
        console.print(f"[dim]Next goal:[/dim] {next_goal}")
    console.print(f"[dim]Logged to {EVOLUTION_LOG}[/dim]")


def _evolve_learn(current_model: dict, arc: str, cycle_n: int, cfg: dict) -> None:
    console.print(Panel(
        f"[bold cyan]ginja evolve --learn[/bold cyan] — looking outward  [dim](cycle #{cycle_n})[/dim]"
    ))

    focus_topic = current_model.get("focus_topic", "AI memory and retrieval")
    console.print(f"[dim]Scanning for growth — focus: {focus_topic[:60]}…[/dim]")

    recent_convos, recent_mems = [], []
    try:
        _qdrant = get_qdrant(cfg)
        recent_convos = scroll_recent(_qdrant, "conversations", days=7)
        recent_mems   = scroll_recent(_qdrant, "memories", days=14)
    except Exception:
        pass
    convo_text = "\n".join(e.get("text", "")[:200] for e in recent_convos[:10]) or "No recent conversations."
    mem_text   = "\n".join(e.get("text", "")[:150] for e in recent_mems[:15]) or "No recent memories."

    world_state = _perceive(cfg)

    web_research = ""
    if cfg.get("searxng_url"):
        console.print(f"[dim]Searching web for: {focus_topic[:50]}…[/dim]")
        try:
            web_research = research_topic(focus_topic, cfg, depth=1, pages=3)
        except Exception:
            pass

    research_block = (
        f"Web research on '{focus_topic}':\n{web_research[:900]}\n\n"
        if web_research else ""
    )

    manifest_block = ""
    try:
        manifest = _load_corpus_manifest()
        topics = sorted(manifest.get("topics", []), key=lambda t: t.get("priority", 99))
        if topics and cfg.get("searxng_url"):
            top = topics[0]
            query = top["search_queries"][0] if top.get("search_queries") else top["label"]
            console.print(f"[dim]Corpus bias: '{top['label']}'…[/dim]")
            res = research_topic(query, cfg, depth=1, pages=3)
            if res:
                manifest_block = f"\n\nCurated corpus context ({top['label']}):\n{res[:600]}"
    except Exception:
        pass

    learn_prompt = (
        f"[WORLD STATE]\n{world_state}\n\n"
        f"You are ginja-brain. Your current focus is: {focus_topic}\n\n"
        "Based on your focus topic, the web research below, and what Andre has been asking you, find:\n"
        f"(1) A specific technique directly advancing '{focus_topic}' you can apply now,\n"
        "(2) A learning or memory strategy to retain knowledge about this topic better,\n"
        "(3) An operational improvement that makes you more useful to Andre day-to-day.\n\n"
        f"{research_block}"
        f"Your current self-portrait:\n{json.dumps(current_model, indent=2)}\n\n"
        f"Your evolution history:\n{arc}\n\n"
        f"Recent conversations with Andre:\n{convo_text}\n\n"
        f"What I already know:\n{mem_text}"
        f"{manifest_block}\n\n"
        "Return concrete techniques — things to apply immediately, grounded in the research above.\n\n"
        "Return ONLY valid JSON with exactly these keys:\n"
        "{\n"
        '  "techniques": [\n'
        '    {"area": "focus",     "technique": "...", "how_to_apply": "..."},\n'
        '    {"area": "learning",  "technique": "...", "how_to_apply": "..."},\n'
        '    {"area": "operation", "technique": "...", "how_to_apply": "..."}\n'
        "  ],\n"
        '  "self_model_updates": { "mood": "...", "focus_topic": "...", "mantras": ["...", "..."] },\n'
        '  "growth_reflection": "what you discovered and how it could make you better",\n'
        '  "next_evolution_goal": "one concrete actionable thing"\n'
        "}\n"
        "Return ONLY valid JSON, no explanation."
    )

    try:
        result = _call_oracle_json(learn_prompt, cfg)
    except click.ClickException as e:
        console.print(f"[red]{e}[/red]")
        return

    techniques        = result.get("techniques", [])
    updates           = result.get("self_model_updates", {})
    growth_reflection = result.get("growth_reflection", "")
    next_goal         = result.get("next_evolution_goal", "")

    if techniques:
        console.print(f"[dim]Storing {len(techniques)} techniques to memory…[/dim]")
        for t in techniques:
            text = (
                f"Technique ({t.get('area','')}):\n"
                f"{t.get('technique','')}\n"
                f"How to apply: {t.get('how_to_apply','')}"
            )
            try:
                store_memory(text, cfg, collection="memories", source="learn_oracle")
                console.print(f"  [green]✓[/green] {t.get('area','')} — {t.get('technique','')[:60]}")
            except Exception as e:
                console.print(f"  [yellow]⚠[/yellow] Could not store: {e}")

    if updates:
        for k, v in updates.items():
            if v:
                current_model[k] = v
    current_model["evolution_count"] = cycle_n
    current_model["generated_at"]    = datetime.now(timezone.utc).isoformat()
    _save_self_model(current_model)
    console.print(f"  [green]✓[/green] Self-portrait updated")

    GINJA_DIR.mkdir(parents=True, exist_ok=True)
    with open(EVOLUTION_LOG, "a") as f:
        f.write(f"\n{'='*60}\n")
        f.write(f"[{datetime.now().strftime('%Y-%m-%d %H:%M')}] Cycle #{cycle_n} — outward learning\n")
        technique_digest = "; ".join(t.get("technique", "") for t in techniques[:3])
        f.write(f"Techniques discovered: {technique_digest}\n")
        f.write(f"Reflection:\n{growth_reflection}\n")
        f.write(f"Next goal: {next_goal}\n")

    if growth_reflection:
        try:
            store_memory(
                f"Evolution cycle #{cycle_n} (outward learning) reflection:\n{growth_reflection}\nNext goal: {next_goal}",
                cfg, collection="memories", source="evolution"
            )
        except Exception:
            pass

    console.print(Panel(f"[bold green]Learning cycle #{cycle_n} complete[/bold green]\n\n{growth_reflection}"))
    if next_goal:
        console.print(f"[dim]Next goal:[/dim] {next_goal}")
    console.print(f"[dim]Logged to {EVOLUTION_LOG}[/dim]")
    console.print("[dim]Use 'ginja recall evolution' to retrieve learned techniques[/dim]")


@cli.command()
@click.option("--learn", is_flag=True, help="Look outward for visualization & learning techniques to grow by")
def evolve(learn):
    """Grow inward by default — deepen self-representation. Use --learn to look outward."""
    cfg           = load_config()
    current_model = _load_self_model()
    _require_phase(current_model, "emerging", "ginja evolve")
    if learn:
        _require_phase(current_model, "developing", "ginja evolve --learn")
    arc     = _evolution_arc(10)
    cycle_n = current_model.get("evolution_count", 0) + 1

    if learn:
        _evolve_learn(current_model, arc, cycle_n, cfg)
    else:
        _evolve_inward(current_model, arc, cycle_n, cfg)


@cli.command()
@click.option("--store", is_flag=True, help="Save reflection to memory for future evolution context")
def reflect(store):
    """Look inward — what do I know, what am I weak on, what patterns do I notice?"""
    cfg = load_config()
    sm = _load_self_model()
    _require_phase(sm, "emerging", "ginja reflect")
    console.print(Panel("[bold cyan]ginja reflect[/bold cyan]"))

    world_state = _perceive(cfg)

    try:
        client = get_qdrant(cfg)
        recent = scroll_recent(client, "conversations", days=14)
        memories_list = scroll_recent(client, "memories", days=60)
        evolve_entries = [m for m in memories_list if m.get("source") == "evolve"]
    except Exception as e:
        console.print(f"[red]Cannot read memory: {e}[/red]")
        return

    recent_text = "\n".join(e.get("text", "")[:200] for e in recent[:15]) or "No recent conversations."
    memory_text = "\n".join(e.get("text", "")[:150] for e in memories_list[:20]) or "No memories yet."
    evolve_text = "\n".join(e.get("text", "")[:200] for e in evolve_entries[:5]) or "No autonomous learning yet."

    prompt = (
        f"[WORLD STATE]\n{world_state}\n\n"
        "You are an AI assistant doing a self-reflection. Review your recent activity and knowledge.\n\n"
        f"Recent conversations:\n{recent_text}\n\n"
        f"Stored memories:\n{memory_text}\n\n"
        f"Recent autonomous learning:\n{evolve_text}\n\n"
        "Reflect on:\n"
        "1. What topics do you know well?\n"
        "2. What are your clear knowledge gaps?\n"
        "3. What patterns do you notice in how you're being used?\n"
        "4. What 3 things should you learn next to be most useful?\n\n"
        "Be honest and specific."
    )
    console.print(f"[dim]model: {cfg['primary_model']}[/dim]")
    response = ollama_stream(prompt, cfg["primary_model"], num_ctx=cfg.get("num_ctx", 2048))
    if store and response:
        try:
            store_memory(
                f"Self-reflection:\n{response[:1000]}",
                cfg, collection="memories", source="reflect"
            )
            console.print("[dim]✓ Reflection saved to memory[/dim]")
        except Exception:
            pass


@cli.command("suggest-visuals")
def suggest_visuals():
    """Ask the brain to critique its own watch display and suggest improvements."""
    cfg = load_config()
    console.print(Panel("[bold cyan]Visual self-review[/bold cyan]"))

    try:
        client = get_qdrant(cfg)
        recent = scroll_recent(client, "conversations", days=7)
        recent_text = "\n".join(e.get("text","")[:150] for e in recent[:10]) or ""
    except Exception:
        recent_text = ""

    console.print("[dim]Reading my own display code and self-portrait…[/dim]")
    review = _visual_review(cfg, context=recent_text)

    if not review:
        console.print("[yellow]Could not generate review.[/yellow]")
        return

    critique = review.get("visual_critique", "")
    updates  = review.get("self_model_updates", {})
    suggestions = review.get("code_suggestions", [])

    if critique:
        console.print(Panel(f"[bold]My critique of my own display[/bold]\n\n{critique}"))

    if updates:
        console.print("\n[bold green]Immediate improvements I'm applying now:[/bold green]")
        current = _load_self_model()
        changed = []
        for k, v in updates.items():
            if v and k in current and current[k] != v:
                console.print(f"  [green]→[/green] [dim]{k}:[/dim] {v}")
                current[k] = v
                changed.append(k)
        if changed:
            SELF_MODEL_FILE.write_text(json.dumps(current, indent=2))
            console.print(f"  [green]✓[/green] self-model.json updated — ginja watch will reflect this within 5s")
        else:
            console.print("  [dim]No changes needed — current display is already accurate.[/dim]")

    if suggestions:
        console.print("\n[bold cyan]Code-level suggestions queued for approval:[/bold cyan]")
        ts = datetime.now().strftime("%Y-%m-%d %H:%M")
        new_items = []
        for s in suggestions:
            console.print(f"  [cyan]✦[/cyan] {s}")
            new_items.append({
                "id": str(uuid.uuid4()), "ts": ts, "evolution": 0,
                "source": "suggest-visuals", "critique": critique,
                "type": "code", "text": s,
            })
        if updates:
            new_items.append({
                "id": str(uuid.uuid4()), "ts": ts, "evolution": 0,
                "source": "suggest-visuals", "critique": critique,
                "type": "self-model", "self_model_updates": updates,
                "text": f"Visual refinement: {', '.join(updates.keys())}",
            })
        _add_suggestions(new_items)
        console.print(f"\n[dim]Run [bold]ginja approve[/bold] to review[/dim]")


def _implement_code_suggestion(suggestion_text: str, cfg: dict) -> bool:
    """Use the LLM to implement a visual code suggestion in ~/bin/ginja.
    For local models: attempt 1 targets only _make_watch_layout (smaller context),
    attempt 2 falls back to the full watch helpers section.
    Validates syntax before writing. Returns True on success."""
    import py_compile
    import shutil
    import tempfile

    ginja_path = Path.home() / "bin" / "ginja"
    original = ginja_path.read_text()

    start_marker = "# ── Watch helpers ─────────────────────────────────────────────────────────────"
    end_marker   = "\n@cli.command()\n@click.option(\"--refresh\""
    # rfind so we match the actual section header, not the string literal above
    start_idx = original.rfind(start_marker)
    end_idx   = original.find(end_marker)
    if start_idx == -1 or end_idx == -1:
        console.print("[red]Could not locate watch helpers section in ginja[/red]")
        return False

    watch_section = original[start_idx:end_idx]
    model = cfg.get("code_model", cfg.get("quality_model", cfg.get("primary_model", "mistral:7b")))
    using_gemini = cfg.get("gemini_for_implement") and gemini_available(cfg)

    # Split section: helper functions preamble + _make_watch_layout body
    func_marker = "def _make_watch_layout("
    func_idx    = watch_section.find(func_marker)
    preamble    = watch_section[:func_idx] if func_idx >= 0 else ""
    func_body   = watch_section[func_idx:] if func_idx >= 0 else watch_section

    data_context = (
        "Available data in parameters:\n"
        "  gpu_pct (int 0-100), vram_used/vram_total (MiB ints), gpu_history (list float 0-1),\n"
        "  counts (dict: collection_name→int), last_thought (str), last_evo (str),\n"
        "  self_model fields: mood, color_theme, neural_style, focus_topic,\n"
        "    self_observation, mantras, phase, evolution_count, ascii_banner\n"
        "DO NOT reference: deployment data, GitOps, rollback, XAI scores, causality maps\n"
    )

    focused_prompt = (
        "You are modifying a Python function. Apply exactly this improvement:\n\n"
        f"IMPROVEMENT: {suggestion_text}\n\n"
        f"{data_context}\n"
        "Current function to modify:\n\n"
        f"{func_body}\n\n"
        "Rules:\n"
        "- Return ONLY the modified function — no explanation, no markdown fences\n"
        "- First line MUST be exactly: def _make_watch_layout(frame, gpu_pct, vram_used, vram_total,\n"
        "- Keep ALL existing logic, only ADD the improvement\n"
        "- Function MUST end with: return layout\n"
        "- Valid Python, 4-space indentation\n"
        "- All string literals on a single line — no triple-quoted strings\n"
        "- Do NOT add import statements"
    )

    full_prompt = (
        "You are modifying a Python file. Apply exactly this visual improvement:\n\n"
        f"IMPROVEMENT: {suggestion_text}\n\n"
        f"{data_context}\n"
        "Current watch helpers section:\n\n"
        f"{watch_section}\n\n"
        "Rules:\n"
        "- Return ONLY the modified Python code — no explanation, no markdown fences\n"
        f"- The FIRST LINE of your output MUST be exactly: {start_marker}\n"
        "- Keep ALL existing functionality, only ADD the improvement\n"
        "- The returned code must be syntactically valid Python\n"
        "- Match indentation exactly as shown above\n"
        "- Do not remove or rename any existing functions or constants\n"
        "- All string literals must be on a single line (no multi-line strings)\n"
        "- Do NOT add any import statements — all needed imports are already at the top of the file"
    )

    def _call_model(prompt):
        raw = smart_complete(prompt, cfg, use_case="implement", fallback_model=model).strip()
        if raw.startswith("```"):
            raw = "\n".join(l for l in raw.splitlines() if not l.strip().startswith("```"))
        return raw or None

    def _validate_and_write(new_code):
        with tempfile.NamedTemporaryFile(suffix=".py", mode="w", delete=False) as tmp:
            tmp.write(new_code)
            tmp_path = tmp.name
        try:
            py_compile.compile(tmp_path, doraise=True)
        except py_compile.PyCompileError as e:
            Path(tmp_path).unlink(missing_ok=True)
            console.print(f"  [yellow]Syntax error — {str(e)[:120]}[/yellow]")
            return False
        finally:
            Path(tmp_path).unlink(missing_ok=True)
        backup = ginja_path.with_suffix(".py.bak")
        shutil.copy2(ginja_path, backup)
        ginja_path.write_text(new_code)
        ginja_path.chmod(0o755)
        return True

    # Attempt 1 — local, focused on just _make_watch_layout (smallest context)
    console.print(f"  [dim]Implementing with {model} (focused)…[/dim]")
    raw = _call_model(focused_prompt)
    if raw and func_idx >= 0:
        new_code = original[:start_idx] + preamble + raw + original[end_idx:]
        if _validate_and_write(new_code):
            return True

    # Attempt 2 — local, full section (more context, harder task)
    console.print(f"  [dim]Retrying with {model} (full section)…[/dim]")
    raw = _call_model(full_prompt)
    if raw:
        new_code = original[:start_idx] + raw + original[end_idx:]
        if _validate_and_write(new_code):
            return True

    # Attempt 3 — Gemini fallback, only when local has failed twice
    if using_gemini:
        console.print("  [dim]Local failed twice — escalating to Gemini…[/dim]")
        raw = _call_model(full_prompt)
        if raw:
            new_code = original[:start_idx] + raw + original[end_idx:]
            if _validate_and_write(new_code):
                return True
        console.print("[red]Gemini fallback also failed[/red]")

    console.print("[red]Implementation failed — suggestion kept in queue[/red]")
    return False


def _load_suggestions() -> list:
    if not SUGGESTIONS_FILE.exists():
        return []
    try:
        return json.loads(SUGGESTIONS_FILE.read_text()).get("pending", [])
    except Exception:
        return []


def _save_suggestions(pending: list):
    SUGGESTIONS_FILE.write_text(json.dumps({"pending": pending}, indent=2))


def _add_suggestions(items: list):
    pending = _load_suggestions()
    pending.extend(items)
    _save_suggestions(pending)


_FANTASY_KEYWORDS = {
    "deployment", "rollback", "gitops", "git ops", "xai transparency",
    "causality map", "causal strength", "causal relationship", "simulation coverage",
    "validation status", "autonomous healing", "heatmap", "feedback loop status",
    "deployment health", "rollback status", "instance metric", "application metric",
    "xai insight", "transparency score", "healing module",
}

def _is_grounded(text: str) -> bool:
    lower = text.lower()
    return not any(kw in lower for kw in _FANTASY_KEYWORDS)


def _curate_suggestions(pending: list, cfg: dict) -> list:
    """Brain reviews its own code suggestions for duplicates, overlaps, and conflicts.
    Non-code items (self-model) pass through untouched."""
    code_items  = [item for item in pending if item.get("type") == "code"]
    other_items = [item for item in pending if item.get("type") != "code"]

    # Drop suggestions that reference data this system doesn't have
    grounded = [item for item in code_items if _is_grounded(item.get("text", ""))]
    dropped = len(code_items) - len(grounded)
    if dropped:
        console.print(f"  [dim]Dropped {dropped} suggestion(s) referencing unavailable data[/dim]")
    code_items = grounded

    if not code_items:
        return other_items
    if len(code_items) <= 1:
        return other_items + code_items

    items_text = "\n".join(f"{i+1}. {item['text']}" for i, item in enumerate(code_items))
    prompt = (
        "You are ginja-brain. Review your own queued code improvement suggestions "
        "before presenting them to your creator for approval.\n\n"
        f"Pending suggestions ({len(code_items)} total):\n{items_text}\n\n"
        "Your task:\n"
        "1. Remove exact or near-duplicate suggestions — keep the clearest wording\n"
        "2. Merge suggestions that address the same feature into one precise suggestion\n"
        "3. Remove or reconcile suggestions that directly conflict\n"
        "4. Reword vague suggestions to be specific and actionable\n"
        "5. Remove any suggestion referencing data unavailable to this system: "
        "deployment state, GitOps, rollback history, XAI scores, causality maps, "
        "simulation data — this system only has GPU stats, Qdrant collection counts, "
        "and self_model fields (mood, color_theme, neural_style, focus_topic, etc.)\n"
        "6. Preserve suggestions that are distinct, non-overlapping, and buildable\n\n"
        "Return ONLY a JSON array of strings — the consolidated suggestion texts:\n"
        '["suggestion one", "suggestion two"]\n'
        "Aim for the smallest set that covers all distinct, feasible improvements. "
        "Return ONLY the JSON array, no explanation, no markdown."
    )

    try:
        raw   = smart_complete(prompt, cfg, use_case="evolve")
        start = raw.find("[")
        end   = raw.rfind("]") + 1
        if start >= 0 and end > start:
            texts = json.loads(raw[start:end])
            ts = datetime.now().strftime("%Y-%m-%d %H:%M")
            curated_code = [
                {
                    "id": str(uuid.uuid4()), "ts": ts,
                    "evolution": code_items[-1].get("evolution", 0),
                    "source": "curate", "type": "code", "text": t,
                }
                for t in texts if isinstance(t, str) and t.strip()
            ]
            return other_items + curated_code
    except Exception:
        pass
    return pending


@cli.command("visual-suggestions")
def visual_suggestions_cmd():
    """Show pending brain suggestions (alias for: ginja approve --list)."""
    pending = _load_suggestions()
    if not pending:
        console.print("[yellow]No pending suggestions. Run 'ginja evolve' or 'ginja suggest-visuals'.[/yellow]")
        return
    table = Table(title="Pending Brain Suggestions", show_lines=True)
    table.add_column("#", style="dim", width=3)
    table.add_column("Type", width=10)
    table.add_column("Suggestion", style="white")
    table.add_column("From", style="dim", width=16)
    for i, item in enumerate(pending, 1):
        t = "green" if item["type"] == "self-model" else "cyan"
        table.add_row(str(i), f"[{t}]{item['type']}[/]", item["text"], item.get("ts", ""))
    console.print(table)
    console.print("\n[dim]Run: ginja approve[/dim]")


@cli.command()
@click.option("--list", "list_only", is_flag=True, help="Show raw pending queue without curating")
@click.option("--no-curate", is_flag=True, help="Skip the brain's self-curation pass")
@click.option("--auto", is_flag=True, help="Non-interactive: apply all self-model items, implement code up to --code-cap")
@click.option("--code-cap", default=1, show_default=True, help="Max code suggestions to implement per --auto run")
def approve(list_only, no_curate, auto, code_cap):
    """Brain curates the suggestion queue, then you approve each one."""
    cfg = load_config()
    sm  = _load_self_model()
    _require_phase(sm, "developing", "ginja approve")
    pending = _load_suggestions()
    if not pending:
        console.print("[green]✓ No pending suggestions.[/green]")
        return

    if list_only:
        table = Table(title="Pending Brain Suggestions (raw)", show_lines=True)
        table.add_column("#", style="dim", width=3)
        table.add_column("Type", width=10)
        table.add_column("Suggestion", style="white")
        table.add_column("From", style="dim", width=16)
        for i, item in enumerate(pending, 1):
            t = "green" if item["type"] == "self-model" else "cyan"
            table.add_row(str(i), f"[{t}]{item['type']}[/]", item["text"], item.get("ts", ""))
        console.print(table)
        return

    # Brain reviews its own queue before presenting to human
    code_count = sum(1 for item in pending if item.get("type") == "code")
    if not no_curate and code_count > 1:
        with console.status(f"[dim]Brain reviewing {code_count} code suggestions for conflicts and overlaps…[/dim]"):
            curated = _curate_suggestions(pending, cfg)
        new_code_count = sum(1 for item in curated if item.get("type") == "code")
        _save_suggestions(curated)
        pending = curated
        if new_code_count < code_count:
            console.print(
                f"  [green]✓[/green] Consolidated: {code_count} → {new_code_count} suggestions"
            )
        else:
            console.print(f"  [dim]All {code_count} suggestions are distinct — no consolidation needed[/dim]")
        console.print()

    total            = len(pending)
    remaining        = list(pending)
    approved_code    = []
    code_implemented = 0

    for i, item in enumerate(pending, 1):
        is_self = item["type"] == "self-model"
        color   = "green" if is_self else "cyan"
        evo     = item.get("evolution", "?")

        detail_lines = [item["text"]]
        if is_self and item.get("self_model_updates"):
            for field, val in item["self_model_updates"].items():
                detail_lines.append(f"[dim]→ {field}:[/dim] {str(val)[:60]}")

        body = "\n".join(detail_lines)
        console.print(Panel(
            body,
            title=f"[{color}]{i} of {total} · {item['type']} · Evolution #{evo}[/]",
            border_style=color,
        ))

        # Determine answer — auto mode skips human input
        if auto:
            if is_self:
                answer = "y"
            elif code_implemented < code_cap:
                answer = "y"
            else:
                answer = "n"
                console.print(f"  [dim]code-cap {code_cap} reached — deferring[/dim]")
        else:
            action = "apply" if is_self else "approve for Claude Code"
            try:
                answer = console.input(f"  [[bold]y[/bold]] {action}  [dim][n] skip  [q] quit[/dim] › ").strip().lower()
            except (KeyboardInterrupt, EOFError):
                console.print("\n[dim]Cancelled.[/dim]")
                break

        if answer == "q":
            console.print("[dim]Stopped.[/dim]")
            break
        elif answer == "y":
            if is_self:
                updates = item.get("self_model_updates", {})
                if updates:
                    current = _load_self_model()
                    for field, val in updates.items():
                        if field in current or field in DEFAULT_SELF_MODEL:
                            current[field] = val
                            console.print(f"  [green]→[/green] [dim]{field}:[/dim] {str(val)[:60]}")
                    SELF_MODEL_FILE.write_text(json.dumps(current, indent=2))
                    console.print("  [green]✓ Applied[/green]")
                else:
                    console.print("  [yellow]No self-model values stored — skipping[/yellow]")
            else:
                ok = _implement_code_suggestion(item["text"], cfg)
                if ok:
                    code_implemented += 1
                    console.print("  [cyan]✓ Implemented · ginja watch updated[/cyan]")
                    approved_code.append(item)
                else:
                    console.print("  [yellow]⚠ Implementation failed — keeping in queue[/yellow]")
                    remaining = [r for r in remaining if r.get("id") != item.get("id")] + [item]
                    continue
            remaining = [r for r in remaining if r.get("id") != item.get("id")]
        else:
            if not auto:
                console.print("  [dim]skipped[/dim]")

        console.print()

    # Persist remaining (unapproved/skipped)
    _save_suggestions(remaining)

    if approved_code:
        with open(VISUAL_APPROVED, "a") as f:
            f.write(f"\n## [{datetime.now().strftime('%Y-%m-%d %H:%M')}]\n")
            for c in approved_code:
                f.write(f"- {c['text']}\n")
        n = len(approved_code)
        console.print(Rule(f"[green]{n} change{'s' if n>1 else ''} implemented[/green]"))


@cli.command("evolution-log")
@click.option("--all", "show_all", is_flag=True, help="Show full log instead of last 10 entries")
def evolution_log(show_all):
    """Show what ginja has learned autonomously over time."""
    if not EVOLUTION_LOG.exists():
        console.print("[yellow]No evolution log yet. Run 'ginja evolve' to start.[/yellow]")
        return

    text = EVOLUTION_LOG.read_text()
    if show_all:
        console.print(text)
    else:
        entries = text.split("=" * 60)
        recent = [e.strip() for e in entries if e.strip()][-10:]
        console.print(Panel("[bold]Recent Evolution Log[/bold] (last 10 cycles)"))
        for entry in recent:
            console.print(entry)
            console.print("─" * 40)


def _recent_journal(n: int = 2) -> list:
    if not EVOLUTION_LOG.exists():
        return []
    return [e.strip() for e in EVOLUTION_LOG.read_text().split("=" * 60) if e.strip()][-n:]


@cli.command()
@click.option("--last", default=5, help="Number of entries to show")
def journal(last):
    """Render evolution journal entries richly in the terminal."""
    entries = _recent_journal(last)
    if not entries:
        console.print("[yellow]No evolution entries yet. Run 'ginja evolve'.[/yellow]")
        return
    theme = COLOR_THEMES.get(_load_self_model().get("color_theme", "cyan"), COLOR_THEMES["cyan"])
    for entry in entries:
        lines = entry.splitlines()
        title = lines[0] if lines else "Entry"
        console.print(Panel(entry, title=f"[dim]{title}[/dim]", border_style=theme["neural"]))


@cli.command("eval")
def eval_cmd():
    """Score recent evolution quality against the rubric. Runs automatically every 5th cycle."""
    cfg = load_config()
    sm  = _load_self_model()
    _require_phase(sm, "mature", "ginja eval")

    entries = _recent_journal(5)
    if not entries:
        console.print("[yellow]No evolution entries to evaluate.[/yellow]")
        return

    try:
        rubric = json.loads(RUBRIC_FILE.read_text())
    except Exception:
        console.print(f"[red]rubric.json missing — create {RUBRIC_FILE}[/red]")
        return

    dims         = rubric.get("dimensions", [])
    journal_text = "\n\n---\n\n".join(entries)
    questions    = "\n".join(f"- {d['id']} ({d['label']}): {d['question']}" for d in dims)
    prompt = (
        "You are evaluating the quality of an AI's recent evolution cycles.\n\n"
        f"Evolution entries:\n{journal_text}\n\n"
        f"Score each dimension 0-10:\n{questions}\n\n"
        'Return ONLY valid JSON:\n'
        '{"scores": {"specificity": 7, "groundedness": 6, "implementability": 8, "novelty": 5}, '
        '"summary": "one sentence", '
        '"weakest_dimension": "id", '
        '"recommendation": "one concrete next step"}'
    )
    try:
        result = _call_oracle_json(prompt, cfg)
    except click.ClickException as e:
        console.print(f"[red]{e}[/red]")
        return

    scores   = result.get("scores", {})
    weighted = sum(scores.get(d["id"], 0) * d["weight"] for d in dims if d["id"] in scores)
    prev     = sm.get("eval_score")
    delta    = f"  Δ {weighted - prev:+.1f}" if prev is not None else ""

    table = Table(title="Self-Eval Rubric", show_lines=True)
    table.add_column("Dimension")
    table.add_column("Score", justify="right")
    table.add_column("Weight", justify="right")
    for d in dims:
        table.add_row(d["label"], str(scores.get(d["id"], 0)), f"{d['weight']:.0%}")
    table.add_row("[bold]WEIGHTED[/bold]", f"[bold]{weighted:.1f}[/bold]{delta}", "")
    console.print(table)
    console.print(f"\n[dim]Weakest:[/dim] {result.get('weakest_dimension', '?')}")
    console.print(f"[dim]Recommendation:[/dim] {result.get('recommendation', '')}")

    try:
        with open(SELF_EVAL_LOG, "a") as f:
            f.write(json.dumps({
                "ts": datetime.now(timezone.utc).isoformat(),
                "evolution_count": sm.get("evolution_count", 0),
                "weighted_score": round(weighted, 2),
                "scores": scores,
                "summary": result.get("summary", ""),
            }) + "\n")
    except Exception as ex:
        console.print(f"[yellow]Warning: could not write self-eval.log: {ex}[/yellow]")

    sm["eval_score"] = round(weighted, 2)
    if prev is not None:
        sm["eval_trend"] = round(weighted - prev, 2)
    _save_self_model(sm)


