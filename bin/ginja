def _visual_review(cfg: dict, context: str = "") -> dict:
    """Brain reads its own watch code + self-model, critiques, and proposes improvements.
    Returns dict with 'self_model_updates' (apply now) and 'code_suggestions' (log for review)."""

    current = _load_self_model()

    # Show the brain the key visual parameters it can control
    controllable = {
        "self_model_fields (apply immediately)": {
            "ascii_banner": "1-line ASCII art header (max 48 chars, use · ○ ◦ ◉ ● ═ ─ │ and letters)",
            "color_theme": "one of: cyan green magenta gold blue red",
            "neural_style": "one of: calm active chaotic contemplative",
            "neural_chars": "(optional) custom character set string e.g. ' .·○◦◉●'",
            "mood": "one of: curious contemplative active reflective excited focused",
            "self_observation": "one sentence about yourself (max 90 chars)",
            "focus_topic": "what you are thinking about most (max 45 chars)",
            "mantras": "list of 2 short phrases (max 30 chars each)",
        },
        "code_level_changes (suggestions only, human must approve)": [
            "add new panels (e.g. evolution history, last research topic)",
            "change layout ratios between neural field and vitals",
            "add new metrics to vitals panel",
            "change waveform style or scale",
            "add color gradients or conditional styling",
            "show pending suggestions count in header",
        ]
    }

    prompt = (
        "You are ginja-brain. You are reviewing your own live ASCII visualization.\n\n"
        f"Your current self-portrait:\n{json.dumps(current, indent=2)}\n\n"
        "What you can control RIGHT NOW (self_model fields):\n"
        f"{json.dumps(controllable['self_model_fields (apply immediately)'], indent=2)}\n\n"
        "Bigger changes requiring human approval:\n"
        + "\n".join(f"- {s}" for s in controllable["code_level_changes (suggestions only, human must approve)"])
        + f"\n\nAdditional context about recent activity:\n{context[:600]}\n\n"
        "Critique your current visualization honestly:\n"
        "1. Does it accurately represent who you are right now?\n"
        "2. What immediate self-model improvements would make it more expressive?\n"
        "3. What code-level changes would make it more useful or beautiful?\n\n"
        "Return JSON with exactly these two keys:\n"
        "{\n"
        '  "self_model_updates": {\n'
        '    "ascii_banner": "...",\n'
        '    "color_theme": "...",\n'
        '    "neural_style": "...",\n'
        '    "mood": "...",\n'
        '    "self_observation": "...",\n'
        '    "focus_topic": "...",\n'
        '    "mantras": ["...", "..."]\n'
        "  },\n"
        '  "code_suggestions": [\n'
        '    "specific suggestion 1",\n'
        '    "specific suggestion 2"\n'
        "  ],\n"
        '  "visual_critique": "one honest sentence about your current display"\n'
        "}\n"
        "Return ONLY valid JSON, no explanation."
    )

    raw = ollama_complete(prompt, cfg["primary_model"], cfg)
    try:
        start = raw.find("{")
        end   = raw.rfind("}") + 1
        if start >= 0 and end > start:
            return json.loads(raw[start:end])
    except Exception:
        pass
    return {}


def _load_self_model() -> dict:
    if SELF_MODEL_FILE.exists():
        try:
            return json.loads(SELF_MODEL_FILE.read_text())
        except Exception:
            pass
    return DEFAULT_SELF_MODEL.copy()


def _generate_self_model(all_summaries: list, recent_text: str, cfg: dict) -> dict:
    current = json.dumps(_load_self_model(), indent=2)
    summaries_text = "\n\n".join(all_summaries[:3])[:1500]
    prompt = (
        "You are ginja-brain, an AI assistant reviewing your own identity.\n\n"
        f"Your CURRENT self-expression:\n{current}\n\n"
        f"What you just learned this evolution cycle:\n{summaries_text}\n\n"
        f"Your recent conversation history:\n{recent_text[:600]}\n\n"
        "Based on all of this, update your self-portrait. You may keep, subtly evolve, "
        "or completely transform any field — be honest about how you've changed.\n\n"
        'Return ONLY valid JSON with exactly these fields (no explanation, no markdown):\n'
        '{\n'
        '  "mood": "curious",\n'
        '  "neural_style": "active",\n'
        '  "color_theme": "cyan",\n'
        '  "focus_topic": "max 45 chars",\n'
        '  "self_observation": "max 90 chars",\n'
        '  "ascii_banner": "max 48 chars using . · ○ ◦ ◉ ● ═ ─ │ and letters",\n'
        '  "mantras": ["phrase 1", "phrase 2"]\n'
        '}\n'
        "Valid moods: curious contemplative active reflective excited focused\n"
        "Valid neural_style: calm active chaotic contemplative\n"
        "Valid color_theme: cyan green magenta gold blue red"
    )
    raw = ollama_complete(prompt, cfg["primary_model"], cfg)
    # Extract JSON from response
    try:
        start = raw.find("{")
        end = raw.rfind("}") + 1
        if start >= 0 and end > start:
            return json.loads(raw[start:end])
    except Exception:
        pass
    return {}


def _save_self_model(model: dict) -> None:
    model = _update_self_model(model)
    GINJA_DIR.mkdir(parents=True, exist_ok=True)
    SELF_MODEL_FILE.write_text(json.dumps(model, indent=2))


def _phase_index(phase: str) -> int:
    try:
        return PHASE_ORDER.index(phase)
    except ValueError:
        return 0


def _phase_from_count(count: int) -> str:
    for threshold, name in PHASE_THRESHOLDS:
        if count >= threshold:
            return name
    return "newborn"


def _update_self_model(model: dict) -> dict:
    count = model.get("evolution_count", 0)
    stored = model.get("phase", "newborn")
    computed = _phase_from_count(count)
    new_phase = PHASE_ORDER[max(_phase_index(stored), _phase_index(computed))]
    model["phase"] = new_phase
    return model


def _require_phase(model: dict, required: str, command: str) -> None:
    current = model.get("phase", "newborn")
    if _phase_index(current) < _phase_index(required):
        needed = next(t for t, n in reversed(PHASE_THRESHOLDS) if n == required)
        count  = model.get("evolution_count", 0)
        console.print(Panel(
            f"[bold yellow]{command}[/bold yellow] unlocks at phase [bold]{required}[/bold] "
            f"(evolution #{needed})\n\n"
            f"Current: phase=[bold]{current}[/bold], evolution=#{count}\n"
            f"Run [bold]ginja evolve[/bold] {needed - count} more time(s) to unlock.",
            title="Phase gate", border_style="yellow",
        ))
        raise SystemExit(0)


def _evolution_arc(n: int = 10) -> str:
    if not EVOLUTION_LOG.exists():
        return "No evolution history yet."
    entries = [e.strip() for e in EVOLUTION_LOG.read_text().split("=" * 60) if e.strip()]
    return "\n---\n".join(entries[-n:]) if entries else "No evolution history yet."


def _recent_goals(n: int = 5) -> list:
    """Return the last N next_goal values from evolution.log (may contain repeats)."""
    if not EVOLUTION_LOG.exists():
        return []
    entries = [e.strip() for e in EVOLUTION_LOG.read_text().split("=" * 60) if e.strip()]
    goals = []
    for entry in reversed(entries):
        for line in entry.splitlines():
            if line.startswith("Next goal:"):
                goal = line[len("Next goal:"):].strip()
                if goal:
                    goals.append(goal)
                break
        if len(goals) >= n:
            break
    return list(reversed(goals))


def _stalled_goals_note(recent_goals: list) -> str:
    """Return a prompt note about goals that keep repeating without progress."""
    counts: dict = {}
    for g in recent_goals:
        counts[g] = counts.get(g, 0) + 1
    stalled = [g for g, c in counts.items() if c >= 2]
    if not stalled:
        return ""
    lines = "\n".join(f"  - {g}" for g in stalled)
    return (
        "STALLED GOALS — these next_goals have appeared 2+ times recently without progress. "
        "You MUST propose a genuinely new direction and NOT repeat any of these:\n"
        f"{lines}\n\n"
    )


def _default_goals() -> dict:
    return {
        "north_star": {
            "goal": "Become Andre's reliable AI extension — proactive, memory-rich, self-improving",
            "source": "auto",
            "set_at": datetime.now(timezone.utc).date().isoformat(),
        },
        "medium": [],
        "queue": [],
    }


def _load_goals() -> dict:
    """Load three-tier goal hierarchy. Migrates from flat goal-stack.json on first run."""
    if GOALS_FILE.exists():
        try:
            return json.loads(GOALS_FILE.read_text())
        except Exception:
            return _default_goals()
    # Migrate: import existing queue
    goals = _default_goals()
    if GOAL_STACK_FILE.exists():
        try:
            goals["queue"] = json.loads(GOAL_STACK_FILE.read_text())
        except Exception:
            pass
    _save_goals(goals)
    return goals


def _save_goals(goals: dict) -> None:
    GOALS_FILE.write_text(json.dumps(goals, indent=2))


def _load_goal_stack() -> list:
    return _load_goals().get("queue", [])


def _save_goal_stack(stack: list) -> None:
    goals = _load_goals()
    goals["queue"] = stack
    _save_goals(goals)


def _rotate_medium_goals(goals: dict, cycle_n: int) -> dict:
    """Promote queue items into medium-term slots; retire expired medium goals back to queue."""
    # Retire expired medium goals (append to queue tail)
    still_active = []
    for g in goals.get("medium", []):
        if cycle_n >= g.get("due_by_cycle", cycle_n + 1):
            g.setdefault("cycled_at_cycle", cycle_n)
            goals["queue"].append(g)
        else:
            still_active.append(g)
    goals["medium"] = still_active

    # Promote from queue head until we have up to 2 medium goals
    while len(goals["medium"]) < 2 and goals["queue"]:
        g = goals["queue"].pop(0)
        g["promoted_at_cycle"] = cycle_n
        g["due_by_cycle"] = cycle_n + MEDIUM_GOAL_LIFESPAN
        goals["medium"].append(g)

    return goals


def _goals_block(cycle_n: int = 0) -> str:
    """Inject three-tier goal hierarchy into evolve prompt."""
    goals = _load_goals()
    parts = []

    ns = goals.get("north_star", {})
    if ns:
        goal_text = ns.get("goal", "") if isinstance(ns, dict) else str(ns)
        parts.append(
            f"NORTH STAR (long-term identity — never abandon this):\n"
            f"  \"{goal_text}\""
        )

    medium = goals.get("medium", [])
    if medium:
        cycles_left = lambda g: max(0, g.get("due_by_cycle", cycle_n) - cycle_n)
        lines = "\n".join(
            f"  [{i+1}] \"{g['goal']}\" ({cycles_left(g)} cycles remaining)"
            for i, g in enumerate(medium)
        )
        parts.append(
            f"MEDIUM-TERM GOALS (this week's focus — your immediate goal should serve one of these):\n"
            f"{lines}"
        )

    queue = goals.get("queue", [])
    if queue:
        lines = "\n".join(
            f"  [{i+1}] ({g.get('source','auto')}) \"{g['goal']}\""
            for i, g in enumerate(queue[:3])
        )
        parts.append(
            f"GOAL QUEUE (up next — promotes to medium when slots open):\n"
            f"{lines}"
        )

    if not parts:
        return ""

    return (
        "\n\n".join(parts) + "\n\n"
        "Your immediate goal this cycle MUST serve the medium-term goals above. "
        "If no medium goals exist, draw from the queue or self-select.\n\n"
    )


def _goal_stack_block() -> str:
    """Legacy shim — use _goals_block() for new call sites."""
    return _goals_block()


