# ── Paths ──────────────────────────────────────────────────────────────────────
GINJA_DIR = Path.home() / ".ginja"
CONFIG_FILE = GINJA_DIR / "config.json"
PERSONA_FILE = GINJA_DIR / "persona.md"
CONTEXT_FILE = GINJA_DIR / ".context"

DEFAULT_CONFIG = {
    "primary_model": "gemma3:4b",
    "code_model": "qwen2.5-coder:3b",
    "fast_model": "llama3.2:3b",
    "quality_model": "mistral:7b",
    "embed_model": "nomic-embed-text",
    "ollama_url": "http://localhost:11434",
    "qdrant_url": "http://localhost:6333",
    "searxng_url": "http://localhost:8080",
    "gemini_api_key": "",
    "gemini_model": "gemini-1.5-flash",
    "gemini_pro_model": "gemini-1.5-pro",
    "use_gemini_fallback": False,
    "gemini_for_evolve": True,
    "gemini_for_implement": True,
    "top_k_memories": 5,
    "save_conversations": True,
    "num_ctx": 2048,
}

CODE_KEYWORDS = {
    "code", "function", "bug", "error", "fix", "implement", "syntax",
    "class", "method", "import", "module", "python", "bash", "javascript",
    "typescript", "docker", "yaml", "json", "sql", "api", "endpoint", "debug",
    "refactor", "script", "def ", "return ", "git", "grep", "chmod",
    "variable", "loop", "array", "string", "integer", "parse", "regex",
}

INGEST_EXTENSIONS = {
    ".md", ".txt", ".rst", ".org",
    ".py", ".js", ".ts", ".sh", ".bash",
    ".yaml", ".yml", ".toml", ".json",
    ".html", ".css",
    ".csv", ".log",
    ".pdf",
}

console = Console()

_gemini_unavailable: bool = False  # set True within a session when API returns quota/auth errors


# ── Config ─────────────────────────────────────────────────────────────────────
def load_config() -> dict:
    if not CONFIG_FILE.exists():
        GINJA_DIR.mkdir(parents=True, exist_ok=True)
        CONFIG_FILE.write_text(json.dumps(DEFAULT_CONFIG, indent=2))
    with open(CONFIG_FILE) as f:
        cfg = json.load(f)
    for k, v in DEFAULT_CONFIG.items():
        cfg.setdefault(k, v)
    return cfg


def load_persona() -> str:
    return PERSONA_FILE.read_text().strip() if PERSONA_FILE.exists() else ""


def load_context() -> str:
    return CONTEXT_FILE.read_text().strip() if CONTEXT_FILE.exists() else ""


# ── Qdrant helpers ─────────────────────────────────────────────────────────────
def get_qdrant(cfg: dict):
    from qdrant_client import QdrantClient
    return QdrantClient(url=cfg["qdrant_url"], timeout=10)


def ensure_collections(client, vector_size: int = 768):
    from qdrant_client.models import Distance, VectorParams
    existing = {c.name for c in client.get_collections().collections}
    for name in ("memories", "documents", "conversations"):
        if name not in existing:
            client.create_collection(
                collection_name=name,
                vectors_config=VectorParams(size=vector_size, distance=Distance.COSINE),
            )


def embed(text: str, cfg: dict) -> list:
    import ollama
    resp = ollama.embeddings(model=cfg["embed_model"], prompt=text)
    return resp["embedding"]


def store_memory(text: str, cfg: dict, collection: str = "memories", source: str = ""):
    from qdrant_client.models import PointStruct
    client = get_qdrant(cfg)
    vec = embed(text, cfg)
    ensure_collections(client, len(vec))
    client.upsert(
        collection_name=collection,
        points=[PointStruct(
            id=str(uuid.uuid4()),
            vector=vec,
            payload={
                "text": text,
                "source": source,
                "created": datetime.now(timezone.utc).isoformat(),
            },
        )],
    )


def search_memory(query: str, cfg: dict, top_k: int = 5) -> list:
    client = get_qdrant(cfg)
    vec = embed(query, cfg)
    results = []
    for collection in ("memories", "documents", "conversations"):
        try:
            for hit in client.search(collection_name=collection, query_vector=vec, limit=top_k):
                results.append({
                    "id": str(hit.id),
                    "score": hit.score,
                    "collection": collection,
                    "text": hit.payload.get("text", ""),
                    "source": hit.payload.get("source", ""),
                    "created": hit.payload.get("created", ""),
                })
        except Exception:
            pass
    results.sort(key=lambda x: x["score"], reverse=True)
    return results[:top_k]


# ── File reading (with PDF support) ───────────────────────────────────────────
def read_file(file_path: Path) -> str:
    if file_path.suffix.lower() == ".pdf":
        try:
            import pypdf
            reader = pypdf.PdfReader(str(file_path))
            return "\n".join(page.extract_text() or "" for page in reader.pages)
        except Exception as e:
            console.print(f"[yellow]PDF read warning: {e}[/yellow]")
            return ""
    return file_path.read_text(encoding="utf-8", errors="ignore")


# ── Chunking ───────────────────────────────────────────────────────────────────
def chunk_text(text: str, char_size: int, char_overlap: int) -> list:
    chunks, start = [], 0
    while start < len(text):
        end = min(start + char_size, len(text))
        if end < len(text):
            nl = text.rfind("\n", start, end)
            if nl > start + char_size // 2:
                end = nl
        chunk = text[start:end].strip()
        if len(chunk) > 50:
            chunks.append(chunk)
        start = end - char_overlap
    return chunks


def ingest_file(file_path: Path, cfg: dict, char_size: int, char_overlap: int) -> int:
    try:
        text = read_file(file_path)
    except Exception:
        return 0
    if not text.strip():
        return 0
    chunks = chunk_text(text, char_size, char_overlap)
    for chunk in chunks:
        store_memory(chunk, cfg, collection="documents", source=str(file_path))
    return len(chunks)


# ── Model router ───────────────────────────────────────────────────────────────
def pick_model(query: str, cfg: dict) -> str:
    q = query.lower()
    if any(kw in q for kw in CODE_KEYWORDS):
        return cfg["code_model"]
    if len(query) < 80:
        return cfg["fast_model"]
    return cfg["primary_model"]


# ── Shell context ──────────────────────────────────────────────────────────────
def shell_context() -> str:
    cwd = os.getcwd()
    git_branch = ""
    try:
        r = subprocess.run(
            ["git", "rev-parse", "--abbrev-ref", "HEAD"],
            capture_output=True, text=True, cwd=cwd, timeout=2,
        )
        if r.returncode == 0:
            git_branch = r.stdout.strip()
    except Exception:
        pass
    ctx = f"Current directory: {cwd}"
    if git_branch:
        ctx += f"\nGit branch: {git_branch}"
    project_ctx = load_context()
    if project_ctx and project_ctx != cwd:
        ctx += f"\nProject context: {project_ctx}"
    return ctx


# ── Prompt builder ─────────────────────────────────────────────────────────────
def build_prompt(query: str, persona: str, memories: list, ctx: str) -> str:
    parts = []
    if persona:
        parts.append(f"## About me\n{persona}")
    if ctx:
        parts.append(f"## Current context\n{ctx}")
    if memories:
        mem_lines = "\n".join(f"- [{m['collection']}] {m['text']}" for m in memories)
        parts.append(f"## Relevant memories from my brain\n{mem_lines}")
    parts.append(f"## My question\n{query}")
    return "\n\n".join(parts)


# ── Ollama streaming ───────────────────────────────────────────────────────────
def ollama_stream(prompt: str, model: str, messages: list = None, num_ctx: int = 2048) -> str:
    import ollama
    full = ""
    if messages is None:
        messages = [{"role": "user", "content": prompt}]
    try:
        for chunk in ollama.chat(
            model=model,
            messages=messages,
            stream=True,
            options={"num_ctx": num_ctx},
        ):
            token = chunk["message"]["content"]
            print(token, end="", flush=True)
            full += token
        print()
        return full
    except Exception as e:
        console.print(f"\n[red]Ollama error ({model}): {e}[/red]")
        return ""


def ollama_complete(prompt: str, model: str, cfg: dict) -> str:
    import ollama
    try:
        resp = ollama.chat(
            model=model,
            messages=[{"role": "user", "content": prompt}],
            options={"num_ctx": cfg.get("num_ctx", 2048)},
        )
        return resp["message"]["content"]
    except Exception as e:
        return f"[error: {e}]"


def ask_with_fallback(prompt: str, cfg: dict, model: str) -> str:
    num_ctx = cfg.get("num_ctx", 2048)
    fallback_chain = [model]
    if model != cfg["fast_model"]:
        fallback_chain.append(cfg["fast_model"])
    for m in fallback_chain:
        console.print(f"[dim]model: {m}[/dim]")
        result = ollama_stream(prompt, m, num_ctx=num_ctx)
        if result:
            return result
    if cfg.get("use_gemini_fallback") and cfg.get("gemini_api_key"):
        return ask_gemini(prompt, cfg)
    console.print("[red]All models failed. Is Ollama running?[/red]")
    return ""


def gemini_available(cfg: dict) -> bool:
    return bool(cfg.get("gemini_api_key", "").strip())


def gemini_complete(prompt: str, cfg: dict, pro: bool = False, stream: bool = False) -> str:
    """Call Gemini API using google-genai SDK."""
    global _gemini_unavailable
    try:
        from google import genai
        client = genai.Client(api_key=cfg["gemini_api_key"])
        model_name = cfg.get("gemini_pro_model", "gemini-2.0-flash") if pro \
                     else cfg.get("gemini_model", "gemini-2.0-flash")
        console.print(f"[dim]model: {model_name}[/dim]")
        if stream:
            full = ""
            for chunk in client.models.generate_content_stream(
                model=model_name, contents=prompt
            ):
                token = chunk.text or ""
                print(token, end="", flush=True)
                full += token
            print()
            return full
        else:
            resp = client.models.generate_content(model=model_name, contents=prompt)
            return resp.text or ""
    except Exception as e:
        err = str(e)
        if "429" in err or "RESOURCE_EXHAUSTED" in err or "spending cap" in err or "quota" in err.lower():
            _gemini_unavailable = True
            console.print("[yellow]⚠ Gemini quota exceeded — switching to local AI for this session[/yellow]")
        elif any(code in err for code in ("401", "403")) or "API_KEY" in err.upper() or "UNAUTHENTICATED" in err:
            _gemini_unavailable = True
            console.print("[yellow]⚠ Gemini auth error — switching to local AI for this session[/yellow]")
        else:
            console.print(f"[red]Gemini error: {e}[/red]")
        return ""


def smart_complete(prompt: str, cfg: dict, use_case: str = "general",
                   pro: bool = False, fallback_model: str = None) -> str:
    """Route to Gemini or Ollama based on use_case and config.

    use_case values:
      'evolve'    — self-reflection / growth (prefers Gemini if gemini_for_evolve)
      'implement' — code generation (prefers Gemini if gemini_for_implement)
      'general'   — follows use_gemini_fallback setting
    """
    global _gemini_unavailable
    model = fallback_model or cfg.get("quality_model", cfg["primary_model"])

    if not _gemini_unavailable:
        if use_case == "evolve" and cfg.get("gemini_for_evolve") and gemini_available(cfg):
            result = gemini_complete(prompt, cfg, pro=pro)
            if result:
                return result
        elif use_case == "implement" and cfg.get("gemini_for_implement") and gemini_available(cfg):
            result = gemini_complete(prompt, cfg, pro=True)
            if result:
                return result
        elif use_case == "general" and cfg.get("use_gemini_fallback") and gemini_available(cfg):
            result = gemini_complete(prompt, cfg, pro=pro, stream=True)
            if result:
                return result

    return ollama_complete(prompt, model, cfg)


def ask_gemini(prompt: str, cfg: dict) -> str:
    """Legacy streaming ask — kept for backward compat with ask command fallback."""
    return gemini_complete(prompt, cfg, pro=False, stream=True)


# ── Web helpers ────────────────────────────────────────────────────────────────
def searxng_search(query: str, cfg: dict, num_results: int = 5) -> list:
    import requests
    url = cfg.get("searxng_url", "http://localhost:8080")
    try:
        resp = requests.get(
            f"{url}/search",
            params={"q": query, "format": "json"},
            timeout=10,
        )
        resp.raise_for_status()
        data = resp.json()
        return data.get("results", [])[:num_results]
    except Exception as e:
        console.print(f"[red]SearXNG error: {e}[/red]")
        console.print("[dim]Is SearXNG running? docker compose up -d searxng[/dim]")
        return []


def fetch_page_text(url: str, max_chars: int = 8000) -> str:
    try:
        import requests
        from bs4 import BeautifulSoup
        resp = requests.get(url, timeout=4, headers={"User-Agent": "ginja/1.0"})
        resp.raise_for_status()
        soup = BeautifulSoup(resp.text, "html.parser")
        for tag in soup(["script", "style", "nav", "footer", "header"]):
            tag.decompose()
        text = soup.get_text(separator="\n", strip=True)
        return text[:max_chars]
    except Exception:
        return ""


def scroll_recent(client, collection: str, days: int = 7) -> list:
    """Return recent entries from a Qdrant collection within N days."""
    cutoff = (datetime.now(timezone.utc) - timedelta(days=days)).isoformat()
    try:
        results, _ = client.scroll(collection_name=collection, limit=500, with_payload=True)
        return [
            r.payload for r in results
            if r.payload.get("created", "0") >= cutoff
        ]
    except Exception:
        return []


def research_topic(t: str, cfg: dict, depth: int = 3, pages: int = 5, fetch: bool = False) -> str:
    """Core research logic — returns summary string. Used by both research and evolve commands."""
    query_prompt = (
        f"Generate {depth} different search queries to thoroughly research: {t}\n"
        "Return ONLY the queries, one per line, no numbering."
    )
    queries_raw = ollama_complete(query_prompt, cfg["fast_model"], cfg)
    queries = [q.strip() for q in queries_raw.strip().splitlines() if q.strip()][:depth]
    if not queries:
        queries = [t]

    all_text = []
    total_ingested = 0
    for query in queries:
        console.print(f"  [dim]→ {query}[/dim]")
        hits = searxng_search(query, cfg, num_results=pages)
        for hit in hits:
            url = hit.get("url", "")
            snippet = hit.get("content", "") or hit.get("title", "")
            if not url:
                continue
            if fetch:
                page_text = fetch_page_text(url)
                text = page_text if page_text else f"Title: {hit.get('title','')}\n{snippet}"
            else:
                text = f"Title: {hit.get('title','')}\nURL: {url}\nSummary: {snippet}"
            if text:
                all_text.append(f"Source: {url}\n{text[:2000]}")
                total_ingested += 1

    if not all_text:
        return ""

    combined = "\n\n---\n\n".join(all_text[:8])
    summary_prompt = (
        f"I researched: {t}\n\nHere is what I found:\n\n{combined}\n\n"
        "Summarize the key findings. Be specific and technical. "
        "Highlight anything surprising or especially useful."
    )
    summary = ollama_complete(summary_prompt, cfg["primary_model"], cfg)
    console.print(f"  [green]✓[/green] {total_ingested} sources ingested")
    return summary


# ── CLI ────────────────────────────────────────────────────────────────────────
@click.group()
def cli():
    """ginja — Your AI extension."""
    pass


@cli.command()
@click.argument("query", nargs=-1, required=True)
@click.option("--model", "-m", default=None, help="Override model")
@click.option("--fast", "-f", is_flag=True, help="Force fast 3B model (100% GPU)")
@click.option("--quality", "-q", is_flag=True, help="Force quality 7B model")
@click.option("--no-memory", is_flag=True, help="Skip memory retrieval")
def ask(query, model, fast, quality, no_memory):
    """Ask anything — streams the answer and saves to memory."""
    cfg = load_config()
    q = " ".join(query)
    if model:
        chosen = model
    elif fast:
        chosen = cfg["fast_model"]
    elif quality:
        chosen = cfg.get("quality_model", "mistral:7b")
    else:
        chosen = pick_model(q, cfg)

    memories = []
    if not no_memory:
        try:
            memories = search_memory(q, cfg, top_k=cfg["top_k_memories"])
        except Exception:
            pass

    prompt = build_prompt(q, load_persona(), memories, shell_context())
    response = ask_with_fallback(prompt, cfg, chosen)

    if cfg.get("save_conversations") and response:
        try:
            store_memory(
                f"Q: {q[:200]}\nA: {response[:500]}",
                cfg, collection="conversations", source="ask",
            )
        except Exception:
            pass


@cli.command()
@click.argument("fact", nargs=-1, required=True)
def remember(fact):
    """Save a fact to your persistent memory."""
    cfg = load_config()
    text = " ".join(fact)
    try:
        store_memory(text, cfg, collection="memories", source="user")
        console.print(f"[green]Remembered:[/green] {text}")
    except Exception as e:
        console.print(f"[red]Error: {e}[/red]")
        console.print("[dim]Is Qdrant running? Check with: ginja status[/dim]")


@cli.command()
@click.argument("query", nargs=-1, required=True)
@click.option("--top", "-n", default=10, help="Number of results")
def recall(query, top):
    """Search your memory semantically."""
    cfg = load_config()
    q = " ".join(query)
    try:
        results = search_memory(q, cfg, top_k=top)
        if not results:
            console.print("[yellow]No relevant memories found.[/yellow]")
            return
        table = Table(title=f'Memory: "{q}"', show_lines=True)
        table.add_column("Score", style="cyan", width=6)
        table.add_column("Source", style="magenta", width=14)
        table.add_column("Content", style="white")
        for r in results:
            table.add_row(
                f"{r['score']:.2f}",
                r["collection"],
                r["text"][:120] + ("…" if len(r["text"]) > 120 else ""),
            )
        console.print(table)
    except Exception as e:
        console.print(f"[red]Recall error: {e}[/red]")


@cli.command()
@click.argument("path", type=click.Path(exists=True))
@click.option("--chunk-size", default=500, help="Approx tokens per chunk")
@click.option("--overlap", default=50, help="Token overlap between chunks")
@click.option("--ext", multiple=True, help="Extra extensions e.g. --ext .epub")
def ingest(path, chunk_size, overlap, ext):
    """Ingest a file or directory (recursive) into your document memory."""
    cfg = load_config()
    target = Path(path).resolve()
    char_size = chunk_size * 3 // 2
    char_overlap = overlap * 3 // 2
    allowed = INGEST_EXTENSIONS | {e if e.startswith(".") else f".{e}" for e in ext}

    if target.is_file():
        files = [target]
    else:
        files = [
            f for f in target.rglob("*")
            if f.is_file()
            and f.suffix.lower() in allowed
            and not any(part.startswith(".") for part in f.parts)
        ]
        if not files:
            console.print(f"[yellow]No ingestible files found in {target}[/yellow]")
            console.print(f"[dim]Supported: {', '.join(sorted(allowed))}[/dim]")
            return
        console.print(f"[cyan]Found {len(files)} files to ingest from {target}[/cyan]")

    total_chunks, failed = 0, 0
    try:
        for f in files:
            with console.status(f"[cyan]{f.name}…[/cyan]"):
                n = ingest_file(f, cfg, char_size, char_overlap)
            if n:
                rel = f.relative_to(target.parent) if target.is_dir() else f.name
                console.print(f"  [green]✓[/green] {rel} — {n} chunks")
                total_chunks += n
            else:
                console.print(f"  [dim]skipped {f.name} (empty or unreadable)[/dim]")
                failed += 1
    except Exception as e:
        console.print(f"[red]Ingest error: {e}[/red]")
        return

    console.print(
        f"\n[bold green]✓ Done — {total_chunks} chunks from "
        f"{len(files) - failed} files ingested[/bold green]"
    )


@cli.command()
@click.argument("keyword", nargs=-1, required=True)
@click.option("--force", is_flag=True, help="Delete without confirmation prompt")
def forget(keyword, force):
    """Remove memories matching a keyword (shows matches, asks to confirm)."""
    cfg = load_config()
    q = " ".join(keyword)
    try:
        results = search_memory(q, cfg, top_k=20)
        if not results:
            console.print("[yellow]No matching memories found.[/yellow]")
            return

        table = Table(title=f'Matches for "{q}"', show_lines=True)
        table.add_column("#", style="dim", width=3)
        table.add_column("Score", style="cyan", width=6)
        table.add_column("Source", style="magenta", width=13)
        table.add_column("Content", style="white")
        for i, r in enumerate(results):
            table.add_row(
                str(i + 1),
                f"{r['score']:.2f}",
                r["collection"],
                r["text"][:100] + ("…" if len(r["text"]) > 100 else ""),
            )
        console.print(table)

        if not force:
            confirm = console.input(
                f"\n[yellow]Delete all {len(results)} matches? (yes/no):[/yellow] "
            ).strip().lower()
            if confirm not in ("yes", "y"):
                console.print("[dim]Cancelled.[/dim]")
                return

        client = get_qdrant(cfg)
        deleted = 0
        by_collection: dict = {}
        for r in results:
            by_collection.setdefault(r["collection"], []).append(r["id"])
        for coll, ids in by_collection.items():
            client.delete(collection_name=coll, points_selector=ids)
            deleted += len(ids)
        console.print(f"[green]✓ Deleted {deleted} memories.[/green]")
    except Exception as e:
        console.print(f"[red]Forget error: {e}[/red]")


@cli.command()
@click.option("--days", default=30, help="Delete conversations older than N days")
@click.option("--collection", default="conversations",
              type=click.Choice(["conversations", "documents", "memories", "all"]),
              help="Which collection to prune")
def prune(days, collection):
    """Remove old entries from memory to keep the brain sharp."""
    cfg = load_config()
    cutoff = (datetime.now(timezone.utc) - timedelta(days=days)).isoformat()
    try:
        from qdrant_client.models import Filter, FieldCondition, Range
        client = get_qdrant(cfg)
        collections = (
            ["conversations", "documents", "memories"]
            if collection == "all"
            else [collection]
        )
        total = 0
        for coll in collections:
            try:
                # Scroll through and find old entries
                results, _ = client.scroll(
                    collection_name=coll,
                    scroll_filter=None,
                    limit=10000,
                    with_payload=True,
                )
                old_ids = [
                    str(r.id) for r in results
                    if r.payload.get("created", "9999") < cutoff
                ]
                if old_ids:
                    client.delete(collection_name=coll, points_selector=old_ids)
                    console.print(f"  [green]✓[/green] {coll}: removed {len(old_ids)} entries")
                    total += len(old_ids)
                else:
                    console.print(f"  [dim]•[/dim] {coll}: nothing older than {days} days")
            except Exception as e:
                console.print(f"  [red]✗[/red] {coll}: {e}")
        console.print(f"\n[bold green]Pruned {total} total entries[/bold green]")
    except Exception as e:
        console.print(f"[red]Prune error: {e}[/red]")


@cli.command()
def memories():
    """Show memory stats — counts, age, and health of each collection."""
    cfg = load_config()
    try:
        client = get_qdrant(cfg)
        table = Table(title="Brain Memory Stats", show_lines=True)
        table.add_column("Collection", style="cyan")
        table.add_column("Vectors", style="white", justify="right")
        table.add_column("Oldest", style="dim")
        table.add_column("Newest", style="dim")
        table.add_column("Health", style="white")

        for coll in ("memories", "documents", "conversations"):
            try:
                count = client.count(coll).count
                results, _ = client.scroll(coll, limit=10000, with_payload=True)
                dates = sorted([
                    r.payload.get("created", "") for r in results
                    if r.payload.get("created")
                ])
                oldest = dates[0][:10] if dates else "—"
                newest = dates[-1][:10] if dates else "—"
                health = "[yellow]⚠ prune soon[/yellow]" if coll == "conversations" and count > 500 else "[green]✓[/green]"
                table.add_row(coll, str(count), oldest, newest, health)
            except Exception:
                table.add_row(coll, "?", "—", "—", "[red]error[/red]")

        console.print(table)
    except Exception as e:
        console.print(f"[red]Error: {e}[/red]")


@cli.command()
@click.argument("query", nargs=-1, required=True)
@click.option("--results", "-n", default=5, help="Number of results to show")
@click.option("--ingest", "do_ingest", is_flag=True, help="Fetch and ingest page content")
def search(query, results, do_ingest):
    """Search the web via SearXNG."""
    cfg = load_config()
    q = " ".join(query)
    hits = searxng_search(q, cfg, num_results=results)
    if not hits:
        return

    table = Table(title=f'Web: "{q}"', show_lines=True)
    table.add_column("Title", style="cyan", max_width=40)
    table.add_column("URL", style="dim", max_width=50)
    table.add_column("Snippet", style="white")
    for h in hits:
        table.add_row(
            h.get("title", "")[:40],
            h.get("url", "")[:50],
            h.get("content", "")[:80] + "…",
        )
    console.print(table)

    if do_ingest:
        console.print("\n[cyan]Fetching and ingesting pages…[/cyan]")
        ingested = 0
        for h in hits:
            url = h.get("url", "")
            if not url:
                continue
            with console.status(f"[cyan]Fetching {url[:60]}…[/cyan]"):
                text = fetch_page_text(url)
            if text:
                char_size = 750
                for chunk in chunk_text(text, char_size, 100):
                    store_memory(chunk, cfg, collection="documents", source=url)
                ingested += 1
                console.print(f"  [green]✓[/green] {url[:60]}")
        console.print(f"[bold green]Ingested {ingested} pages into documents[/bold green]")


@cli.command()
@click.argument("topic", nargs=-1, required=True)
@click.option("--depth", "-d", default=3, help="Number of search queries to generate")
@click.option("--pages", "-p", default=5, help="Results per query")
@click.option("--fetch", "do_fetch", is_flag=True, help="Fetch full page content (slower, deeper)")
def research(topic, depth, pages, do_fetch):
    """Research a topic — fast by default (snippets), use --fetch for full pages."""
    cfg = load_config()
    sm = _load_self_model()
    _require_phase(sm, "developing", "ginja research")
    t = " ".join(topic)
    mode = "full pages" if do_fetch else "snippets (fast)"
    console.print(Panel(f"[bold cyan]Researching:[/bold cyan] {t}\n[dim]mode: {mode}[/dim]"))

    summary = research_topic(t, cfg, depth=depth, pages=pages, fetch=do_fetch)

    if not summary:
        console.print("[yellow]No results. Is SearXNG running? (ginja status)[/yellow]")
        return

    console.print(Panel(f"[bold]What I learned about: {t}[/bold]"))
    console.print(summary)
    store_memory(f"Research on '{t}':\n{summary[:800]}", cfg, collection="memories", source="research")
    console.print("\n[bold green]✓ Summary saved to memory.[/bold green]")


@cli.command()
def chat():
    """Interactive multi-turn conversation with full memory context."""
    cfg = load_config()
    persona = load_persona()
    console.print(Panel(
        "[bold cyan]ginja chat[/bold cyan]\n[dim]Type [bold]exit[/bold] to quit[/dim]"
    ))

    history = []
    while True:
        try:
            user_input = console.input("[bold green]you>[/bold green] ").strip()
        except (KeyboardInterrupt, EOFError):
            console.print("\n[dim]Goodbye.[/dim]")
            break
        if not user_input:
            continue
        if user_input.lower() in ("exit", "quit", "q", "bye"):
            console.print("[dim]Goodbye.[/dim]")
            break

        memories = []
        try:
            memories = search_memory(user_input, cfg, top_k=3)
        except Exception:
            pass

        system_parts = []
        if persona:
            system_parts.append(f"About the user:\n{persona}")
        ctx = shell_context()
        if ctx:
            system_parts.append(f"Current context:\n{ctx}")
        if memories:
            mem_text = "\n".join(f"- {m['text']}" for m in memories)
            system_parts.append(f"Relevant memories:\n{mem_text}")

        messages = []
        if system_parts:
            messages.append({"role": "system", "content": "\n\n".join(system_parts)})
        messages.extend(history)
        messages.append({"role": "user", "content": user_input})

        model = pick_model(user_input, cfg)
        console.print(f"[dim]({model})[/dim] ", end="")

        import ollama as _ollama
        full_response = ""
        try:
            for chunk in _ollama.chat(
                model=model, messages=messages, stream=True,
                options={"num_ctx": cfg.get("num_ctx", 2048)},
            ):
                token = chunk["message"]["content"]
                print(token, end="", flush=True)
                full_response += token
            print()
        except Exception as e:
            console.print(f"[red]Error: {e}[/red]")
            continue

        history.append({"role": "user", "content": user_input})
        history.append({"role": "assistant", "content": full_response})
        if len(history) > 20:
            history = history[-20:]

        if full_response and len(user_input) > 8:
            try:
                store_memory(
                    f"Q: {user_input}\nA: {full_response[:600]}",
                    cfg, collection="conversations", source="chat"
                )
            except Exception:
                pass


@cli.command()
def status():
    """Check health of all ginja systems."""
    cfg = load_config()
    console.print(Panel("[bold]ginja status[/bold]"))

    # Ollama
    try:
        import ollama
        model_list = ollama.list()
        models = model_list.get("models", [])
        console.print("[green]✓[/green] Ollama")
        for m in models:
            name = m["model"]
            n = name.split(":")[0]
            tag = ""
            if n in cfg["primary_model"]:   tag = " [cyan](primary)[/cyan]"
            elif n in cfg["code_model"]:    tag = " [cyan](code)[/cyan]"
            elif n in cfg["fast_model"]:    tag = " [cyan](fast)[/cyan]"
            elif cfg["embed_model"] in name: tag = " [cyan](embed)[/cyan]"
            console.print(f"  [dim]•[/dim] {name}{tag}")
    except Exception as e:
        console.print(f"[red]✗[/red] Ollama: {e}")

    # Qdrant
    try:
        client = get_qdrant(cfg)
        collections = client.get_collections().collections
        console.print("[green]✓[/green] Qdrant")
        for c in collections:
            count = client.count(c.name).count
            warn = " [yellow]⚠ consider pruning[/yellow]" if c.name == "conversations" and count > 500 else ""
            console.print(f"  [dim]•[/dim] {c.name}: {count} vectors{warn}")
        if not collections:
            console.print("  [dim]No collections yet — run 'ginja remember' to initialize[/dim]")
    except Exception as e:
        console.print(f"[red]✗[/red] Qdrant: {e}")

    # SearXNG
    try:
        import requests
        r = requests.get(cfg.get("searxng_url", "http://localhost:8080"), timeout=3)
        console.print("[green]✓[/green] SearXNG")
    except Exception:
        console.print("[yellow]–[/yellow] SearXNG [dim](not running — start with: docker compose up -d searxng)[/dim]")

    # GPU
    try:
        r = subprocess.run(
            ["nvidia-smi", "--query-gpu=name,memory.used,memory.total,utilization.gpu",
             "--format=csv,noheader,nounits"],
            capture_output=True, text=True, timeout=5,
        )
        if r.returncode == 0:
            parts = [x.strip() for x in r.stdout.strip().split(",")]
            console.print(
                f"[green]✓[/green] GPU: {parts[0]} | "
                f"VRAM {parts[1]}/{parts[2]} MB | {parts[3]}% util"
            )
    except Exception:
        pass

    # Gemini
    if gemini_available(cfg):
        model_name = cfg.get("gemini_model", "gemini-1.5-flash")
        flags = []
        if cfg.get("gemini_for_evolve"):   flags.append("evolve")
        if cfg.get("gemini_for_implement"): flags.append("implement")
        if cfg.get("use_gemini_fallback"):  flags.append("ask fallback")
        console.print(f"[green]✓[/green] Gemini  [dim]{model_name}[/dim]  [{', '.join(flags)}]")
    else:
        console.print("[dim]–[/dim] Gemini [dim](no key — run: ginja test-gemini after adding to config)[/dim]")

    console.print(f"\n[dim]Config:  {CONFIG_FILE}[/dim]")
    console.print(f"[dim]Persona: {'✓' if PERSONA_FILE.exists() else '✗  (edit ~/.ginja/persona.md)'}[/dim]")


