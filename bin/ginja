# ── Knowledge Graph ────────────────────────────────────────────────────────────

KG_RELATIONS  = ["enables", "depends_on", "part_of", "orchestrates", "implements",
                  "related_to", "learned_from", "contrasts_with"]
KG_CATEGORIES = ["tool", "concept", "system", "goal", "technique"]
KG_DOMAINS    = ["homelab", "ai", "networking", "storage", "general"]


def _kg_ensure(client, vector_size: int):
    from qdrant_client.models import Distance, VectorParams
    existing = {c.name for c in client.get_collections().collections}
    for name in ("kg_nodes", "kg_edges"):
        if name not in existing:
            client.create_collection(
                collection_name=name,
                vectors_config=VectorParams(size=vector_size, distance=Distance.COSINE),
            )


def _kg_node_text(label: str, description: str) -> str:
    return f"{label}: {description}"


def _kg_edge_text(source_label: str, relation: str, target_label: str, description: str) -> str:
    return f"{source_label} {relation} {target_label}: {description}"


def _kg_find_node(client, label: str):
    """Find a node by exact label match. Returns ScoredPoint-like object or None."""
    from qdrant_client.models import Filter, FieldCondition, MatchValue
    try:
        results, _ = client.scroll(
            collection_name="kg_nodes",
            scroll_filter=Filter(must=[FieldCondition(key="label", match=MatchValue(value=label))]),
            limit=1,
            with_payload=True,
        )
        return results[0] if results else None
    except Exception:
        return None


def _kg_upsert_node(client, cfg: dict, label: str, category: str, domain: str,
                    description: str, confidence: float = 0.8, tags: list = None,
                    source: str = "manual", cycle: int = 0, memory_ids: list = None) -> str:
    from qdrant_client.models import PointStruct
    node_id = str(uuid.uuid4())
    vec = embed(_kg_node_text(label, description), cfg)
    _kg_ensure(client, len(vec))
    now = datetime.now(timezone.utc).isoformat()
    client.upsert(
        collection_name="kg_nodes",
        points=[PointStruct(
            id=node_id,
            vector=vec,
            payload={
                "label":       label,
                "category":    category,
                "domain":      domain,
                "description": description,
                "confidence":  confidence,
                "tags":        tags or [],
                "source":      source,
                "cycle":       cycle,
                "memory_ids":  memory_ids or [],
                "created_at":  now,
                "updated_at":  now,
            },
        )],
    )
    return node_id


def _kg_upsert_edge(client, cfg: dict, source_id: str, target_id: str,
                    source_label: str, target_label: str, relation: str,
                    description: str, weight: float = 0.8,
                    source: str = "manual", cycle: int = 0) -> str:
    from qdrant_client.models import PointStruct
    edge_id = str(uuid.uuid4())
    vec = embed(_kg_edge_text(source_label, relation, target_label, description), cfg)
    _kg_ensure(client, len(vec))
    client.upsert(
        collection_name="kg_edges",
        points=[PointStruct(
            id=edge_id,
            vector=vec,
            payload={
                "source_id":    source_id,
                "target_id":    target_id,
                "source_label": source_label,
                "target_label": target_label,
                "relation":     relation,
                "description":  description,
                "weight":       weight,
                "source":       source,
                "cycle":        cycle,
                "created_at":   datetime.now(timezone.utc).isoformat(),
            },
        )],
    )
    return edge_id


def _kg_get_edges(client, node_id: str) -> tuple:
    """Return (outgoing, incoming) edge payload lists for a node."""
    from qdrant_client.models import Filter, FieldCondition, MatchValue
    out, _ = client.scroll(
        collection_name="kg_edges",
        scroll_filter=Filter(must=[FieldCondition(key="source_id", match=MatchValue(value=node_id))]),
        limit=100, with_payload=True,
    )
    inc, _ = client.scroll(
        collection_name="kg_edges",
        scroll_filter=Filter(must=[FieldCondition(key="target_id", match=MatchValue(value=node_id))]),
        limit=100, with_payload=True,
    )
    return [r.payload for r in out], [r.payload for r in inc]


def _graph_enrich_text(text: str, cycle_n: int, cfg: dict):
    """Extract concepts and relationships from text and upsert them into the knowledge graph."""
    prompt = (
        "Extract key concepts and relationships from the text below. "
        "Return ONLY valid JSON, no explanation:\n"
        '{"nodes": [{"label": "...", "category": "tool|concept|technique|system|goal", '
        '"domain": "homelab|ai|networking|storage|general", "description": "one sentence"}], '
        '"edges": [{"from": "...", "to": "...", '
        '"relation": "enables|depends_on|part_of|related_to|learned_from", '
        '"description": "one sentence"}]}\n'
        "Max 4 nodes, 4 edges. Use existing labels if they match concepts in the text.\n\n"
        f"TEXT:\n{text[:1200]}"
    )
    try:
        raw = ollama_complete(prompt, cfg.get("fast_model", cfg["primary_model"]), cfg)
        start = raw.find("{")
        end = raw.rfind("}") + 1
        if start < 0 or end <= start:
            return
        data = json.loads(raw[start:end])
    except Exception:
        return

    client = get_qdrant(cfg)
    node_map: dict = {}
    for n in data.get("nodes", []):
        label = n.get("label", "").strip()
        if not label:
            continue
        category = n.get("category", "concept")
        domain   = n.get("domain", "general")
        desc     = n.get("description", "")
        if category not in KG_CATEGORIES:
            category = "concept"
        if domain not in KG_DOMAINS:
            domain = "general"
        try:
            node_id = _kg_upsert_node(client, cfg, label, category, domain, desc,
                                      confidence=0.75, source="evolve", cycle=cycle_n)
            node_map[label.lower()] = node_id
        except Exception:
            pass

    for e in data.get("edges", []):
        from_label = e.get("from", "").strip()
        to_label   = e.get("to", "").strip()
        relation   = e.get("relation", "related_to")
        desc       = e.get("description", "")
        if relation not in KG_RELATIONS:
            relation = "related_to"
        src_id = node_map.get(from_label.lower())
        dst_id = node_map.get(to_label.lower())
        if not src_id:
            existing = _kg_find_node(client, from_label)
            if existing:
                src_id = str(existing.id)
        if not dst_id:
            existing = _kg_find_node(client, to_label)
            if existing:
                dst_id = str(existing.id)
        if src_id and dst_id:
            try:
                _kg_upsert_edge(client, cfg, src_id, dst_id, from_label, to_label,
                                relation, desc, weight=0.75, source="evolve", cycle=cycle_n)
            except Exception:
                pass


def _graph_context_for_topic(topic: str, cfg: dict, top_n: int = 4) -> str:
    """Return a formatted string of graph nodes + edges relevant to topic, for oracle prompts."""
    try:
        client = get_qdrant(cfg)
        _kg_ensure(client, 768)
        vec = embed(topic, cfg)
        hits = client.query_points(collection_name="kg_nodes", query=vec, limit=top_n).points
        if not hits:
            return ""
        lines = ["Knowledge graph context:"]
        for hit in hits:
            if hit.score < 0.5:
                continue
            p = hit.payload
            label    = p.get("label", "?")
            category = p.get("category", "?")
            domain   = p.get("domain", "?")
            desc     = p.get("description", "")
            outgoing, incoming = _kg_get_edges(client, str(hit.id))
            edge_parts = []
            for edge in outgoing[:3]:
                edge_parts.append(f"→ {edge.get('relation','?')}: {edge.get('target_label','?')}")
            for edge in incoming[:2]:
                edge_parts.append(f"← {edge.get('relation','?')}: {edge.get('source_label','?')}")
            edge_str = "  " + "; ".join(edge_parts) if edge_parts else ""
            lines.append(f"· {label} [{category}/{domain}] — {desc}")
            if edge_str:
                lines.append(edge_str)
        return "\n".join(lines) + "\n" if len(lines) > 1 else ""
    except Exception:
        return ""


@cli.group()
def graph():
    """Semantic knowledge graph — nodes, edges, and structured reasoning."""
    pass


@graph.command("add-node")
@click.option("--label",       required=True, help="Concept name, e.g. 'Qdrant'")
@click.option("--category",    required=True, type=click.Choice(KG_CATEGORIES), help="Node type")
@click.option("--domain",      required=True, type=click.Choice(KG_DOMAINS),    help="Domain area")
@click.option("--description", default="",   help="1-2 sentence explanation")
@click.option("--confidence",  default=0.8,  type=float, help="Understanding confidence 0.0-1.0")
@click.option("--tags",        default="",   help="Comma-separated tags")
def graph_add_node(label, category, domain, description, confidence, tags):
    """Add a concept node to the knowledge graph."""
    cfg      = load_config()
    client   = get_qdrant(cfg)
    tag_list = [t.strip() for t in tags.split(",") if t.strip()] if tags else []
    node_id  = _kg_upsert_node(client, cfg, label, category, domain,
                                description, confidence, tag_list)
    console.print(f"[green]✓[/green] Node [bold]{label}[/bold] added  [dim]{node_id[:8]}…[/dim]")


@graph.command("add-edge")
@click.option("--from",        "from_label", required=True, help="Source node label")
@click.option("--to",          "to_label",   required=True, help="Target node label")
@click.option("--relation",    required=True, type=click.Choice(KG_RELATIONS), help="Relationship type")
@click.option("--description", default="",   help="Full sentence describing the relationship")
@click.option("--weight",      default=0.8,  type=float, help="Relationship strength 0.0-1.0")
def graph_add_edge(from_label, to_label, relation, description, weight):
    """Add a directed edge between two nodes."""
    cfg    = load_config()
    client = get_qdrant(cfg)
    src    = _kg_find_node(client, from_label)
    tgt    = _kg_find_node(client, to_label)
    if not src:
        console.print(f"[red]Node not found:[/red] {from_label}")
        console.print(f"[dim]Run: ginja graph add-node --label '{from_label}' --category … --domain …[/dim]")
        return
    if not tgt:
        console.print(f"[red]Node not found:[/red] {to_label}")
        console.print(f"[dim]Run: ginja graph add-node --label '{to_label}' --category … --domain …[/dim]")
        return
    if not description:
        description = f"{from_label} {relation} {to_label}"
    edge_id = _kg_upsert_edge(client, cfg, str(src.id), str(tgt.id),
                               from_label, to_label, relation, description, weight)
    console.print(
        f"[green]✓[/green] [bold]{from_label}[/bold] "
        f"[cyan]{relation}[/cyan] [bold]{to_label}[/bold]  [dim]{edge_id[:8]}…[/dim]"
    )


@graph.command("search")
@click.argument("query")
@click.option("--limit", default=8, show_default=True, help="Max results")
def graph_search(query, limit):
    """Semantic search over knowledge graph nodes."""
    cfg    = load_config()
    client = get_qdrant(cfg)
    vec    = embed(query, cfg)
    try:
        hits = client.query_points(collection_name="kg_nodes", query=vec, limit=limit).points
    except Exception as e:
        console.print(f"[red]Search failed: {e}[/red]")
        return
    if not hits:
        console.print("[yellow]No nodes found.[/yellow]")
        return
    table = Table(title=f'Knowledge Graph — "{query}"', show_lines=True)
    table.add_column("Label",       style="bold")
    table.add_column("Category",    style="cyan",    width=10)
    table.add_column("Domain",      style="magenta", width=10)
    table.add_column("Description", style="dim")
    table.add_column("Score",       justify="right",  width=6)
    for hit in hits:
        p = hit.payload
        table.add_row(
            p.get("label", ""),
            p.get("category", ""),
            p.get("domain", ""),
            p.get("description", "")[:70],
            f"{hit.score:.2f}",
        )
    console.print(table)


@graph.command("show")
@click.argument("label")
def graph_show(label):
    """Show a node and all its edges."""
    cfg    = load_config()
    client = get_qdrant(cfg)
    node   = _kg_find_node(client, label)
    if not node:
        vec  = embed(label, cfg)
        hits = client.query_points(collection_name="kg_nodes", query=vec, limit=1).points
        node = hits[0] if hits else None
    if not node:
        console.print(f"[red]Node not found:[/red] {label}")
        return
    p = node.payload
    console.print(Panel(
        f"[bold]{p.get('label')}[/bold]  [{p.get('category')}]  [dim]{p.get('domain')}[/dim]\n\n"
        f"{p.get('description', '')}\n\n"
        f"[dim]Confidence: {p.get('confidence', 0):.0%}  │  "
        f"Source: {p.get('source', '?')}  │  "
        f"Tags: {', '.join(p.get('tags') or ['—'])}[/dim]",
        border_style="cyan",
    ))
    outgoing, incoming = _kg_get_edges(client, str(node.id))
    if outgoing:
        t = Table(title="Outgoing", show_lines=True, box=None)
        t.add_column("Relation",    style="cyan", width=14)
        t.add_column("Target",      style="bold")
        t.add_column("Description", style="dim")
        t.add_column("W",  justify="right", width=4)
        for e in outgoing:
            t.add_row(e.get("relation",""), e.get("target_label",""),
                      e.get("description","")[:60], f"{e.get('weight',0):.1f}")
        console.print(t)
    if incoming:
        t = Table(title="Incoming", show_lines=True, box=None)
        t.add_column("Source",      style="bold")
        t.add_column("Relation",    style="cyan", width=14)
        t.add_column("Description", style="dim")
        t.add_column("W",  justify="right", width=4)
        for e in incoming:
            t.add_row(e.get("source_label",""), e.get("relation",""),
                      e.get("description","")[:60], f"{e.get('weight',0):.1f}")
        console.print(t)
    if not outgoing and not incoming:
        console.print("[dim]No edges yet — use: ginja graph add-edge[/dim]")


@graph.command("list")
@click.option("--domain",   default=None, type=click.Choice(KG_DOMAINS + ["all"]),    help="Filter by domain")
@click.option("--category", default=None, type=click.Choice(KG_CATEGORIES + ["all"]), help="Filter by category")
@click.option("--limit",    default=50,   show_default=True, help="Max rows")
def graph_list(domain, category, limit):
    """List all knowledge graph nodes."""
    cfg    = load_config()
    client = get_qdrant(cfg)
    from qdrant_client.models import Filter, FieldCondition, MatchValue
    filters = []
    if domain and domain != "all":
        filters.append(FieldCondition(key="domain", match=MatchValue(value=domain)))
    if category and category != "all":
        filters.append(FieldCondition(key="category", match=MatchValue(value=category)))
    try:
        results, _ = client.scroll(
            collection_name="kg_nodes",
            scroll_filter=Filter(must=filters) if filters else None,
            limit=limit,
            with_payload=True,
        )
    except Exception as e:
        console.print(f"[red]Failed: {e}[/red]")
        return
    if not results:
        console.print("[yellow]No nodes found. Run: ginja graph seed[/yellow]")
        return
    table = Table(title=f"Knowledge Graph Nodes ({len(results)})", show_lines=False)
    table.add_column("Label",       style="bold")
    table.add_column("Category",    style="cyan",    width=10)
    table.add_column("Domain",      style="magenta", width=10)
    table.add_column("Conf",        justify="right",  width=5)
    table.add_column("Description", style="dim")
    for r in results:
        p = r.payload
        table.add_row(
            p.get("label", ""),
            p.get("category", ""),
            p.get("domain", ""),
            f"{p.get('confidence', 0):.0%}",
            p.get("description", "")[:60],
        )
    console.print(table)


@graph.command("stats")
def graph_stats():
    """Node/edge counts and domain breakdown."""
    cfg    = load_config()
    client = get_qdrant(cfg)
    from qdrant_client.models import Filter, FieldCondition, MatchValue
    try:
        node_count = client.count("kg_nodes").count
        edge_count = client.count("kg_edges").count
    except Exception as e:
        console.print(f"[red]Failed: {e}[/red]")
        return
    console.print(Panel(
        f"[bold]Nodes:[/bold] {node_count}   [bold]Edges:[/bold] {edge_count}",
        title="[cyan]Knowledge Graph[/cyan]", border_style="cyan",
    ))
    if node_count == 0:
        console.print("[dim]Run: ginja graph seed  — to populate from memory[/dim]")
        return
    table = Table(title="By Domain", show_lines=False)
    table.add_column("Domain")
    table.add_column("Nodes", justify="right")
    for domain in KG_DOMAINS:
        try:
            count = client.count(
                "kg_nodes",
                count_filter=Filter(must=[FieldCondition(key="domain", match=MatchValue(value=domain))]),
            ).count
        except Exception:
            count = 0
        if count:
            table.add_row(domain, str(count))
    console.print(table)


@graph.command("seed")
@click.option("--limit",   default=30,   show_default=True, help="Max memory entries to scan")
@click.option("--dry-run", is_flag=True, help="Show extracted graph without writing to Qdrant")
def graph_seed(limit, dry_run):
    """Populate the knowledge graph by extracting entities and relationships from memory."""
    cfg    = load_config()
    sm     = _load_self_model()
    cycle  = sm.get("evolution_count", 0)
    console.print(Panel("[bold cyan]Knowledge Graph — Seeding from memory[/bold cyan]"))
    try:
        client       = get_qdrant(cfg)
        mem_entries  = scroll_recent(client, "memories",      days=90)
        conv_entries = scroll_recent(client, "conversations", days=30)
    except Exception as e:
        console.print(f"[red]Cannot reach Qdrant: {e}[/red]")
        return
    entries = (mem_entries + conv_entries)[:limit]
    if not entries:
        console.print("[yellow]No memory entries found.[/yellow]")
        return
    corpus = "\n\n".join(e.get("text", "")[:300] for e in entries if e.get("text"))
    prompt = (
        "You are extracting a semantic knowledge graph from an AI assistant's memory.\n\n"
        "The assistant is a homelab AI agent focused on FOSS tools, AI memory architecture, "
        "automation, and self-evolution.\n\n"
        f"MEMORY CORPUS:\n{corpus}\n\n"
        "Extract up to 12 NODES and up to 15 EDGES.\n\n"
        f"Node categories: {KG_CATEGORIES}\n"
        f"Node domains: {KG_DOMAINS}\n"
        f"Edge relations: {KG_RELATIONS}\n\n"
        "Rules:\n"
        "- Only extract entities actually present in the corpus\n"
        "- Descriptions must be specific, max 1 sentence\n"
        "- Confidence 0.9 if mentioned multiple times, 0.7 if mentioned once\n"
        "- Edge descriptions should be full sentences explaining the relationship\n\n"
        'Return ONLY valid JSON:\n'
        '{\n'
        '  "nodes": [\n'
        '    {"label": "Qdrant", "category": "tool", "domain": "ai",\n'
        '     "description": "Vector database used for semantic memory storage.",\n'
        '     "confidence": 0.9, "tags": ["vector", "database", "search"]}\n'
        '  ],\n'
        '  "edges": [\n'
        '    {"from": "Qdrant", "to": "Semantic Search", "relation": "enables",\n'
        '     "description": "Qdrant enables semantic search over stored memories.", "weight": 0.9}\n'
        '  ]\n'
        '}'
    )
    console.print(f"[dim]Scanning {len(entries)} memory entries…[/dim]")
    with console.status("[dim]Extracting knowledge graph…[/dim]"):
        try:
            result = _call_oracle_json(prompt, cfg)
        except Exception as e:
            console.print(f"[red]Extraction failed: {e}[/red]")
            return
    nodes = result.get("nodes", [])
    edges = result.get("edges", [])
    if not nodes:
        console.print("[yellow]No nodes extracted — try running more evolution cycles first.[/yellow]")
        return
    console.print(f"\n[bold]Extracted:[/bold] {len(nodes)} nodes, {len(edges)} edges\n")
    node_id_map: dict = {}
    for n in nodes:
        label = n.get("label", "").strip()
        if not label:
            continue
        console.print(
            f"  [cyan]node[/cyan]  [bold]{label}[/bold]  "
            f"[{n.get('category')}]  [dim]{n.get('description','')[:60]}[/dim]"
        )
        if not dry_run:
            node_id = _kg_upsert_node(
                client, cfg,
                label=label,
                category=n.get("category", "concept"),
                domain=n.get("domain", "general"),
                description=n.get("description", ""),
                confidence=float(n.get("confidence", 0.8)),
                tags=n.get("tags", []),
                source="seed",
                cycle=cycle,
            )
            node_id_map[label] = node_id
    console.print()
    skipped = 0
    for e in edges:
        src_label = e.get("from", "").strip()
        tgt_label = e.get("to", "").strip()
        relation  = e.get("relation", "related_to")
        if relation not in KG_RELATIONS:
            relation = "related_to"
        console.print(
            f"  [magenta]edge[/magenta]  [bold]{src_label}[/bold] "
            f"[cyan]{relation}[/cyan] [bold]{tgt_label}[/bold]"
        )
        if not dry_run:
            src_id = node_id_map.get(src_label)
            tgt_id = node_id_map.get(tgt_label)
            if not src_id:
                found  = _kg_find_node(client, src_label)
                src_id = str(found.id) if found else None
            if not tgt_id:
                found  = _kg_find_node(client, tgt_label)
                tgt_id = str(found.id) if found else None
            if src_id and tgt_id:
                _kg_upsert_edge(
                    client, cfg,
                    source_id=src_id, target_id=tgt_id,
                    source_label=src_label, target_label=tgt_label,
                    relation=relation,
                    description=e.get("description", f"{src_label} {relation} {tgt_label}"),
                    weight=float(e.get("weight", 0.8)),
                    source="seed", cycle=cycle,
                )
            else:
                console.print(f"    [dim]skipped — node not in graph[/dim]")
                skipped += 1
    if dry_run:
        console.print("\n[dim]Dry run — nothing written. Remove --dry-run to commit.[/dim]")
    else:
        written = len(edges) - skipped
        console.print(
            f"\n[green]✓[/green] {len(node_id_map)} nodes, {written} edges written to Qdrant.\n"
            "[dim]Explore: ginja graph list  │  ginja graph search <query>  │  ginja graph show <label>[/dim]"
        )


@graph.command("enrich")
@click.option("--days", default=7, show_default=True, help="Enrich from memories in the last N days")
def graph_enrich(days):
    """Batch-enrich the knowledge graph from recent memories."""
    cfg   = load_config()
    model = _load_self_model()
    cycle = model.get("evolution_count", 0)
    try:
        client = get_qdrant(cfg)
        entries = scroll_recent(client, "memories", days=days)
    except Exception as e:
        console.print(f"[red]Could not load memories: {e}[/red]")
        return

    SIGNAL_SOURCES = {"evolution", "learn_oracle", "wonder", "user", "remember", "evolve_research"}
    entries = [e for e in entries if e.get("source", "") in SIGNAL_SOURCES]
    if not entries:
        console.print(f"[yellow]No signal memories in the last {days} days.[/yellow]")
        return

    console.print(f"[dim]Enriching graph from {len(entries)} memories (last {days} days)…[/dim]")
    for i, entry in enumerate(entries, 1):
        text = entry.get("text", "")
        if len(text) < 50:
            continue
        try:
            _graph_enrich_text(text, cycle, cfg)
            if i % 5 == 0:
                console.print(f"  [dim]processed {i}/{len(entries)}…[/dim]")
        except Exception:
            pass

    try:
        kg_client = get_qdrant(cfg)
        n_nodes = kg_client.count("kg_nodes").count
        n_edges = kg_client.count("kg_edges").count
        console.print(f"[bold green]✓ Enrichment complete[/bold green] — graph now has {n_nodes} nodes, {n_edges} edges.")
    except Exception:
        console.print("[green]✓ Enrichment complete.[/green]")


# ── Operator interface ─────────────────────────────────────────────────────────

@cli.group()
def intent():
    """Operator directives — shape ginja's evolution from the god seat."""
    pass


@intent.command("set")
@click.argument("directive", nargs=-1, required=True)
def intent_set(directive):
    """Set the operator directive. Ginja's evolution will align with this until cleared."""
    text = " ".join(directive)
    data = {
        "directive": text,
        "set_at": datetime.now(timezone.utc).isoformat(),
    }
    OPERATOR_INTENT_FILE.write_text(json.dumps(data, indent=2))
    console.print(Panel(
        f"[bold green]Operator directive set[/bold green]\n\n\"{text}\"\n\n"
        "[dim]This will be injected as a god-tier constraint into every evolve cycle.[/dim]"
    ))


@intent.command("show")
def intent_show():
    """Show the current operator directive."""
    intent = _load_operator_intent()
    if not intent or not intent.get("directive"):
        console.print("[dim]No operator directive set. Ginja is evolving autonomously.[/dim]")
        console.print("[dim]Set one with: ginja intent set \"your directive here\"[/dim]")
        return
    set_at = intent.get("set_at", "")[:19].replace("T", " ")
    console.print(Panel(
        f"[bold cyan]Current operator directive[/bold cyan]\n\n"
        f"\"{intent['directive']}\"\n\n"
        f"[dim]Set: {set_at} UTC[/dim]"
    ))


@intent.command("clear")
def intent_clear():
    """Clear the operator directive. Ginja resumes autonomous goal selection."""
    if not OPERATOR_INTENT_FILE.exists():
        console.print("[dim]No directive to clear.[/dim]")
        return
    OPERATOR_INTENT_FILE.unlink()
    console.print("[green]✓[/green] Operator directive cleared. Ginja evolves autonomously.")


@cli.command()
@click.argument("reaction", nargs=-1, required=True)
def react(reaction):
    """Send feedback to ginja — stored as operator memory weighted above self-reflection."""
    cfg = load_config()
    text = " ".join(reaction)
    try:
        client = get_qdrant(cfg)
        vec = embed(text, cfg)
        existing = {c.name for c in client.get_collections().collections}
        if "operator_feedback" not in existing:
            from qdrant_client.models import Distance, VectorParams
            client.create_collection(
                collection_name="operator_feedback",
                vectors_config=VectorParams(size=len(vec), distance=Distance.COSINE),
            )
        from qdrant_client.models import PointStruct
        client.upsert(
            collection_name="operator_feedback",
            points=[PointStruct(
                id=str(uuid.uuid4()),
                vector=vec,
                payload={
                    "text": text,
                    "source": "operator",
                    "created": datetime.now(timezone.utc).isoformat(),
                },
            )],
        )
        console.print(f"[green]✓[/green] Reaction stored: \"{text}\"")
        console.print("[dim]This will influence ginja's next evolution cycle.[/dim]")
    except Exception as e:
        console.print(f"[red]Error storing reaction: {e}[/red]")
        console.print("[dim]Is Qdrant running? Check with: ginja status[/dim]")


# ── Goal Stack ─────────────────────────────────────────────────────────────────

@cli.group()
def goals():
    """Three-tier goal hierarchy — north star / medium-term / queue."""
    pass


@goals.command("show")
def goals_show():
    """Show all goals across the three tiers."""
    goals = _load_goals()
    cycle_n = 0
    try:
        sm = json.loads((GINJA_DIR / "self-model.json").read_text())
        cycle_n = sm.get("evolution_count", 0)
    except Exception:
        pass

    console.print(Rule("[bold]Goal Hierarchy[/bold]"))

    # North star
    ns = goals.get("north_star", {})
    ns_text = ns.get("goal", "[dim]not set[/dim]") if isinstance(ns, dict) else str(ns)
    ns_by = ns.get("set_at", "?") if isinstance(ns, dict) else "?"
    console.print(Panel(
        f"[bold white]{ns_text}[/bold white]\n[dim]set {ns_by}[/dim]",
        title="[bold yellow]★  North Star[/bold yellow]",
        border_style="yellow",
    ))

    # Medium-term
    medium = goals.get("medium", [])
    if medium:
        mt = Table(title="Medium-Term Goals", box=None, show_header=True)
        mt.add_column("#", style="dim", width=3)
        mt.add_column("Goal", style="white")
        mt.add_column("Source", style="magenta", width=10)
        mt.add_column("Cycles left", justify="right", width=12)
        for i, g in enumerate(medium):
            left = max(0, g.get("due_by_cycle", cycle_n) - cycle_n)
            color = "green" if left > 6 else "yellow" if left > 2 else "red"
            mt.add_row(str(i + 1), g["goal"], g.get("source", "auto"),
                       f"[{color}]{left}[/{color}]")
        console.print(mt)
    else:
        console.print("[dim]No medium-term goals — will auto-promote from queue on next evolve cycle.[/dim]")

    # Queue
    console.print()
    queue = goals.get("queue", [])
    if queue:
        qt = Table(title="Queue (next in line)", box=None, show_header=True)
        qt.add_column("#", style="dim", width=3)
        qt.add_column("Goal", style="white")
        qt.add_column("Source", style="magenta", width=10)
        qt.add_column("Added", style="dim", width=12)
        for i, g in enumerate(queue):
            qt.add_row(str(i + 1), g["goal"], g.get("source", "auto"),
                       g.get("added_at", "")[:10])
        console.print(qt)
    else:
        console.print("[dim]Queue is empty.[/dim]")

    console.print()
    console.print("[dim]ginja goals push \"...\", goals set-north-star \"...\", goals promote <n>, goals complete medium <n>[/dim]")


@goals.command("list")
def goals_list():
    """Alias for 'goals show'."""
    ctx = click.get_current_context()
    ctx.invoke(goals_show)


@goals.command("set-north-star")
@click.argument("goal", nargs=-1, required=True)
def goals_set_north_star(goal):
    """Set the long-term north star goal."""
    text = " ".join(goal)
    g = _load_goals()
    g["north_star"] = {
        "goal": text,
        "source": "operator",
        "set_at": datetime.now(timezone.utc).date().isoformat(),
    }
    _save_goals(g)
    console.print(f"[yellow]★[/yellow] North star set: \"{text}\"")


@goals.command("push")
@click.argument("goal", nargs=-1, required=True)
@click.option("--source", default="manual", help="Source label (manual, wonder, operator…)")
@click.option("--medium", "to_medium", is_flag=True, help="Push directly to medium-term instead of queue")
def goals_push(goal, source, to_medium):
    """Add a goal to the queue (or --medium to add directly to medium-term)."""
    text = " ".join(goal)
    g = _load_goals()
    entry = {
        "goal": text,
        "source": source,
        "added_at": datetime.now(timezone.utc).isoformat(),
    }
    if to_medium:
        sm_cycle = 0
        try:
            sm = json.loads((GINJA_DIR / "self-model.json").read_text())
            sm_cycle = sm.get("evolution_count", 0)
        except Exception:
            pass
        entry["promoted_at_cycle"] = sm_cycle
        entry["due_by_cycle"] = sm_cycle + MEDIUM_GOAL_LIFESPAN
        g["medium"].insert(0, entry)
        _save_goals(g)
        console.print(f"[green]✓[/green] Added to medium-term: \"{text}\"")
    else:
        g["queue"].insert(0, entry)
        _save_goals(g)
        console.print(f"[green]✓[/green] Pushed to queue: \"{text}\"")
        console.print(f"[dim]Queue now has {len(g['queue'])} goal(s).[/dim]")


@goals.command("promote")
@click.argument("index", type=int)
def goals_promote(index):
    """Promote queue item #N directly to medium-term (1-based index)."""
    g = _load_goals()
    queue = g.get("queue", [])
    if not queue:
        console.print("[dim]Queue is empty.[/dim]")
        return
    if index < 1 or index > len(queue):
        console.print(f"[red]Invalid index — queue has {len(queue)} item(s).[/red]")
        return
    item = queue.pop(index - 1)
    sm_cycle = 0
    try:
        sm = json.loads((GINJA_DIR / "self-model.json").read_text())
        sm_cycle = sm.get("evolution_count", 0)
    except Exception:
        pass
    item["promoted_at_cycle"] = sm_cycle
    item["due_by_cycle"] = sm_cycle + MEDIUM_GOAL_LIFESPAN
    g["queue"] = queue
    g["medium"].append(item)
    _save_goals(g)
    console.print(f"[green]✓[/green] Promoted to medium-term: \"{item['goal']}\"")


@goals.command("complete")
@click.argument("tier", type=click.Choice(["medium", "queue"]))
@click.argument("index", type=int)
def goals_complete(tier, index):
    """Mark a goal as complete and remove it (1-based index)."""
    g = _load_goals()
    items = g.get(tier, [])
    if not items:
        console.print(f"[dim]{tier} is empty.[/dim]")
        return
    if index < 1 or index > len(items):
        console.print(f"[red]Invalid index — {tier} has {len(items)} item(s).[/red]")
        return
    removed = items.pop(index - 1)
    g[tier] = items
    _save_goals(g)
    console.print(f"[green]✓[/green] Completed: \"{removed['goal']}\"")


@goals.command("pop")
def goals_pop():
    """Remove the top goal from the queue."""
    stack = _load_goal_stack()
    if not stack:
        console.print("[dim]Goal queue is already empty.[/dim]")
        return
    removed = stack.pop(0)
    _save_goal_stack(stack)
    console.print(f"[green]✓[/green] Popped: \"{removed['goal']}\"")
    if stack:
        console.print(f"[dim]Next in queue: {stack[0]['goal']}[/dim]")


@goals.command("clear")
@click.option("--tier", type=click.Choice(["queue", "medium", "all"]), default="queue",
              show_default=True, help="Which tier to clear")
def goals_clear(tier):
    """Clear goals from a tier (default: queue)."""
    g = _load_goals()
    if tier == "all":
        g["queue"] = []
        g["medium"] = []
        _save_goals(g)
        console.print("[green]✓[/green] All goals cleared (north star preserved).")
    else:
        g[tier] = []
        _save_goals(g)
        console.print(f"[green]✓[/green] {tier.capitalize()} cleared.")


# ── Memory Consolidation ────────────────────────────────────────────────────────

@cli.command()
@click.option("--days", default=7, show_default=True,
              help="Consolidate perception entries older than N days")
@click.option("--force", is_flag=True, help="Run even if consolidation is recent")
def consolidate(days, force):
    """Compress episodic perception logs into semantic memory (run during idle time)."""
    cfg = load_config()

    if not force and LAST_CONSOLIDATION.exists():
        try:
            last_ts = datetime.fromisoformat(LAST_CONSOLIDATION.read_text().strip())
            hours_ago = (datetime.now(timezone.utc) - last_ts).total_seconds() / 3600
            if hours_ago < 20:
                console.print(f"[dim]Consolidation ran {hours_ago:.1f}h ago — skipping (use --force to override)[/dim]")
                return
        except Exception:
            pass

    console.print(Panel("[bold cyan]ginja consolidate[/bold cyan] — compressing episodic → semantic"))

    cutoff = datetime.now(timezone.utc) - timedelta(days=days)

    # ── 1. Perception log ──────────────────────────────────────────────────────
    perception_entries = []
    if PERCEPTION_LOG.exists():
        for line in PERCEPTION_LOG.read_text().splitlines():
            try:
                entry = json.loads(line)
                ts_str = entry.get("ts", "")
                if ts_str:
                    ts = datetime.fromisoformat(ts_str)
                    if ts < cutoff:
                        perception_entries.append(entry)
            except Exception:
                pass

    if perception_entries:
        # Group by day
        by_day: dict = {}
        for e in perception_entries:
            day = e.get("ts", "")[:10]
            by_day.setdefault(day, []).append(e.get("summary", ""))

        stored = 0
        for day, summaries in sorted(by_day.items()):
            combined = " | ".join(summaries[:12])
            summary_prompt = (
                f"Summarize this homelab system state across {len(summaries)} readings on {day}:\n\n"
                f"{combined}\n\n"
                "Write a 2-3 sentence factual summary of: system health patterns, load trends, "
                "notable events. Be specific."
            )
            with console.status(f"[cyan]Summarizing {day}…[/cyan]"):
                summary = ollama_complete(summary_prompt, cfg["fast_model"], cfg)
            if summary:
                try:
                    store_memory(
                        f"Homelab daily summary ({day}):\n{summary}",
                        cfg, collection="memories", source="consolidation",
                        dedup_threshold=0.88,
                    )
                    stored += 1
                    console.print(f"  [green]✓[/green] {day} — {len(summaries)} readings → 1 memory")
                except Exception as e:
                    console.print(f"  [yellow]⚠[/yellow] {day}: {e}")

        console.print(f"\n[bold]Perception:[/bold] {len(perception_entries)} entries → {stored} day-summaries")
    else:
        console.print(f"[dim]Perception: no entries older than {days} days[/dim]")

    # ── 2. Evolution reflections (avoid re-consolidating already-stored ones) ──
    evo_entries = []
    if EVOLUTION_LOG.exists():
        sections = [s.strip() for s in EVOLUTION_LOG.read_text().split("=" * 60) if s.strip()]
        for sec in sections:
            # Parse date from header line
            for line in sec.splitlines():
                if line.startswith("[") and "] Cycle #" in line:
                    try:
                        date_str = line[1:line.index("]")]
                        ts = datetime.strptime(date_str, "%Y-%m-%d %H:%M")
                        ts = ts.replace(tzinfo=timezone.utc)
                        if ts < cutoff:
                            evo_entries.append((ts, sec))
                    except Exception:
                        pass
                    break

    if evo_entries:
        # Batch older evolution entries into a single consolidated summary
        combined = "\n---\n".join(text for _, text in evo_entries[:20])
        batch_prompt = (
            f"Summarize {len(evo_entries)} ginja evolution cycles (all older than {days} days):\n\n"
            f"{combined[:3000]}\n\n"
            "Write a compact 3-4 sentence summary: major themes, direction changes, "
            "key techniques learned. This becomes a long-term semantic memory."
        )
        with console.status(f"[cyan]Consolidating {len(evo_entries)} old evolution cycles…[/cyan]"):
            evo_summary = ollama_complete(batch_prompt, cfg["primary_model"], cfg)
        if evo_summary:
            try:
                store_memory(
                    f"Evolution history consolidation ({len(evo_entries)} cycles, pre-{days}d):\n{evo_summary}",
                    cfg, collection="memories", source="consolidation",
                    dedup_threshold=0.88,
                )
                console.print(f"[bold]Evolution:[/bold] {len(evo_entries)} cycles → 1 consolidated memory")
            except Exception as e:
                console.print(f"[yellow]⚠[/yellow] Evolution consolidation: {e}")
    else:
        console.print(f"[dim]Evolution: no cycles older than {days} days[/dim]")

    LAST_CONSOLIDATION.write_text(datetime.now(timezone.utc).isoformat())
    console.print(f"\n[bold green]✓ Consolidation complete[/bold green]")
    console.print("[dim]Run 'ginja memories' to see updated counts[/dim]")


# ── Resources ─────────────────────────────────────────────────────────────────

@cli.command()
@click.option("--evict", "evict_model", default=None, metavar="MODEL",
              help="Unload a specific model from Ollama VRAM")
@click.option("--evict-all", is_flag=True, help="Unload all models currently in Ollama VRAM")
def resources(evict_model, evict_all):
    """Show inference resource state — VRAM, RAM, loaded models, and lock.

    Use --evict <model> to unload a specific model, or --evict-all to clear VRAM.
    """
    cfg = load_config()
    ollama_url = cfg.get("ollama_url", "http://localhost:11434")

    if evict_model:
        console.print(f"Evicting [bold]{evict_model}[/bold] from VRAM…")
        ok = _rm.evict(evict_model, ollama_url)
        console.print("[green]✓ evicted[/green]" if ok else "[red]✗ evict failed (model may not be loaded)[/red]")
        return

    if evict_all:
        loaded = _rm.loaded_models(ollama_url)
        if not loaded:
            console.print("[dim]No models currently loaded — nothing to evict[/dim]")
            return
        for m in loaded:
            name = m.get("name", "?")
            ok = _rm.evict(name, ollama_url)
            status = "[green]✓[/green]" if ok else "[red]✗[/red]"
            console.print(f"  {status} {name}")
        return

    st = _rm.status()

    # ── Lock status ────────────────────────────────────────────────────────────
    lock = st["lock_info"]
    if lock:
        since = lock.get("since", "")
        try:
            elapsed = int((datetime.now(timezone.utc) - datetime.fromisoformat(since)).total_seconds())
            elapsed_str = f"{elapsed}s elapsed"
        except Exception:
            elapsed_str = since or "?"
        lock_line = (
            f"[red]LOCKED[/red]  model=[bold]{lock.get('model', '?')}[/bold]"
            f"  pid={lock.get('pid', '?')}  ({elapsed_str})"
        )
    else:
        lock_line = "[green]FREE[/green]"
    console.print(Panel(f"Inference slot: {lock_line}", title="[bold]Resource Manager[/bold]"))

    # ── VRAM ──────────────────────────────────────────────────────────────────
    vu, vt, vf = st["vram_used_mb"], st["vram_total_mb"], st["vram_free_mb"]
    if vt > 0:
        pct = vu / vt
        bar = "█" * int(pct * 20) + "░" * (20 - int(pct * 20))
        color = "green" if pct < 0.6 else "yellow" if pct < 0.85 else "red"
        console.print(f"VRAM  [{color}]{bar}[/{color}]  {vu:,}/{vt:,} MB  ({pct:.0%} used, {vf:,} MB free)")
    else:
        console.print("VRAM  [dim]nvidia-smi unavailable — assuming 4,000 MB free[/dim]")

    # ── RAM ───────────────────────────────────────────────────────────────────
    rt, ra = st["ram_total_mb"], st["ram_avail_mb"]
    if rt > 0:
        ru = rt - ra
        pct = ru / rt
        bar = "█" * int(pct * 20) + "░" * (20 - int(pct * 20))
        color = "green" if pct < 0.7 else "yellow" if pct < 0.9 else "red"
        console.print(f"RAM   [{color}]{bar}[/{color}]  {ru:,}/{rt:,} MB  ({pct:.0%} used, {ra:,} MB avail)")

    # ── Load ──────────────────────────────────────────────────────────────────
    load = st["load1"]
    load_color = "green" if load < 3 else "yellow" if load < 5 else "red"
    console.print(f"Load  [{load_color}]{load:.1f}[/{load_color}]")

    # ── Currently loaded in Ollama ────────────────────────────────────────────
    console.print()
    loaded = _rm.loaded_models(ollama_url)
    if loaded:
        lt = Table(title="Loaded in Ollama", box=None, show_header=True)
        lt.add_column("Model", style="bold")
        lt.add_column("VRAM", justify="right")
        lt.add_column("Expires in")
        for m in loaded:
            vram_mb = m.get("size_vram", 0) // (1024 * 1024)
            expires = m.get("expires_at", "")
            try:
                exp_dt = datetime.fromisoformat(expires.replace("Z", "+00:00"))
                secs = int((exp_dt - datetime.now(timezone.utc)).total_seconds())
                exp_str = f"{secs}s" if secs > 0 else "[dim]expired[/dim]"
            except Exception:
                exp_str = expires[:19] if expires else "?"
            lt.add_row(m.get("name", "?"), f"{vram_mb:,} MB", exp_str)
        console.print(lt)
    else:
        console.print("[dim]No models currently loaded in Ollama[/dim]")

    # ── Model budget ──────────────────────────────────────────────────────────
    console.print()
    table = Table(title="Model VRAM Budget", box=None, show_header=True)
    table.add_column("Model", style="bold")
    table.add_column("Est. VRAM", justify="right")
    table.add_column("Fits?", justify="center")
    table.add_column("Role", style="dim")

    role_map = {
        cfg.get("primary_model", ""):  "primary",
        cfg.get("code_model", ""):     "code",
        cfg.get("fast_model", ""):     "fast",
        cfg.get("quality_model", ""):  "quality",
        cfg.get("embed_model", ""):    "embed",
    }
    seen: set = set()
    for model_name in [
        cfg.get("primary_model"), cfg.get("code_model"),
        cfg.get("fast_model"),    cfg.get("quality_model"),
        cfg.get("embed_model"),
    ]:
        if not model_name or model_name in seen:
            continue
        seen.add(model_name)
        needed = _rm.model_vram_mb(model_name)
        fits = vf >= needed + 300 if vt > 0 else True
        fits_str = "[green]✓[/green]" if fits else "[red]✗[/red]"
        table.add_row(model_name, f"{needed:,} MB", fits_str, role_map.get(model_name, ""))

    console.print(table)
    console.print()
    console.print(f"[dim]Lock: {INFERENCE_LOCK}[/dim]")
    console.print("[dim]Hint: ginja resources --evict <model>  |  --evict-all[/dim]")


if __name__ == "__main__":
    cli()
