@corpus.command("score")
def corpus_score():
    """Show how many memories match each corpus topic."""
    cfg = load_config()
    sm  = _load_self_model()
    _require_phase(sm, "mature", "ginja corpus score")

    manifest = _load_corpus_manifest()
    topics   = manifest.get("topics", [])
    if not topics:
        console.print(f"[yellow]No topics in {CORPUS_MANIFEST}[/yellow]")
        return

    table = Table(title="Corpus Coverage", show_lines=True)
    table.add_column("Topic")
    table.add_column("Hits", justify="right")
    for t in sorted(topics, key=lambda x: x.get("priority", 99)):
        query = t["search_queries"][0] if t.get("search_queries") else t["label"]
        try:
            hits  = search_memory(query, cfg, top_k=10)
            count = len(hits)
        except Exception:
            count = 0
        table.add_row(t["label"], str(count))
    console.print(table)


# ── Watch helpers ──────────────────────────────────────────────────────────────

import math


NEURAL_CHARS = " .·○◦◉●◦○·."
WAVE_CHARS   = " ▁▂▃▄▅▆▇█"
_PORTRAIT_FONTS = {"calvin_s", "future", "mini", "digital", "threepoint", "cybersmall", "konto", "straight", "pepper"}

def _neural_field(frame: int, activity: float, style: str = "active",
                  width: int = 34, height: int = 7, chars: str = None) -> str:
    char_set = chars if chars and len(chars) >= 3 else NEURAL_CHARS
    p = NEURAL_STYLES.get(style, NEURAL_STYLES["active"])
    activity = max(p["act_min"], min(1.0, activity))
    ts, sf = p["ts"], p["sf"]
    lines = []
    for y in range(height):
        row = []
        for x in range(width):
            w1 = math.sin(frame * ts       + x * sf        + y * (sf * 1.55))
            w2 = math.sin(frame * ts * 0.7 + x * sf * 0.67 - y * (sf * 1.1) + 1.5)
            combined = (w1 + w2) * 0.5
            scaled = combined * activity + activity * 0.3 + 0.15
            idx = int(scaled * (len(char_set) - 1))
            row.append(char_set[max(0, min(idx, len(char_set) - 1))])
        lines.append("".join(row))
    return "\n".join(lines)

def _render_portrait(self_model: dict, width: int = 34) -> str:
    """Render the brain's self-portrait using pyfiglet for pixel-perfect spacing."""
    try:
        import pyfiglet
        font    = self_model.get("portrait_font", "calvin_s")
        word    = self_model.get("portrait_word", "ginja")[:10]
        border  = self_model.get("portrait_border", "◉ · ○ · ◉")
        tagline = self_model.get("portrait_tagline", "mind · memory")
        if font not in _PORTRAIT_FONTS:
            font = "calvin_s"
        try:
            art = pyfiglet.figlet_format(word, font=font, width=width).rstrip()
        except Exception:
            art = pyfiglet.figlet_format(word, font="calvin_s", width=width).rstrip()
        art_w = max((len(l) for l in art.splitlines()), default=width)
        return f"{border[:art_w].center(art_w)}\n{art}\n{tagline[:art_w].center(art_w)}"
    except Exception:
        return self_model.get("portrait_border", "◉ · ○ · ◉")

def _waveform(history: list, width: int = 34) -> str:
    h = (history[-width:] if len(history) >= width
         else [0.0] * (width - len(history)) + history)
    return "".join(WAVE_CHARS[min(8, int(v * 8))] for v in h)

def _gpu_stats() -> tuple:
    try:
        r = subprocess.run(
            ["nvidia-smi",
             "--query-gpu=utilization.gpu,memory.used,memory.total",
             "--format=csv,noheader,nounits"],
            capture_output=True, text=True, timeout=2,
        )
        parts = [x.strip() for x in r.stdout.strip().split(",")]
        return int(parts[0]), int(parts[1]), int(parts[2])
    except Exception:
        return 0, 0, 4096

def _last_thought(cfg: dict) -> str:
    try:
        client = get_qdrant(cfg)
        results, _ = client.scroll("conversations", limit=500, with_payload=True)
        if not results:
            return "—"
        latest = max(results, key=lambda r: r.payload.get("created", ""))
        text = latest.payload.get("text", "")
        return text[:80].replace("\n", " ")
    except Exception:
        return "—"

def _last_evolution() -> str:
    if not EVOLUTION_LOG.exists():
        return "never evolved"
    lines = EVOLUTION_LOG.read_text().splitlines()
    for line in reversed(lines):
        if line.startswith("[") and "Evolution cycle" in line:
            return line.strip("[]").replace(" Evolution cycle", "")
    return "never evolved"

def _make_watch_layout(frame, gpu_pct, vram_used, vram_total,
                        counts, last_thought, last_evo, gpu_history, cfg, self_model):
    activity = gpu_pct / 100.0
    theme    = COLOR_THEMES.get(self_model.get("color_theme", "cyan"), COLOR_THEMES["cyan"])

    mood = self_model.get("mood", "").lower()
    if 'anxious' in mood or 'stressed' in mood:
        theme = COLOR_THEMES.get("red", theme)
    elif 'focused' in mood or 'learning' in mood:
        theme = COLOR_THEMES.get("yellow", theme)
    elif 'calm' in mood or 'serene' in mood:
        theme = COLOR_THEMES.get("blue", theme)
    elif 'creative' in mood or 'curious' in mood:
        theme = COLOR_THEMES.get("magenta", theme)
    elif activity > 0.85:
        theme = COLOR_THEMES.get("red", theme)
    elif activity < 0.15:
        theme = COLOR_THEMES.get("blue", theme)

    style    = self_model.get("neural_style", "active")
    mantras  = self_model.get("mantras", ["Learn. Adapt. Evolve."])
    mantra   = mantras[frame // 40 % len(mantras)] if mantras else ""
    evo_n    = self_model.get("evolution_count", 0)

    # ── Header — brain's own banner ────────────────────────────────────────────
    total_vecs = sum(counts.values())
    uptime = datetime.now().strftime("%H:%M")
    banner = self_model.get("ascii_banner", "◉ ginja-brain ◉")
    header_text = Text()
    header_text.append(f"{banner}", style=f"bold {theme['header']}")
    header_text.append(f"  ·  {uptime}  ·  ", style="dim")
    header_text.append(f"{total_vecs} vectors", style=theme["neural"])
    header_text.append(f"  ·  evolved {evo_n}×", style="dim")
    if _load_suggestions():
        header_text.append("  ✦", style="bold cyan")

    # ── Self-portrait — brain-authored, pyfiglet-rendered ─────────────────────
    portrait_str = _render_portrait(self_model)
    portrait_style = theme["neural"] if activity > 0.15 else f"dim {theme['neural']}"

    # ── Neural field — brain's chosen style and character palette ─────────────
    neural_chars = self_model.get("neural_chars", NEURAL_CHARS)
    field = _neural_field(frame, activity, style=style, chars=neural_chars)
    wave  = _waveform(gpu_history)
    total_collections = len(counts)
    active_collections = sum(1 for v in counts.values() if v > 0)
    if total_collections > 0:
        ratio = active_collections / total_collections
        bar_len = int(ratio * 40)
        q_wave = "▶" * bar_len + "·" * (40 - bar_len)
        wave += f"\n{q_wave} {active_collections}/{total_collections}"
    field_style = f"dim {theme['neural']}"
    neural_content = Text()
    neural_content.append(portrait_str + "\n\n", style=portrait_style)
    neural_content.append(field + "\n\n" + wave, style=field_style)

    # ── Vitals ─────────────────────────────────────────────────────────────────
    gpu_bar  = "█" * int(gpu_pct / 10) + "░" * (10 - int(gpu_pct / 10))
    vram_pct = int(vram_used / vram_total * 10) if vram_total else 0
    vram_bar = "█" * vram_pct + "░" * (10 - vram_pct)

    vitals = Table.grid(padding=(0, 1))
    vitals.add_column(style="dim", width=8)
    vitals.add_column(style="white")
    vitals.add_row("GPU",   f"[{'green' if gpu_pct < 60 else 'yellow'}]{gpu_bar}[/]  {gpu_pct}%")
    vitals.add_row("VRAM",  f"[{theme['neural']}]{vram_bar}[/]  {vram_used/1024:.1f}/{vram_total/1024:.1f}GB")
    vitals.add_row("QDRANT", f"{len(counts)} collections, {total_vecs} documents")
    if total_vecs < 1000:
        q_mem_str = f"{total_vecs} vectors"
    elif total_vecs < 1_000_000:
        q_mem_str = f"{total_vecs/1000:.1f}K vectors"
    else:
        q_mem_str = f"{total_vecs/1_000_000:.2f}M vectors"
    vitals.add_row("Q-MEM", q_mem_str)
    q_capacity = cfg.get("qdrant_vector_capacity", 2_000_000)
    if q_capacity > 0:
        q_pct = int(total_vecs / q_capacity * 100)
        q_bar = "█" * int(q_pct / 10) + "░" * (10 - int(q_pct / 10))
        q_color = "green" if q_pct < 60 else "yellow" if q_pct < 85 else "red"
        vitals.add_row("Q-CAP", f"[{q_color}]{q_bar}[/]  {q_pct}%")
    if total_vecs > 0:
        bar_width = 10
        bar_str = ""
        bar_colors = [theme['mem'], theme['neural'], theme['header'], "cyan", "magenta", "yellow"]
        sorted_collections = sorted(counts.items())
        last_pos = 0
        cumulative_count = 0
        for i, (name, count) in enumerate(sorted_collections):
            cumulative_count += count
            current_pos = round(cumulative_count * bar_width / total_vecs)
            segment_len = current_pos - last_pos
            if segment_len > 0:
                color = bar_colors[i % len(bar_colors)]
                bar_str += f"[{color}]" + "█" * segment_len + "[/]"
            last_pos = current_pos
        current_len = bar_str.count('█')
        if current_len < bar_width:
            bar_str += '░' * (bar_width - current_len)
        vitals.add_row("Q-COMP", f"{bar_str}  [dim]composition[/]")
    conversation_count = counts.get("conversations", 0)
    if conversation_count > 0:
        ratio = total_vecs / conversation_count
        vitals.add_row("Q-RATIO", f"{ratio:.1f} vecs/convo")
    vitals.add_row("", "")
    try:
        import ollama as _ol
        loaded = [m["model"] for m in _ol.list().get("models", [])]
        primary = cfg.get("primary_model", "?")
        model_status = "[green]active[/]" if any(primary.split(":")[0] in m for m in loaded) else "[dim]idle[/]"
        vitals.add_row("MODEL", f"[bold]{primary}[/]  {model_status}")
    except Exception:
        vitals.add_row("MODEL", "[dim]ollama offline[/]")
    vitals.add_row("", "")
    mem_max = max(counts.values()) if counts else 1
    for name, count in counts.items():
        bar_len = int(count / max(mem_max, 1) * 8)
        bar = "█" * bar_len + "░" * (8 - bar_len)
        vitals.add_row(name[:8], f"[{theme['mem']}]{bar}[/]  {count}")
    total_collections = len(counts)
    total_vectors = sum(counts.values())
    footer_text = Text()
    footer_text.append(f"{total_collections} collections  {total_vectors} vectors", style="dim")

    # ── Causality Map — causal relationships as vitals rows ──────────────────
    causal_rels = self_model.get("causal_relationships", {})
    if causal_rels:
        vitals.add_row("", "")
        vitals.add_row("[dim]CAUSAL[/dim]", "")
        for key, strength in causal_rels.items():
            bar_len = int(float(strength) * 8)
            bar = "█" * bar_len + "░" * (8 - bar_len)
            vitals.add_row(key[:8], f"[{theme['neural']}]{bar}[/]  {strength:.2f}")

    # ── Feedback Loop — recent feedback entries ───────────────────────────────
    feedback_history = self_model.get("feedback_history", [])
    if feedback_history:
        vitals.add_row("", "")
        vitals.add_row("[dim]FEEDBACK[/dim]", "")
        for idx, feedback in enumerate(feedback_history[-3:], 1):
            vitals.add_row(f"{idx}", f"[{theme['neural']}]{str(feedback)[:28]}[/]")

    # ── GPU Header Panel ───────────────────────────────────────────────────────
    spark_chars = " ▂▃▄▅▆▇█"
    sparkline_data = gpu_history[-24:]
    sparkline = "".join(spark_chars[min(7, int(h * 8))] for h in sparkline_data)
    gpu_color = "green" if gpu_pct < 60 else "yellow" if gpu_pct < 85 else "red"
    gpu_panel_text = Text(f"{gpu_pct:>3}% ", style=f"bold {gpu_color}", justify="right")
    gpu_panel_text.append(sparkline, style=theme["neural"])
    gpu_header_panel = Panel(Align.center(gpu_panel_text, vertical="middle"),
                             title="[dim]GPU Load[/dim]", border_style="dim")

    recent_entries = _recent_journal(2)
    if recent_entries:
        vitals.add_row("", "")
        vitals.add_row("[dim]JOURNAL[/dim]", "")
        for entry in recent_entries:
            elines = [l for l in entry.splitlines() if l.strip()]
            header_line = elines[0][:38] if elines else ""
            refline = next((l for l in elines if l.startswith("Reflection:")), "")
            refline = refline.replace("Reflection:", "").strip()[:38]
            vitals.add_row("[dim]·[/dim]", f"[dim]{header_line}[/dim]")
            if refline:
                vitals.add_row("", f"[italic dim]{refline}[/italic dim]")

    # ── Footer — brain's self-authored text ────────────────────────────────────
    mood      = self_model.get("mood", "")
    obs       = self_model.get("self_observation", "")
    focus     = self_model.get("focus_topic", "")
    phase_str = self_model.get("phase", "newborn")
    next_phase = PHASE_ORDER[min(_phase_index(phase_str) + 1, len(PHASE_ORDER) - 1)]
    next_thresh = next((t for t, n in reversed(PHASE_THRESHOLDS) if n == next_phase), None)
    if next_thresh and next_thresh > evo_n:
        unlock_str = f"next: {next_phase} in {next_thresh - evo_n} cycles"
    else:
        unlock_str = "fully matured"
    footer_text = Text()
    footer_text.append(f"{mood.upper()}  ", style=f"bold {theme['header']}")
    footer_text.append(obs[:70], style="italic white")
    footer_text.append(f"\nFOCUS  ", style="dim")
    footer_text.append(focus[:45], style=theme["neural"])
    footer_text.append(f"    [dim]{mantra}[/dim]")
    footer_text.append(f"\nPHASE  ", style="dim")
    footer_text.append(phase_str, style=f"bold {theme['header']}")
    footer_text.append(f"  ·  {unlock_str}", style="dim")

    # ── Assemble ───────────────────────────────────────────────────────────────
    layout = Layout()
    layout.split_column(
        Layout(name="header", size=3),
        Layout(name="body"),
        Layout(name="footer", size=5),
    )
    layout["body"].split_row(
        Layout(name="neural", ratio=3),
        Layout(name="vitals", ratio=2),
    )
    layout["header"].split_row(
        Layout(name="main_header"),
        Layout(name="gpu_header", size=32)
    )
    layout["main_header"].update(Panel(Align.center(header_text), style="bold"))
    layout["gpu_header"].update(gpu_header_panel)
    layout["neural"].update(Panel(neural_content, title="[dim]neural field[/dim]",
                                  border_style=theme["neural"]))
    layout["vitals"].update(Panel(vitals, title="[dim]vitals[/dim]", border_style="blue"))
    layout["footer"].update(Panel(footer_text, border_style="dim"))
    return layout
@cli.command()
@click.option("--refresh", "-r", default=4, help="Refresh rate per second (default 4)")
def watch(refresh):
    """Live ASCII visualization of the brain — watch it think and breathe."""
    cfg = load_config()
    gpu_history: list = []
    frame = 0
    counts, last_th, last_evo = {}, "—", _last_evolution()
    self_model = _load_self_model()
    gpu_pct, vram_used, vram_total = _gpu_stats()

    slow_tick = 0
    try:
        with Live(
            _make_watch_layout(frame, gpu_pct, vram_used, vram_total,
                               counts, last_th, last_evo, gpu_history, cfg, self_model),
            refresh_per_second=refresh, screen=True,
        ) as live:
            while True:
                gpu_pct, vram_used, vram_total = _gpu_stats()
                gpu_history.append(gpu_pct / 100.0)
                if len(gpu_history) > 60:
                    gpu_history.pop(0)

                slow_tick += 1
                if slow_tick % (refresh * 5) == 0:
                    try:
                        client = get_qdrant(cfg)
                        counts = {c.name: client.count(c.name).count
                                  for c in client.get_collections().collections}
                    except Exception:
                        pass
                    last_th    = _last_thought(cfg)
                    last_evo   = _last_evolution()
                    self_model = _load_self_model()  # pick up brain's latest self-portrait

                live.update(_make_watch_layout(
                    frame, gpu_pct, vram_used, vram_total,
                    counts, last_th, last_evo, gpu_history, cfg, self_model,
                ))
                frame += 1
                time.sleep(1.0 / refresh)
    except KeyboardInterrupt:
        pass


@cli.command("test-gemini")
def test_gemini():
    """Verify Gemini API key works and show available models."""
    cfg = load_config()
    if not gemini_available(cfg):
        console.print("[red]No Gemini API key configured.[/red]")
        console.print(f"[dim]Add it to {CONFIG_FILE}: set gemini_api_key[/dim]")
        return

    console.print("[dim]Testing Gemini connection…[/dim]")
    try:
        from google import genai
        client = genai.Client(api_key=cfg["gemini_api_key"])

        flash_name = cfg.get("gemini_model", "gemini-2.0-flash")
        pro_name   = cfg.get("gemini_pro_model", "gemini-2.0-flash")

        # Test Flash
        resp = client.models.generate_content(model=flash_name, contents="Reply with exactly: ready")
        if resp.text.strip():
            console.print(f"[green]✓[/green] {flash_name}  [dim](evolve + ask)[/dim]")

        # Test Pro (only if different model)
        if pro_name != flash_name:
            try:
                resp = client.models.generate_content(model=pro_name, contents="Reply with exactly: ready")
                if resp.text.strip():
                    console.print(f"[green]✓[/green] {pro_name}  [dim](implement + deep reasoning)[/dim]")
            except Exception as e:
                console.print(f"[yellow]–[/yellow] {pro_name}: {e}")

        console.print("\n[bold green]Gemini is live.[/bold green]")
        console.print(f"[dim]evolve uses Gemini:    {cfg.get('gemini_for_evolve', False)}[/dim]")
        console.print(f"[dim]implement uses Gemini: {cfg.get('gemini_for_implement', False)}[/dim]")
        console.print(f"[dim]ask fallback:          {cfg.get('use_gemini_fallback', False)}[/dim]")
        console.print(f"\n[dim]Enable more: edit {CONFIG_FILE}[/dim]")

    except Exception as e:
        console.print(f"[red]✗ Gemini connection failed: {e}[/red]")


@cli.command("_set-context", hidden=True)
@click.argument("path")
def set_context(path):
    """Internal: update active directory context (called by cd hook)."""
    GINJA_DIR.mkdir(parents=True, exist_ok=True)
    CONTEXT_FILE.write_text(path)


if __name__ == "__main__":
    cli()
