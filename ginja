@click.group()
@click.pass_context
def cli(ctx):
    """ginja — FOSS-first personal second brain CLI."""
    ctx.ensure_object(dict)
    ctx.obj["cfg"] = load_config()


# ── ask ─────────────────────────────────────────────────────────────────────

@cli.command()
@click.argument("question")
@click.option("--fast",   "-f", is_flag=True, help="Use fast model (llama3.2:3b)")
@click.option("--code",   "-c", is_flag=True, help="Use code model (qwen2.5-coder:7b)")
@click.option("--hard",         is_flag=True, help="Use Gemini fallback (requires API key)")
@click.option("--oracle", "-o", is_flag=True, help="Use cloud oracle — local models exhausted? Use when local has already failed.")
@click.option("--no-rag",       is_flag=True, help="Skip RAG memory injection")
@click.option("--top-k", "top_k", type=int, default=None, help="Memories to retrieve (overrides config)")
@click.option("--model",  "-m", default=None, help="Override model directly")
@click.pass_context
def ask(ctx, question, fast, code, hard, oracle, no_rag, top_k, model):
    """One-shot question with streaming output and RAG context."""
    cfg = ctx.obj["cfg"]
    if top_k is not None:
        cfg["top_k"] = top_k

    if oracle:
        console.print("[dim][oracle] Cloud API call — costs money. Local models exhausted? Proceeding...[/dim]")
        context = ""
        if not no_rag:
            context, _ = build_rag_context(cfg, question)
        persona_path = pathlib.Path(cfg.get("persona_file", str(PERSONA_FILE)))
        persona = (
            persona_path.read_text(encoding="utf-8").strip()
            if persona_path.exists()
            else "You are a helpful personal assistant named Ginja."
        )
