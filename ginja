# ── SECTION 10: Flask serve ─────────────────────────────────────────────────

def _run_flask_server(cfg: dict, port: int) -> None:
    try:
        from flask import Flask, request, jsonify
    except ImportError:
        raise click.ClickException("serve requires: pip install flask")

    # Initialise Qdrant connection once, reuse across requests
    q_client = get_qdrant(cfg)
    ensure_collection(q_client)

    app = Flask("ginja")

    @app.route("/health", methods=["GET"])
    def health():
        return jsonify({"status": "ok", "service": "ginja"})

    @app.route("/ask", methods=["POST"])
    def handle_ask():
        data = request.get_json(force=True) or {}
        query = data.get("query", "").strip()
        if not query:
            return jsonify({"error": "query field required"}), 400
        fast   = bool(data.get("fast", False))
        hard   = bool(data.get("hard", False))
        code   = bool(data.get("code", False))
        no_rag = bool(data.get("no_rag", False))
        chosen = data.get("model") or route_model(cfg, query, fast=fast, code=code, hard=hard)
        context_str = ""
        if not no_rag:
            try:
                context_str, _ = build_rag_context(cfg, query)
            except Exception:
                pass
        messages = build_messages(cfg, query, context_str)
        try:
            if chosen == "gemini":
                answer = ollama_generate_gemini(cfg, messages)
            else:
                answer = ollama_stream(cfg, chosen, messages, print_live=False)
            return jsonify({"answer": answer, "model": chosen})
        except click.ClickException as e:
            return jsonify({"error": e.format_message()}), 500

    @app.route("/remember", methods=["POST"])
    def handle_remember():
        data = request.get_json(force=True) or {}
        text = data.get("text", "").strip()
        if not text:
            return jsonify({"error": "text field required"}), 400
        source = data.get("source", "n8n")
        try:
            vector = ollama_embed(cfg, text)
            pid    = qdrant_store(q_client, text, vector, {"source": source})
            return jsonify({"stored": True, "id": pid})
        except click.ClickException as e:
            return jsonify({"error": e.format_message()}), 500

    @app.route("/recall", methods=["POST"])
    def handle_recall():
        data = request.get_json(force=True) or {}
        query = data.get("query", "").strip()
        if not query:
            return jsonify({"error": "query field required"}), 400
        top_k = int(data.get("top_k", cfg["top_k"]))
        try:
            vector  = ollama_embed(cfg, query)
            results = qdrant_search(q_client, vector, top_k=top_k)
            return jsonify({"results": results})
        except click.ClickException as e:
            return jsonify({"error": e.format_message()}), 500

    console.print(Panel(
        f"[green]Listening on[/green] [bold]http://0.0.0.0:{port}[/bold]\n\n"
        "  [cyan]POST /ask[/cyan]      {\"query\": \"...\", \"fast\": false, \"hard\": false}\n"
        "  [cyan]POST /remember[/cyan] {\"text\": \"...\", \"source\": \"n8n\"}\n"
        "  [cyan]POST /recall[/cyan]   {\"query\": \"...\", \"top_k\": 5}\n"
        "  [cyan]GET  /health[/cyan]   → {\"status\": \"ok\"}\n\n"
        "[dim]Ctrl-C to stop[/dim]",
        title="[bold cyan]ginja serve[/bold cyan]",
        expand=False,
    ))
    try:
        app.run(host="0.0.0.0", port=port, debug=False)
    except KeyboardInterrupt:
        console.print("\n[dim]Server stopped.[/dim]")


