    SUGGESTIONS_FILE.write_text(json.dumps(existing, indent=2, ensure_ascii=False), encoding="utf-8")


def _call_oracle_json(system_prompt: str, user_prompt: str, cfg: dict) -> dict:
    """Call the oracle silently and parse the JSON response."""
    provider = cfg.get("oracle_provider", "gemini")
    raw = ""
    if provider == "anthropic":
        try:
            import anthropic
        except ImportError:
            raise click.ClickException("evolve requires: pip install anthropic")
        api_key = cfg.get("anthropic_api_key") or os.environ.get("ANTHROPIC_API_KEY")
        if not api_key:
            raise click.ClickException(
                "Anthropic oracle requires ANTHROPIC_API_KEY or anthropic_api_key in config."
            )
        model = cfg.get("oracle_model", "claude-haiku-4-5-20251001")
        client_a = anthropic.Anthropic(api_key=api_key)
        msg = client_a.messages.create(
            model=model,
            max_tokens=2048,
            system=system_prompt,
            messages=[{"role": "user", "content": user_prompt}],
        )
        raw = msg.content[0].text
    else:
        try:
            import litellm
        except ImportError:
            raise click.ClickException("evolve requires: pip install litellm")
        api_key = cfg.get("gemini_api_key") or os.environ.get("GEMINI_API_KEY")
        if not api_key:
            raise click.ClickException(
                "Gemini oracle requires GEMINI_API_KEY or gemini_api_key in config."
            )
        resp = litellm.completion(
            model="gemini/gemini-1.5-pro",
            messages=[
                {"role": "system", "content": system_prompt},
                {"role": "user",   "content": user_prompt},
            ],
            api_key=api_key,
        )
        raw = resp.choices[0].message.content

    cleaned = re.sub(r"^```(?:json)?\s*", "", raw.strip(), flags=re.MULTILINE)
    cleaned = re.sub(r"\s*```$", "", cleaned.strip(), flags=re.MULTILINE)
    try:
        return json.loads(cleaned)
    except json.JSONDecodeError as e:
        raise click.ClickException(
            f"Oracle returned invalid JSON: {e}\n\nRaw response (first 500 chars):\n{raw[:500]}"
        )


