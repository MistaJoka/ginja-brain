def ingest(ctx, target, chunk_size, overlap, source):
    """Chunk a file or URL and store every chunk as a searchable memory."""
    cfg = ctx.obj["cfg"]
    with console.status(f"[bold green]Loading {target}..."):
        text, detected_source = load_text_from_path(target)
    source_label = source or detected_source
    chunks = chunk_text(text, chunk_size=chunk_size, overlap=overlap)
    if not chunks:
        raise click.ClickException("No text content found to ingest.")

    client = get_qdrant(cfg)
    with console.status("[bold green]Ingesting...") as status:
        for i, chunk in enumerate(chunks, 1):
            status.update(f"[bold green]Ingesting chunk {i}/{len(chunks)}...")
            vector = ollama_embed(cfg, chunk)
            qdrant_store(client, chunk, vector, {"source": source_label, "chunk_index": i})
    console.print(
        f"[green]✓[/green] Ingested [bold]{len(chunks)}[/bold] chunks "
        f"from [dim]{source_label}[/dim]"
