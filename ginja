def load_config() -> dict:
    cfg = DEFAULT_CONFIG.copy()
    if CONFIG_FILE.exists():
        with open(CONFIG_FILE, encoding="utf-8") as f:
            file_cfg = yaml.safe_load(f) or {}
        cfg.update(file_cfg)
    for env_key, cfg_key in _ENV_MAP.items():
        val = os.environ.get(env_key)
        if val is not None:
            cfg[cfg_key] = int(val) if cfg_key == "top_k" else val
    return cfg


# ── SECTION 3: Ollama Client ────────────────────────────────────────────────

def ollama_embed(cfg: dict, text: str) -> list:
    """POST /api/embeddings → list[float]. Synchronous."""
    url = cfg["ollama_url"] + "/api/embeddings"
    try:
        with httpx.Client(timeout=30) as client:
            r = client.post(url, json={"model": cfg["embed_model"], "prompt": text})
            if r.status_code == 404:
                raise click.ClickException(
                    f"Embed model '{cfg['embed_model']}' not found.\n"
                    f"Pull it with: ollama pull {cfg['embed_model']}"
                )
            r.raise_for_status()
            data = r.json()
            return data.get("embedding") or data.get("embeddings", [[]])[0]
    except click.ClickException:
        raise
    except httpx.ConnectError:
        raise click.ClickException(
            f"Cannot reach Ollama at {cfg['ollama_url']}.\n"
            "Start it with: ollama serve"
        )
    except Exception as e:
        raise click.ClickException(f"Embedding failed: {e}")


def ollama_stream(cfg: dict, model: str, messages: list, print_live: bool = True) -> str:
    """
    POST /api/chat with stream=True. Ollama returns NDJSON — one JSON object
    per line. Prints tokens to stdout when print_live=True. Always returns the
    full assembled response string.
    """
    url = cfg["ollama_url"] + "/api/chat"
    payload = {
        "model": model,
        "messages": messages,
        "stream": True,
        "options": {"num_ctx": 4096},   # cap context to fit GTX 970 4GB VRAM
    }
    full_response: list[str] = []
    try:
        with httpx.Client(timeout=180) as client:
            with client.stream("POST", url, json=payload) as response:
                if response.status_code == 404:
                    raise click.ClickException(
                        f"Model '{model}' not found in Ollama.\n"
                        f"Pull it with: ollama pull {model}"
                    )
                response.raise_for_status()
                for line in response.iter_lines():
                    if not line:
                        continue
                    try:
                        chunk = json.loads(line)
                    except json.JSONDecodeError:
                        continue
                    token = chunk.get("message", {}).get("content", "")
                    if token:
                        full_response.append(token)
                        if print_live:
                            print(token, end="", flush=True)
                    if chunk.get("done"):
                        break
    except click.ClickException:
        raise
    except httpx.ConnectError:
        raise click.ClickException(
            f"Cannot reach Ollama at {cfg['ollama_url']}. Is it running?"
        )
    except Exception as e:
        raise click.ClickException(f"Generation failed: {e}")
    if print_live:
        print()  # final newline after stream
    return "".join(full_response)


def ollama_generate_gemini(cfg: dict, messages: list) -> str:
    """Gemini fallback via litellm. Lazy-imported so it's optional."""
    try:
        import litellm
    except ImportError:
        raise click.ClickException("--hard flag requires: pip install litellm")
    api_key = cfg.get("gemini_api_key") or os.environ.get("GEMINI_API_KEY")
    if not api_key:
        raise click.ClickException(
            "Gemini requires an API key.\n"
            "Set GINJA_GEMINI_API_KEY env var or add gemini_api_key to ~/.ginja/config.yaml."
        )
    try:
        response = litellm.completion(
            model=cfg["gemini_model"],
            messages=messages,
            api_key=api_key,
        )
        return response.choices[0].message.content
    except Exception as e:
        raise click.ClickException(f"Gemini generation failed: {e}")


def build_oracle_context(cfg: dict) -> str:
    """Package persona + recent memories for the oracle's system prompt."""
    parts = []
    persona_path = pathlib.Path(cfg.get("persona_file", str(PERSONA_FILE)))
    if persona_path.exists():
        parts.append("## Persona\n" + persona_path.read_text(encoding="utf-8").strip())
    try:
        client = get_qdrant(cfg)
        ensure_collection(client)
        scroll_result = client.scroll(
            collection_name=COLLECTION_NAME,
            limit=100,
            with_payload=True,
            with_vectors=False,
        )
        points = sorted(
            scroll_result[0],
            key=lambda p: (p.payload or {}).get("timestamp", ""),
            reverse=True,
        )[:20]
        if points:
            mem_lines = [
                f"[{(p.payload or {}).get('timestamp', '')[:10]} | "
                f"{(p.payload or {}).get('source', '?')}] "
                f"{textwrap.shorten((p.payload or {}).get('text', ''), 200)}"
                for p in points
            ]
            parts.append("## Recent Memories\n" + "\n".join(mem_lines))
    except Exception:
        pass  # non-fatal — persona alone is still useful
    return "\n\n".join(parts)


