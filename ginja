_NEURAL_CHARS = {
    "calm":          "░▒",
    "active":        "▒▓█",
    "chaotic":       "░▒▓█▄▀▌▐■□▪▫",
    "contemplative": "·∘○◌◦⋅",
}


def _render_neural_field(style: str, width: int = 44, height: int = 8) -> str:
    chars = _NEURAL_CHARS.get(style, _NEURAL_CHARS["calm"])
    t = time.time()
    rows = []
    for row in range(height):
        line = []
        for col in range(width):
            val = math.sin(t * 0.7 + row * 0.9 + col * 0.4) + math.cos(t * 0.3 + row * 0.5 - col * 0.2)
            idx = int((val + 2) / 4 * (len(chars) - 1))
            idx = max(0, min(idx, len(chars) - 1))
            line.append(chars[idx])
        rows.append("".join(line))
    return "\n".join(rows)


def _get_system_metrics() -> tuple:
    """Returns (gpu_pct_str, cpu_load_str)."""
    gpu_str = "N/A"
    try:
        out = subprocess.check_output(
            ["nvidia-smi", "--query-gpu=utilization.gpu", "--format=csv,noheader,nounits"],
            timeout=2,
            stderr=subprocess.DEVNULL,
        ).decode().strip()
        gpu_str = f"{out}%"
    except Exception:
        pass
    try:
        load = os.getloadavg()[0]
        cpu_str = f"{load:.2f}"
    except AttributeError:
        cpu_str = "N/A"
    return gpu_str, cpu_str


