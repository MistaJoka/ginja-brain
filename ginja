@cli.command()
@click.option("--fps", default=4, type=int, help="Refresh rate (default: 4)")
@click.pass_context
def watch(ctx, fps):
    """Live ASCII terminal visualization driven by the brain's self-model."""
    cfg = ctx.obj["cfg"]
    model = _load_self_model()
    color_style = _COLOR_STYLE_MAP.get(model.get("color_theme", "cyan"), "bold cyan")

    console.print(f"[dim]Watching brain · {model.get('phase', 'newborn')} · Ctrl-C to exit[/dim]")

    try:
        with Live(refresh_per_second=fps, screen=False) as live:
            while True:
                model = _load_self_model()
                color_style = _COLOR_STYLE_MAP.get(model.get("color_theme", "cyan"), "bold cyan")
                panel = _build_watch_display(model, cfg, color_style)
                live.update(panel)
                time.sleep(1.0 / fps)
    except KeyboardInterrupt:
        console.print("\n[dim]watch stopped.[/dim]")


# ── SECTION 15: approve command ─────────────────────────────────────────────

@cli.command()
@click.option("--list", "list_only", is_flag=True, help="List pending suggestions without acting.")
@click.option("--clear", is_flag=True, help="Remove all applied/skipped entries.")
@click.pass_context
def approve(ctx, list_only, clear):
    """Review and apply code suggestions queued by evolve."""
    if not SUGGESTIONS_FILE.exists():
        console.print("[yellow]No suggestions queued yet. Run: ginja evolve[/yellow]")
        return

    try:
        suggestions: list = json.loads(SUGGESTIONS_FILE.read_text(encoding="utf-8"))
    except Exception:
        console.print("[red]Could not read suggestions file.[/red]")
        return

    if clear:
        kept = [s for s in suggestions if s["status"] == "pending"]
        SUGGESTIONS_FILE.write_text(json.dumps(kept, indent=2, ensure_ascii=False), encoding="utf-8")
        console.print(f"[green]✓[/green] Cleared applied/skipped entries. {len(kept)} pending remain.")
        return

    pending = [s for s in suggestions if s["status"] == "pending"]

    if not pending:
        console.print("[dim]No pending suggestions. All caught up.[/dim]")
        return

    table = Table(title="Pending Suggestions", show_lines=True, expand=True)
    table.add_column("#",      style="dim",    width=3)
    table.add_column("ID",     style="dim",    width=10)
    table.add_column("Added",  style="dim",    width=12)
    table.add_column("Suggestion", style="white", ratio=1)
    for i, s in enumerate(pending, 1):
        table.add_row(str(i), s["id"][:8], s.get("added", "—"), s["text"])
    console.print(table)

    if list_only:
        return

    console.print("\n[dim]Mark each suggestion: [y] apply  [n] skip  [q] quit[/dim]")
    applied = skipped = 0
    suggestions_by_id = {s["id"]: s for s in suggestions}

    for s in pending:
        try:
            answer = input(f"\n[{s['id'][:8]}] {s['text']}\n  → ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            break
        if answer == "q":
            break
        elif answer == "y":
            suggestions_by_id[s["id"]]["status"] = "applied"
            applied += 1
        elif answer == "n":
            suggestions_by_id[s["id"]]["status"] = "skipped"
            skipped += 1

    SUGGESTIONS_FILE.write_text(
        json.dumps(list(suggestions_by_id.values()), indent=2, ensure_ascii=False),
        encoding="utf-8",
    )
    console.print(f"\n[green]✓[/green] {applied} applied · {skipped} skipped")
    if applied:
        console.print("[dim]Suggestions marked applied — implement them in the ginja script, then re-run ginja watch.[/dim]")


