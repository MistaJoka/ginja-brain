# ── SECTION 4: Qdrant Client ────────────────────────────────────────────────

_collection_ready = False  # cached per-process; helps in serve mode


def get_qdrant(cfg: dict) -> QdrantClient:
    try:
        kwargs: dict = {"url": cfg["qdrant_url"]}
        if cfg.get("qdrant_api_key"):
            kwargs["api_key"] = cfg["qdrant_api_key"]
        client = QdrantClient(**kwargs)
        client.get_collections()  # connectivity check
        return client
    except Exception as e:
        raise click.ClickException(
            f"Cannot reach Qdrant at {cfg['qdrant_url']}.\n"
            f"Start it with: docker compose up -d qdrant\nDetail: {e}"
        )


def ensure_collection(client: QdrantClient) -> None:
    global _collection_ready
    if _collection_ready:
        return
    existing = {c.name for c in client.get_collections().collections}
    if COLLECTION_NAME not in existing:
        client.create_collection(
            collection_name=COLLECTION_NAME,
            vectors_config=VectorParams(size=EMBEDDING_DIM, distance=Distance.COSINE),
        )
        console.print(f"[green]Created Qdrant collection '{COLLECTION_NAME}'[/green]")
    _collection_ready = True


def _text_id(text: str) -> str:
    """Deterministic UUID from text content — enables idempotent upserts."""
    return str(uuid.uuid5(uuid.NAMESPACE_OID, text))


def qdrant_store(client: QdrantClient, text: str, vector: list, metadata: dict) -> str:
    ensure_collection(client)
    point_id = _text_id(text)
    payload = {
        "text": text,
        "timestamp": datetime.datetime.utcnow().isoformat(),
        **metadata,
    }
    client.upsert(
        collection_name=COLLECTION_NAME,
        points=[PointStruct(id=point_id, vector=vector, payload=payload)],
    )
    return point_id


def qdrant_search(client: QdrantClient, vector: list, top_k: int = 5) -> list:
    ensure_collection(client)
    results = client.search(
        collection_name=COLLECTION_NAME,
        query_vector=vector,
        limit=top_k,
        with_payload=True,
    )
    return [
        {
            "text":      r.payload.get("text", ""),
            "score":     round(r.score, 4),
            "source":    r.payload.get("source", "manual"),
            "timestamp": r.payload.get("timestamp", ""),
        }
        for r in results
    ]


# ── SECTION 5: RAG Pipeline ─────────────────────────────────────────────────

def build_rag_context(cfg: dict, query: str) -> tuple:
    """
    Embed query → search Qdrant → filter by score → format context block.
    Returns (context_str, raw_results). RAG failures are non-fatal for
    ask/chat — caller gets empty context instead of an error.
    """
    try:
        vector = ollama_embed(cfg, query)
        client = get_qdrant(cfg)
        results = qdrant_search(client, vector, top_k=cfg["top_k"])
    except click.ClickException:
        raise
    except Exception:
        return "", []

    relevant = [r for r in results if r["score"] >= RAG_MIN_SCORE]
    if not relevant:
        return "", []

    snippets = [
        f"[Memory {i} | score={r['score']} | source={r['source']}]\n{r['text']}"
        for i, r in enumerate(relevant, 1)
    ]
    context_block = (
        "--- Relevant memories ---\n"
        + "\n\n".join(snippets)
        + "\n--- End memories ---"
    )
    return context_block, relevant


def build_messages(cfg: dict, query: str, context: str, history: list = None) -> list:
    """
    Assemble messages list for /api/chat.
    Order: system (persona + context) → conversation history → user query
    """
    persona_path = pathlib.Path(cfg.get("persona_file", str(PERSONA_FILE)))
    persona = (
        persona_path.read_text(encoding="utf-8")
        if persona_path.exists()
        else "You are a helpful personal assistant named Ginja."
    )

    system_parts = [persona.strip()]
    if context:
        system_parts.append(context)

    messages = [{"role": "system", "content": "\n\n".join(system_parts)}]
    if history:
        messages.extend(history)
    messages.append({"role": "user", "content": query})
    return messages


# ── SECTION 6: Model Router ─────────────────────────────────────────────────

def route_model(cfg: dict, query: str,
                fast: bool = False, code: bool = False, hard: bool = False) -> str:
    """
    Dispatch to the right model. Priority:
    --hard > --fast > --code > code_heuristic(query) > default
    Returns model name string or "gemini" sentinel for Gemini fallback.
    """
    if hard:
        return "gemini"
    if fast:
        return cfg["fast_model"]
    if code:
        return cfg["code_model"]
    if _detect_code(query):
        return cfg["code_model"]
    return cfg["default_model"]


def _detect_code(text: str) -> bool:
    """Heuristic code detection: fences, extensions, or 2+ keyword hits."""
    if "```" in text:
        return True
    text_lower = text.lower()
    if re.search(
        r'\b\w+\.(py|js|ts|rs|go|java|sh|bash|c|cpp|h|rb|php|sql|css|html|yaml|toml|json)\b',
        text_lower
    ):
        return True
    hits = sum(1 for kw in CODE_KEYWORDS if kw in text_lower)
    return hits >= 2


# ── SECTION 7: Chunker ──────────────────────────────────────────────────────

def chunk_text(text: str, chunk_size: int = CHUNK_SIZE, overlap: int = CHUNK_OVERLAP) -> list:
    """
    Split text into overlapping chunks.
    Token count approximated as word_count * 1.3 (conservative, works for English/code).
    CJK and other scripts will over-chunk — acceptable for personal use.
    """
    words = text.split()
    if not words:
        return []
    word_chunk   = max(1, int(chunk_size / 1.3))
    word_overlap = max(0, int(overlap / 1.3))
    step         = max(1, word_chunk - word_overlap)
    chunks = []
    start = 0
    while start < len(words):
        end = min(start + word_chunk, len(words))
        chunks.append(" ".join(words[start:end]))
        if end == len(words):
            break
        start += step
    return chunks


def load_text_from_path(path_or_url: str) -> tuple:
    """Load text from a local file or URL. Returns (text, source_label)."""
    if path_or_url.startswith("http://") or path_or_url.startswith("https://"):
        try:
            with httpx.Client(timeout=30, follow_redirects=True) as client:
                r = client.get(path_or_url)
                r.raise_for_status()
                ct = r.headers.get("content-type", "")
                if "html" in ct:
                    text = re.sub(r'<[^>]+>', ' ', r.text)
                    text = re.sub(r'\s+', ' ', text).strip()
                else:
                    text = r.text
            return text, path_or_url
        except click.ClickException:
            raise
        except Exception as e:
            raise click.ClickException(f"Failed to fetch {path_or_url}: {e}")
    else:
        p = pathlib.Path(path_or_url).expanduser().resolve()
        if not p.exists():
            raise click.ClickException(f"File not found: {p}")
        try:
            return p.read_text(encoding="utf-8", errors="replace"), str(p)
        except Exception as e:
            raise click.ClickException(f"Cannot read {p}: {e}")


