def print_recall_results(results: list) -> None:
    if not results:
        console.print("[yellow]No memories found.[/yellow]")
        return
    table = Table(title="Ginja Memories", show_lines=True, expand=True)
    table.add_column("#",       style="dim",     width=3)
    table.add_column("Score",   style="cyan",    width=6)
    table.add_column("Source",  style="magenta", width=24)
    table.add_column("Date",    style="dim",     width=12)
    table.add_column("Text",    style="white",   ratio=1)
    for i, r in enumerate(results, 1):
        ts = r.get("timestamp", "")[:10] if r.get("timestamp") else "—"
        table.add_row(
            str(i),
            str(r["score"]),
            textwrap.shorten(r.get("source", "—"), width=24),
            ts,
            textwrap.shorten(r["text"], width=180),
        )
    console.print(table)


def print_status_panel(ollama_data: dict, qdrant_data: dict, cfg: dict) -> None:
    lines = []

    if "error" in ollama_data:
        lines.append(f"[red]Ollama:[/red]  ✗  {ollama_data['error']}")
    else:
        models = [m.get("name", "?") for m in ollama_data.get("models", [])]
        model_str = ", ".join(models) if models else "(no models pulled yet)"
        lines.append(f"[green]Ollama:[/green]  ✓  {model_str}")

    if "error" in qdrant_data:
        lines.append(f"[red]Qdrant:[/red]  ✗  {qdrant_data['error']}")
    else:
        count = qdrant_data.get("collection_count", "?")
        lines.append(f"[green]Qdrant:[/green]  ✓  {count} points in '{COLLECTION_NAME}'")

    provider = cfg.get("oracle_provider", "gemini")
    o_model  = cfg.get("oracle_model", "claude-haiku-4-5-20251001")
    has_key  = bool(
        (cfg.get("anthropic_api_key") or os.environ.get("ANTHROPIC_API_KEY"))
        if provider == "anthropic"
        else (cfg.get("gemini_api_key") or os.environ.get("GEMINI_API_KEY"))
    )
    key_icon = "[green]✓ key set[/green]" if has_key else "[red]no key[/red]"
    oracle_label = f"{provider}:{o_model}" if provider == "anthropic" else f"{provider}:gemini-1.5-pro"

    lines += [
        "",
        f"[dim]Embed model  [/dim] {cfg['embed_model']}",
        f"[dim]Fast model   [/dim] {cfg['fast_model']}",
        f"[dim]Default model[/dim] {cfg['default_model']}",
        f"[dim]Code model   [/dim] {cfg['code_model']}",
        f"[dim]Oracle       [/dim] {oracle_label}  {key_icon}",
        f"[dim]Top-k RAG    [/dim] {cfg['top_k']}",
        f"[dim]Serve port   [/dim] {cfg['serve_port']}",
        f"[dim]Persona file [/dim] {cfg.get('persona_file', str(PERSONA_FILE))}",
    ]
    console.print(Panel("\n".join(lines), title="[bold cyan]ginja status[/bold cyan]", expand=False))


