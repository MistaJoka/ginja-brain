def _evolution_arc(n: int = 10) -> str:
    if not EVOLUTION_LOG.exists():
        return "No evolution history yet."
    text = EVOLUTION_LOG.read_text(encoding="utf-8")
    sections = text.split("=" * 60)
    recent = [s.strip() for s in sections if s.strip()][-n:]
    return "\n---\n".join(recent)


def _evolution_cycle_count() -> int:
    if not EVOLUTION_LOG.exists():
        return 0
    return EVOLUTION_LOG.read_text(encoding="utf-8").count("=" * 60)


def _add_suggestions(suggestions: list) -> None:
    GINJA_DIR.mkdir(parents=True, exist_ok=True)
    existing: list = []
    if SUGGESTIONS_FILE.exists():
        try:
            existing = json.loads(SUGGESTIONS_FILE.read_text(encoding="utf-8"))
        except Exception:
