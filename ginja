        return

    chosen = model or route_model(cfg, question, fast=fast, code=code, hard=hard)
    context = ""
    if not no_rag:
        context, _ = build_rag_context(cfg, question)

    messages = build_messages(cfg, question, context)

    if chosen == "gemini":
        console.print("[dim]Model: Gemini[/dim]")
