@cli.command()
@click.option("--fast",   "-f", is_flag=True, help="Force fast model")
@click.option("--code",   "-c", is_flag=True, help="Force code model")
@click.option("--hard",         is_flag=True, help="Force Gemini")
@click.option("--no-rag",       is_flag=True, help="Disable RAG for this session")
@click.option("--session",      default=None, help="Session name to resume (default: timestamp)")
@click.pass_context
def chat(ctx, fast, code, hard, no_rag, session):
    """Interactive REPL with persistent history and RAG context."""
    cfg = ctx.obj["cfg"]
    HISTORY_DIR.mkdir(parents=True, exist_ok=True)
    session_id   = session or datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    history_file = HISTORY_DIR / f"{session_id}.json"

    conversation: list = []
    if history_file.exists():
        try:
            conversation = json.loads(history_file.read_text(encoding="utf-8"))
            console.print(
                f"[dim]Resumed session '{session_id}' "
                f"({len(conversation) // 2} prior exchanges)[/dim]"
            )
        except Exception:
            pass

    console.print(Panel(
        "[bold green]ginja chat[/bold green]  "
        "Type [bold]exit[/bold] or press Ctrl-D to quit.\n"
        f"Session: [dim]{session_id}[/dim]",
        expand=False,
    ))

    while True:
        try:
            user_input = input("\n[you] ").strip()
        except (EOFError, KeyboardInterrupt):
            console.print("\n[dim]Session saved.[/dim]")
            break
        if not user_input:
            continue
        if user_input.lower() in ("exit", "quit", ":q", "bye"):
            console.print("[dim]Session saved.[/dim]")
            break

        chosen = route_model(cfg, user_input, fast=fast, code=code, hard=hard)

        context = ""
        if not no_rag:
            try:
                context, _ = build_rag_context(cfg, user_input)
            except Exception:
                pass

        messages = build_messages(cfg, user_input, context, history=conversation)
        console.print(f"[dim][{chosen}][/dim] ", end="")

        try:
            if chosen == "gemini":
                response_text = ollama_generate_gemini(cfg, messages)
                console.print(Markdown(response_text))
            else:
                response_text = ollama_stream(cfg, chosen, messages, print_live=True)
        except click.ClickException as e:
            console.print(f"[red]Error:[/red] {e.format_message()}")
            continue

        conversation.append({"role": "user",      "content": user_input})
        conversation.append({"role": "assistant",  "content": response_text})
        try:
            history_file.write_text(json.dumps(conversation, indent=2), encoding="utf-8")
        except Exception:
            pass


