@cli.command()
@click.argument("text", required=False, default=None)
@click.option("--file", "-f", "file_path", type=click.Path(), default=None,
              help="Read and store the content of a file")
@click.pass_context
def remember(ctx, text, file_path):
    """Store text or a file as a searchable memory."""
    cfg = ctx.obj["cfg"]
    if file_path:
        content, source = load_text_from_path(file_path)
    elif text:
        content, source = text, "manual"
    else:
        raise click.ClickException("Provide text as an argument or use --file path.")

    with console.status("[bold green]Embedding and storing..."):
        vector = ollama_embed(cfg, content)
        client = get_qdrant(cfg)
        pid = qdrant_store(client, content, vector, {"source": source})
    console.print(f"[green]✓[/green] Stored  [dim](id={pid[:8]}...)[/dim]")


