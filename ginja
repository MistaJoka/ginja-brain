@cli.command()
@click.argument("target", metavar="FILE_OR_URL")
@click.option("--chunk-size", "chunk_size", type=int, default=CHUNK_SIZE,
              help="Approximate tokens per chunk (default 512)")
@click.option("--overlap", type=int, default=CHUNK_OVERLAP,
              help="Approximate token overlap between chunks (default 50)")
@click.option("--source", default=None,
              help="Override source label stored in metadata")
