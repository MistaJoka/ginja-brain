def load_config() -> dict:
    cfg = DEFAULT_CONFIG.copy()
    if CONFIG_FILE.exists():
        with open(CONFIG_FILE, encoding="utf-8") as f:
            file_cfg = yaml.safe_load(f) or {}
        cfg.update(file_cfg)
    for env_key, cfg_key in _ENV_MAP.items():
        val = os.environ.get(env_key)
        if val is not None:
            cfg[cfg_key] = int(val) if cfg_key == "top_k" else val
    return cfg


# ── SECTION 3: Ollama Client ────────────────────────────────────────────────

def ollama_embed(cfg: dict, text: str) -> list:
    """POST /api/embeddings → list[float]. Synchronous."""
    url = cfg["ollama_url"] + "/api/embeddings"
    try:
        with httpx.Client(timeout=30) as client:
            r = client.post(url, json={"model": cfg["embed_model"], "prompt": text})
            if r.status_code == 404:
                raise click.ClickException(
                    f"Embed model '{cfg['embed_model']}' not found.\n"
                    f"Pull it with: ollama pull {cfg['embed_model']}"
                )
            r.raise_for_status()
            data = r.json()
            return data.get("embedding") or data.get("embeddings", [[]])[0]
    except click.ClickException:
        raise
    except httpx.ConnectError:
        raise click.ClickException(
            f"Cannot reach Ollama at {cfg['ollama_url']}.\n"
            "Start it with: ollama serve"
        )
    except Exception as e:
        raise click.ClickException(f"Embedding failed: {e}")


def ollama_stream(cfg: dict, model: str, messages: list, print_live: bool = True) -> str:
    """
    POST /api/chat with stream=True. Ollama returns NDJSON — one JSON object
    per line. Prints tokens to stdout when print_live=True. Always returns the
    full assembled response string.
    """
    url = cfg["ollama_url"] + "/api/chat"
    payload = {
        "model": model,
        "messages": messages,
        "stream": True,
        "options": {"num_ctx": 4096},   # cap context to fit GTX 970 4GB VRAM
    }
    full_response: list[str] = []
    try:
        with httpx.Client(timeout=180) as client:
            with client.stream("POST", url, json=payload) as response:
                if response.status_code == 404:
                    raise click.ClickException(
                        f"Model '{model}' not found in Ollama.\n"
                        f"Pull it with: ollama pull {model}"
                    )
                response.raise_for_status()
                for line in response.iter_lines():
                    if not line:
                        continue
                    try:
                        chunk = json.loads(line)
                    except json.JSONDecodeError:
                        continue
                    token = chunk.get("message", {}).get("content", "")
                    if token:
                        full_response.append(token)
                        if print_live:
                            print(token, end="", flush=True)
                    if chunk.get("done"):
                        break
    except click.ClickException:
        raise
    except httpx.ConnectError:
        raise click.ClickException(
            f"Cannot reach Ollama at {cfg['ollama_url']}. Is it running?"
        )
    except Exception as e:
        raise click.ClickException(f"Generation failed: {e}")
    if print_live:
        print()  # final newline after stream
    return "".join(full_response)


def ollama_generate_gemini(cfg: dict, messages: list) -> str:
    """Gemini fallback via litellm. Lazy-imported so it's optional."""
    try:
        import litellm
    except ImportError:
        raise click.ClickException("--hard flag requires: pip install litellm")
    api_key = cfg.get("gemini_api_key") or os.environ.get("GEMINI_API_KEY")
    if not api_key:
        raise click.ClickException(
            "Gemini requires an API key.\n"
            "Set GINJA_GEMINI_API_KEY env var or add gemini_api_key to ~/.ginja/config.yaml."
        )
    try:
        response = litellm.completion(
            model=cfg["gemini_model"],
            messages=messages,
            api_key=api_key,
        )
        return response.choices[0].message.content
    except Exception as e:
        raise click.ClickException(f"Gemini generation failed: {e}")


def build_oracle_context(cfg: dict) -> str:
    """Package persona + recent memories for the oracle's system prompt."""
    parts = []
    persona_path = pathlib.Path(cfg.get("persona_file", str(PERSONA_FILE)))
    if persona_path.exists():
        parts.append("## Persona\n" + persona_path.read_text(encoding="utf-8").strip())
    try:
        client = get_qdrant(cfg)
        ensure_collection(client)
        scroll_result = client.scroll(
            collection_name=COLLECTION_NAME,
            limit=100,
            with_payload=True,
            with_vectors=False,
        )
        points = sorted(
            scroll_result[0],
            key=lambda p: (p.payload or {}).get("timestamp", ""),
            reverse=True,
        )[:20]
        if points:
            mem_lines = [
                f"[{(p.payload or {}).get('timestamp', '')[:10]} | "
                f"{(p.payload or {}).get('source', '?')}] "
                f"{textwrap.shorten((p.payload or {}).get('text', ''), 200)}"
                for p in points
            ]
            parts.append("## Recent Memories\n" + "\n".join(mem_lines))
    except Exception:
        pass  # non-fatal — persona alone is still useful
    return "\n\n".join(parts)


_ORACLE_FORMAT_INSTRUCTION = (
    "\n\nRESPONSE FORMAT: Token-optimized output only. Use structured headings, bullet points, "
    "and dense factual prose. No conversational filler, no hedging, no padding. Write as a "
    "technical knowledge base entry. Every token must carry information."
)


def ask_oracle(system_prompt: str, user_question: str, cfg: dict) -> str:
    """Call the cloud oracle (Gemini or Anthropic). Streams to stdout, returns full response."""
    full_system = system_prompt + _ORACLE_FORMAT_INSTRUCTION
    provider = cfg.get("oracle_provider", "gemini")

    if provider == "anthropic":
        try:
            import anthropic
        except ImportError:
            raise click.ClickException("Oracle (anthropic) requires: pip install anthropic")
        api_key = cfg.get("anthropic_api_key") or os.environ.get("ANTHROPIC_API_KEY")
        if not api_key:
            raise click.ClickException(
                "Anthropic oracle requires an API key.\n"
                "Set ANTHROPIC_API_KEY env var or add anthropic_api_key to ~/.ginja/config.yaml."
            )
        model = cfg.get("oracle_model", "claude-haiku-4-5-20251001")
        console.print(f"[dim]Model: {model} (oracle·anthropic)[/dim]")
        client_a = anthropic.Anthropic(api_key=api_key)
        parts: list[str] = []
        with client_a.messages.stream(
            model=model,
            max_tokens=2048,
            system=full_system,
            messages=[{"role": "user", "content": user_question}],
        ) as stream:
            for text in stream.text_stream:
                print(text, end="", flush=True)
                parts.append(text)
        print()
        return "".join(parts)

    else:  # gemini via litellm — consistent with existing --hard path
        try:
            import litellm
        except ImportError:
            raise click.ClickException("Oracle (gemini) requires: pip install litellm")
        api_key = cfg.get("gemini_api_key") or os.environ.get("GEMINI_API_KEY")
        if not api_key:
            raise click.ClickException(
                "Gemini oracle requires an API key.\n"
                "Set GINJA_GEMINI_API_KEY env var or add gemini_api_key to ~/.ginja/config.yaml."
            )
        oracle_model = "gemini/gemini-1.5-pro"
        console.print(f"[dim]Model: {oracle_model} (oracle·gemini)[/dim]")
        resp = litellm.completion(
            model=oracle_model,
            messages=[
                {"role": "system", "content": full_system},
                {"role": "user",   "content": user_question},
            ],
            api_key=api_key,
        )
        result = resp.choices[0].message.content
        console.print(result)
        return result


# ── SECTION 4: Qdrant Client ────────────────────────────────────────────────

_collection_ready = False  # cached per-process; helps in serve mode


def get_qdrant(cfg: dict) -> QdrantClient:
    try:
        kwargs: dict = {"url": cfg["qdrant_url"]}
        if cfg.get("qdrant_api_key"):
            kwargs["api_key"] = cfg["qdrant_api_key"]
        client = QdrantClient(**kwargs)
        client.get_collections()  # connectivity check
        return client
    except Exception as e:
        raise click.ClickException(
            f"Cannot reach Qdrant at {cfg['qdrant_url']}.\n"
            f"Start it with: docker compose up -d qdrant\nDetail: {e}"
        )


def ensure_collection(client: QdrantClient) -> None:
    global _collection_ready
    if _collection_ready:
        return
    existing = {c.name for c in client.get_collections().collections}
    if COLLECTION_NAME not in existing:
        client.create_collection(
            collection_name=COLLECTION_NAME,
            vectors_config=VectorParams(size=EMBEDDING_DIM, distance=Distance.COSINE),
        )
        console.print(f"[green]Created Qdrant collection '{COLLECTION_NAME}'[/green]")
    _collection_ready = True


def _text_id(text: str) -> str:
    """Deterministic UUID from text content — enables idempotent upserts."""
    return str(uuid.uuid5(uuid.NAMESPACE_OID, text))


def qdrant_store(client: QdrantClient, text: str, vector: list, metadata: dict) -> str:
    ensure_collection(client)
    point_id = _text_id(text)
    payload = {
        "text": text,
        "timestamp": datetime.datetime.utcnow().isoformat(),
        **metadata,
    }
    client.upsert(
        collection_name=COLLECTION_NAME,
        points=[PointStruct(id=point_id, vector=vector, payload=payload)],
    )
    return point_id


def qdrant_search(client: QdrantClient, vector: list, top_k: int = 5) -> list:
    ensure_collection(client)
    results = client.search(
        collection_name=COLLECTION_NAME,
        query_vector=vector,
        limit=top_k,
        with_payload=True,
    )
    return [
        {
            "text":      r.payload.get("text", ""),
            "score":     round(r.score, 4),
            "source":    r.payload.get("source", "manual"),
            "timestamp": r.payload.get("timestamp", ""),
        }
        for r in results
    ]


# ── SECTION 5: RAG Pipeline ─────────────────────────────────────────────────

def build_rag_context(cfg: dict, query: str) -> tuple:
    """
    Embed query → search Qdrant → filter by score → format context block.
    Returns (context_str, raw_results). RAG failures are non-fatal for
    ask/chat — caller gets empty context instead of an error.
    """
    try:
        vector = ollama_embed(cfg, query)
        client = get_qdrant(cfg)
        results = qdrant_search(client, vector, top_k=cfg["top_k"])
    except click.ClickException:
        raise
    except Exception:
        return "", []

    relevant = [r for r in results if r["score"] >= RAG_MIN_SCORE]
    if not relevant:
        return "", []

    snippets = [
        f"[Memory {i} | score={r['score']} | source={r['source']}]\n{r['text']}"
        for i, r in enumerate(relevant, 1)
    ]
    context_block = (
        "--- Relevant memories ---\n"
        + "\n\n".join(snippets)
        + "\n--- End memories ---"
    )
    return context_block, relevant


def build_messages(cfg: dict, query: str, context: str, history: list = None) -> list:
    """
    Assemble messages list for /api/chat.
    Order: system (persona + context) → conversation history → user query
    """
    persona_path = pathlib.Path(cfg.get("persona_file", str(PERSONA_FILE)))
    persona = (
        persona_path.read_text(encoding="utf-8")
        if persona_path.exists()
        else "You are a helpful personal assistant named Ginja."
    )

    system_parts = [persona.strip()]
    if context:
        system_parts.append(context)

    messages = [{"role": "system", "content": "\n\n".join(system_parts)}]
    if history:
        messages.extend(history)
    messages.append({"role": "user", "content": query})
    return messages


# ── SECTION 6: Model Router ─────────────────────────────────────────────────

def route_model(cfg: dict, query: str,
                fast: bool = False, code: bool = False, hard: bool = False) -> str:
    """
    Dispatch to the right model. Priority:
    --hard > --fast > --code > code_heuristic(query) > default
    Returns model name string or "gemini" sentinel for Gemini fallback.
    """
    if hard:
        return "gemini"
    if fast:
        return cfg["fast_model"]
    if code:
        return cfg["code_model"]
    if _detect_code(query):
        return cfg["code_model"]
    return cfg["default_model"]


def _detect_code(text: str) -> bool:
    """Heuristic code detection: fences, extensions, or 2+ keyword hits."""
    if "```" in text:
        return True
    text_lower = text.lower()
    if re.search(
        r'\b\w+\.(py|js|ts|rs|go|java|sh|bash|c|cpp|h|rb|php|sql|css|html|yaml|toml|json)\b',
        text_lower
    ):
        return True
    hits = sum(1 for kw in CODE_KEYWORDS if kw in text_lower)
    return hits >= 2


# ── SECTION 7: Chunker ──────────────────────────────────────────────────────

def chunk_text(text: str, chunk_size: int = CHUNK_SIZE, overlap: int = CHUNK_OVERLAP) -> list:
    """
    Split text into overlapping chunks.
    Token count approximated as word_count * 1.3 (conservative, works for English/code).
    CJK and other scripts will over-chunk — acceptable for personal use.
    """
    words = text.split()
    if not words:
        return []
    word_chunk   = max(1, int(chunk_size / 1.3))
    word_overlap = max(0, int(overlap / 1.3))
    step         = max(1, word_chunk - word_overlap)
    chunks = []
    start = 0
    while start < len(words):
        end = min(start + word_chunk, len(words))
        chunks.append(" ".join(words[start:end]))
        if end == len(words):
            break
        start += step
    return chunks


def load_text_from_path(path_or_url: str) -> tuple:
    """Load text from a local file or URL. Returns (text, source_label)."""
    if path_or_url.startswith("http://") or path_or_url.startswith("https://"):
        try:
            with httpx.Client(timeout=30, follow_redirects=True) as client:
                r = client.get(path_or_url)
                r.raise_for_status()
                ct = r.headers.get("content-type", "")
                if "html" in ct:
                    text = re.sub(r'<[^>]+>', ' ', r.text)
                    text = re.sub(r'\s+', ' ', text).strip()
                else:
                    text = r.text
            return text, path_or_url
        except click.ClickException:
            raise
        except Exception as e:
            raise click.ClickException(f"Failed to fetch {path_or_url}: {e}")
    else:
        p = pathlib.Path(path_or_url).expanduser().resolve()
        if not p.exists():
            raise click.ClickException(f"File not found: {p}")
        try:
            return p.read_text(encoding="utf-8", errors="replace"), str(p)
        except Exception as e:
            raise click.ClickException(f"Cannot read {p}: {e}")


