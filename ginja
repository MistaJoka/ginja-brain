@cli.command()
@click.argument("question")
@click.option("--save", "-s", is_flag=True,
              help="Store oracle response to memory so ginja learns from it.")
@click.option("--no-context", "no_context", is_flag=True,
              help="Skip persona/memory context (faster, cheaper).")
@click.pass_context
def counsel(ctx, question, save, no_context):
    """Ask the cloud oracle for guidance — last resort when local models have failed.

    Try 'ginja ask' and 'ginja recall' first. The oracle teaches; use --save to store
    its answer so ginja learns and won't need to ask again.
    """
    cfg = ctx.obj["cfg"]
    console.print("[dim][oracle] Cloud API call — costs money. Local models exhausted? Proceeding...[/dim]")

    system = (
        "You are a senior technical guide for ginja-brain, a local AI assistant running on "
        "constrained hardware (4GB VRAM, 3–7B parameter models). Its local resources could not "
        "adequately answer the question below. Explain clearly and teach — your response will be "
        "stored as a memory so ginja learns and won't need to ask again. Factor in its hardware "
        "constraints when suggesting tools, models, or techniques."
    )

    if not no_context:
        context = build_oracle_context(cfg)
        if context:
            system += "\n\nHere is its full context:\n\n" + context

    response = ask_oracle(system, question, cfg)

    if save:
        try:
            with console.status("[bold green]Saving oracle response to memory..."):
                vector = ollama_embed(cfg, response)
                client = get_qdrant(cfg)
                qdrant_store(client, response, vector, {"source": "oracle"})
            console.print("[green]✓[/green] Oracle response saved to memory.")
        except Exception as e:
            console.print(f"[yellow]Warning: could not save to memory: {e}[/yellow]")


