    else:  # gemini via litellm — consistent with existing --hard path
        try:
            import litellm
        except ImportError:
            raise click.ClickException("Oracle (gemini) requires: pip install litellm")
        api_key = cfg.get("gemini_api_key") or os.environ.get("GEMINI_API_KEY")
